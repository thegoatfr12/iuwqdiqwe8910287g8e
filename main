UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if activeHotkeyCaptureBox and input.UserInputType == Enum.UserInputType.Keyboard then
        local capturedKeyCode = input.KeyCode
        if capturedKeyCode and capturedKeyCode ~= Enum.KeyCode.Unknown then
            local normalized = string.upper(tostring(capturedKeyCode.Name or ""))
            activeHotkeyCaptureBox.Text = normalized
            if type(activeHotkeyCaptureApply) == "function" then
                pcall(activeHotkeyCaptureApply, capturedKeyCode)
            end
        end

        local focusedBox = activeHotkeyCaptureBox
        activeHotkeyCaptureBox = nil
        activeHotkeyCaptureApply = nil
        task.defer(function()
            if focusedBox and focusedBox.Parent then
                focusedBox:ReleaseFocus(false)
            end
        end)
        return
    end

    if gameProcessed or scriptUnloaded then
        return
    end

    local keyCode = input.KeyCode
    local keyName = tostring(keyCode.Name):upper()

    if keyCode == panicKeyCode and isAuthorized and not isFreeModeActive() then
        triggerPanicMode(true)
        refreshQuickHud()
        return
    end

    if isAuthorized and hitboxToggleHotkeyCode and keyCode == hitboxToggleHotkeyCode then
        hitboxEnabled = not hitboxEnabled
        if hitboxToggle and hitboxToggleKnob then
            setToggleSwitchState(hitboxToggle, hitboxToggleKnob, hitboxEnabled, true)
        end
        updateAffectedPlayersCountText()
        pcall(UpdatePlayers)
        showStatus(hitboxEnabled and "Hitbox: Enabled" or "Hitbox: Disabled", false)
        return
    end

    if isAuthorized and weaveGlideToggleHotkeyCode and keyCode == weaveGlideToggleHotkeyCode and not isFreeModeActive() then
        if setWeaveGlideEnabledState then
            setWeaveGlideEnabledState(not weaveGlideEnabled, true)
        else
            weaveGlideEnabled = not weaveGlideEnabled
            if weaveGlideToggle and weaveGlideToggleKnob then
                setToggleSwitchState(weaveGlideToggle, weaveGlideToggleKnob, weaveGlideEnabled, true)
            end
        end
        showStatus(weaveGlideEnabled and "Weave glide: Enabled" or "Weave glide: Disabled", false)
        return
    end

    if isAuthorized and antiWeaveToggleHotkeyCode and keyCode == antiWeaveToggleHotkeyCode and not isFreeModeActive() then
        if type(toggleAntiWeaveFromHotkey) == "function" then
            toggleAntiWeaveFromHotkey()
        elseif ApplyButton then
            ApplyButton:Activate()
        end
        return
    end

    if keyName == toggleKey and isAuthorized and MainFrame then
        if mainUiCollapsed then
            expandMainUi()
            return
        end

        MainFrame.Visible = not MainFrame.Visible
        if TOP_NOTIFICATIONS_ENABLED and MainFrame.Visible and Notification then
            Notification.Visible = true
            wait(2)
            Notification.Visible = false
        end
    end
end)

-- Whitelist and original HRP storage
whitelist = {}
originalHRPProps = {}
hitboxOutlineBoxes = {}
characterCollisionProps = setmetatable({}, {__mode = "k"})

-- Per-player connection storage for cleanup and robust handling
playerConnections = {} -- player -> { humanoidConn, diedConn, knockedConn, liveChildAddedConn, charConn }

-- Forward declaration
UpdatePlayers = nil

-- Helpers
function setAllPartsNonCollidable(character)
    if not character then
        return
    end

    local cachedProps = characterCollisionProps[character]
    if not cachedProps then
        cachedProps = setmetatable({}, {__mode = "k"})
        characterCollisionProps[character] = cachedProps
    end

    for _, part in ipairs(character:GetChildren()) do
        if part:IsA("BasePart") then
            if not cachedProps[part] then
                cachedProps[part] = {
                    CanCollide = part.CanCollide,
                    CanTouch = part.CanTouch,
                    CanQuery = part.CanQuery,
                }
            end

            part.CanCollide = false
            part.CanTouch = true
            part.CanQuery = true
        end
    end
end

function restoreCharacterCollisionState(character)
    if not character then
        return
    end

    local cachedProps = characterCollisionProps[character]
    if not cachedProps then
        return
    end

    for part, props in pairs(cachedProps) do
        if part and part.Parent and props then
            part.CanCollide = props.CanCollide
            part.CanTouch = props.CanTouch
            part.CanQuery = props.CanQuery
        end
    end

    characterCollisionProps[character] = nil
end

function getLiveEntryForPlayer(player)
    if not player then return nil end
    local live = workspace:FindFirstChild("Live")
    if not live then return nil end
    return live:FindFirstChild(player.Name)
end

function getKnockedBoolFromEntry(entry)
    if not entry then return nil end
    local knocked = entry:FindFirstChild("Knocked")
    if knocked and knocked:IsA("BoolValue") then
        return knocked
    end
    return nil
end

function clearHitboxOutline(player)
    local outline = player and hitboxOutlineBoxes[player]
    if outline then
        hitboxOutlineBoxes[player] = nil
        pcall(function()
            outline:Destroy()
        end)
    end
end

function applyHitboxVisualStyle(player, root, showSelectionsEnabled)
    if not root or not root:IsA("BasePart") then
        return
    end

    if not HITBOX_STYLE_WHEN_TRANSPARENT or not showSelectionsEnabled then
        clearHitboxOutline(player)
        return
    end

    local outline = hitboxOutlineBoxes[player]
    if not outline or not outline.Parent then
        outline = Instance.new("SelectionBox")
        outline.Name = "ToeHitboxOutline"
        hitboxOutlineBoxes[player] = outline
    end

    outline.Color3 = HITBOX_TRANSPARENT_COLOR
    outline.LineThickness = HITBOX_OUTLINE_THICKNESS
    outline.SurfaceTransparency = 1
    outline.Adornee = root
    outline.Parent = root
    root.Transparency = 1
end

function restoreHitboxVisualStyle(player, root, props)
    clearHitboxOutline(player)
    if not root or not root:IsA("BasePart") or not props then
        return
    end

    if props.Material ~= nil then
        root.Material = props.Material
    end
    if props.Color ~= nil then
        root.Color = props.Color
    end
    if props.Reflectance ~= nil then
        root.Reflectance = props.Reflectance
    end
end

-- Add/remove whitelist with immediate update
function addToWhitelist(player)
    if player and player:IsA("Player") then
        whitelist[player] = true
        pcall(UpdatePlayers)
    end
end

function removeFromWhitelist(player)
    if player and player:IsA("Player") then
        whitelist[player] = nil
        clearHitboxOutline(player)
        if player.Character then
            restoreCharacterCollisionState(player.Character)
        end
        -- restore HRP if we have stored props
        local props = originalHRPProps[player]
        if props and player.Character then
            local Root = player.Character:FindFirstChild("HumanoidRootPart")
            if Root and Root:IsA("BasePart") then
                Root.Size = props.Size
                Root.Transparency = props.Transparency
                Root.CanCollide = props.CanCollide
                Root.CanTouch = props.CanTouch
                Root.CanQuery = props.CanQuery
                restoreHitboxVisualStyle(player, Root, props)
            end
        end
        pcall(UpdatePlayers)
    end
end

-- UpdatePlayers applies HRP changes to whitelisted players and restores for others
UpdatePlayers = function()
    if scriptUnloaded then
        return
    end
    local sizeValue = hitboxEnabled and currentHitbox or 2
    local shouldApplyNoBounce = isNoBounceModeCollisionActive()
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            local humanoid = player.Character:FindFirstChildOfClass("Humanoid")
            local healthOk = humanoid and humanoid.Health > 0
            local liveEntry = getLiveEntryForPlayer(player)
            local knocked = getKnockedBoolFromEntry(liveEntry)
            local knockedFalse = not knocked or knocked.Value == false
            local shouldApplyHitbox = healthOk and ((not includeGroundedTargets) or knockedFalse)
            local Root = player.Character:FindFirstChild("HumanoidRootPart")
            if shouldApplyHitbox then
                whitelist[player] = true
                if Root and Root:IsA("BasePart") then
                    local props = originalHRPProps[player]
                    if not props then
                        props = {
                            Size = Root.Size,
                            Transparency = Root.Transparency,
                            CanCollide = Root.CanCollide,
                            CanTouch = Root.CanTouch,
                            CanQuery = Root.CanQuery,
                            Material = Root.Material,
                            Color = Root.Color,
                            Reflectance = Root.Reflectance,
                        }
                        originalHRPProps[player] = props
                    else
                        if props.Material == nil then
                            props.Material = Root.Material
                        end
                        if props.Color == nil then
                            props.Color = Root.Color
                        end
                        if props.Reflectance == nil then
                            props.Reflectance = Root.Reflectance
                        end
                    end
                    local Size = Vector3.new(sizeValue, sizeValue, sizeValue)
                    Root.Size = Size
                    Root.Transparency = 1
                    if shouldApplyNoBounce then
                        Root.CanCollide = false
                        Root.CanTouch = true
                        Root.CanQuery = true
                    else
                        Root.CanCollide = props.CanCollide
                        Root.CanTouch = props.CanTouch
                        Root.CanQuery = props.CanQuery
                    end
                    applyHitboxVisualStyle(player, Root, showHitboxSelections)
                end
                if shouldApplyNoBounce then
                    setAllPartsNonCollidable(player.Character)
                else
                    restoreCharacterCollisionState(player.Character)
                end
            else
                whitelist[player] = nil
                restoreCharacterCollisionState(player.Character)
                local props = originalHRPProps[player]
                if props and Root and Root:IsA("BasePart") then
                    Root.Size = props.Size
                    Root.Transparency = props.Transparency
                    Root.CanCollide = props.CanCollide
                    Root.CanTouch = props.CanTouch
                    Root.CanQuery = props.CanQuery
                    restoreHitboxVisualStyle(player, Root, props)
                else
                    clearHitboxOutline(player)
                end
            end
        end
    end

    pcall(updateAffectedPlayersCountText)
end

updateBootstrapStatus("Boot complete", false)
hideBootstrapStatus(2)

-- Evaluate whether player should be whitelisted based on health and knocked
function evaluateWhitelistState(player)
    if scriptUnloaded then return end
    if not player then return end
    local char = player.Character
    local humanoid = char and char:FindFirstChildOfClass("Humanoid")
    local healthOk = humanoid and humanoid.Health > 0
    local liveEntry = getLiveEntryForPlayer(player)
    local knocked = getKnockedBoolFromEntry(liveEntry)
    local knockedFalse = not knocked or knocked.Value == false
    local allowHitboxForPlayer = healthOk and ((not includeGroundedTargets) or knockedFalse)

    if allowHitboxForPlayer then
        addToWhitelist(player)
    else
        removeFromWhitelist(player)
    end
end

-- Attach Knocked listener for a given live entry and player
function attachKnockedListener(player, entry)
    if scriptUnloaded then return end
    if not player or not entry then return end
    local conTable = playerConnections[player]
    if not conTable then return end

    -- Clean previous knockedConn if exists
    if conTable.knockedConn then
        conTable.knockedConn:Disconnect()
        conTable.knockedConn = nil
    end

    local knocked = getKnockedBoolFromEntry(entry)
    if knocked then
        conTable.knockedConn = knocked.Changed:Connect(function()
            -- re-evaluate on any change
            evaluateWhitelistState(player)
        end)
        -- ensure immediate state respected
        evaluateWhitelistState(player)
    else
        -- If Knocked not present yet, attach ChildAdded to detect it
        if conTable.liveChildAddedConn then
            conTable.liveChildAddedConn:Disconnect()
            conTable.liveChildAddedConn = nil
        end
        conTable.liveChildAddedConn = entry.ChildAdded:Connect(function(child)
            if child.Name == "Knocked" and child:IsA("BoolValue") then
                -- attach knocked listener
                if conTable.knockedConn then
                    conTable.knockedConn:Disconnect()
                    conTable.knockedConn = nil
                end
                conTable.knockedConn = child.Changed:Connect(function()
                    evaluateWhitelistState(player)
                end)
                evaluateWhitelistState(player)
            end
        end)
    end
end

-- Monitor a single player: humanoid, character, and live entry
function monitorPlayer(player)
    if scriptUnloaded then return end
    if not player then return end

    -- initialize connection table
    playerConnections[player] = playerConnections[player] or {}
    local conTable = playerConnections[player]

    -- ensure player starts whitelisted; evaluate will correct if not
    addToWhitelist(player)

    -- CharacterAdded handler
    if conTable.charConn then
        conTable.charConn:Disconnect()
        conTable.charConn = nil
    end
    conTable.charConn = player.CharacterAdded:Connect(function(character)
        -- cleanup humanoid connections
        if conTable.humanoidConn then
            conTable.humanoidConn:Disconnect()
            conTable.humanoidConn = nil
        end
        if conTable.diedConn then
            conTable.diedConn:Disconnect()
            conTable.diedConn = nil
        end

        -- wait for humanoid
        local humanoid = character:FindFirstChildOfClass("Humanoid") or character:WaitForChild("Humanoid", 5)
        if humanoid then
            conTable.humanoidConn = humanoid.HealthChanged:Connect(function()
                evaluateWhitelistState(player)
            end)
            conTable.diedConn = humanoid.Died:Connect(function()
                evaluateWhitelistState(player)
            end)
        end

        -- attach to live entry if exists or wait for it via global watcher
        local entry = getLiveEntryForPlayer(player)
        if entry then
            -- attach knocked listener or childadded
            attachKnockedListener(player, entry)
        else
            -- if no entry yet, ensure we will attach when entry appears via global watcher
            evaluateWhitelistState(player)
        end

        -- immediate application
        pcall(UpdatePlayers)
    end)

    -- If character already exists, call handler once
    if player.Character then
        -- small delay to let character initialize
        spawn(function()
            wait(0.1)
            if player.Character then
                -- simulate CharacterAdded behavior
                local character = player.Character
                local humanoid = character:FindFirstChildOfClass("Humanoid") or character:WaitForChild("Humanoid", 5)
                if humanoid then
                    if conTable.humanoidConn then conTable.humanoidConn:Disconnect() end
                    conTable.humanoidConn = humanoid.HealthChanged:Connect(function()
                        evaluateWhitelistState(player)
                    end)
                    if conTable.diedConn then conTable.diedConn:Disconnect() end
                    conTable.diedConn = humanoid.Died:Connect(function()
                        evaluateWhitelistState(player)
                    end)
                end
                local entry = getLiveEntryForPlayer(player)
                if entry then
                    attachKnockedListener(player, entry)
                else
                    evaluateWhitelistState(player)
                end
                pcall(UpdatePlayers)
            end
        end)
    end
end

-- Global watcher for workspace.Live and its entries
liveRoot = workspace:FindFirstChild("Live")
liveRootConn = nil

function attachToLiveRoot(root)
    if not root then return end
    -- attach to existing entries
    for _, entry in pairs(root:GetChildren()) do
        local player = Players:FindFirstChild(entry.Name)
        if player then
            -- ensure playerConnections exists
            playerConnections[player] = playerConnections[player] or {}
            -- attach knocked listener for this entry
            attachKnockedListener(player, entry)
        end
    end

    -- watch for new entries
    if liveRootConn then
        liveRootConn:Disconnect()
        liveRootConn = nil
    end
    liveRootConn = root.ChildAdded:Connect(function(entry)
        if entry and entry:IsA("Instance") then
            local player = Players:FindFirstChild(entry.Name)
            if player then
                playerConnections[player] = playerConnections[player] or {}
                attachKnockedListener(player, entry)
            end
        end
    end)
end

-- If Live exists now, attach; otherwise watch for it
if liveRoot then
    attachToLiveRoot(liveRoot)
else
    -- watch workspace for Live creation
    workspace.ChildAdded:Connect(function(child)
        if child.Name == "Live" and child:IsA("Folder") then
            liveRoot = child
            attachToLiveRoot(liveRoot)
        end
    end)
end

-- Also watch for Live being removed and re-added
workspace.ChildRemoved:Connect(function(child)
    if child == liveRoot then
        if liveRootConn then
            liveRootConn:Disconnect()
            liveRootConn = nil
        end
        liveRoot = nil
    end
end)

-- Player added/removed handling
Players.PlayerAdded:Connect(function(player)
    if scriptUnloaded then return end
    monitorPlayer(player)
end)

Players.PlayerRemoving:Connect(function(player)
    -- cleanup
    whitelist[player] = nil
    originalHRPProps[player] = nil
    clearHitboxOutline(player)
    if player.Character then
        restoreCharacterCollisionState(player.Character)
    end
    conTable = playerConnections[player]
    if conTable then
        if conTable.humanoidConn then conTable.humanoidConn:Disconnect() end
        if conTable.diedConn then conTable.diedConn:Disconnect() end
        if conTable.knockedConn then conTable.knockedConn:Disconnect() end
        if conTable.liveChildAddedConn then conTable.liveChildAddedConn:Disconnect() end
        if conTable.charConn then conTable.charConn:Disconnect() end
    end
    playerConnections[player] = nil
end)

-- Initialize existing players
toeInitPlayersList = Players:GetPlayers()
toeInitPlayersIndex = 1
while toeInitPlayersIndex <= #toeInitPlayersList do
    monitorPlayer(toeInitPlayersList[toeInitPlayersIndex])
    toeInitPlayersIndex = toeInitPlayersIndex + 1
end

-- Periodic fallback update
spawn(function()
    while true do
        if scriptUnloaded then
            break
        end
        wait(5)
        pcall(UpdatePlayers)
    end
end)

