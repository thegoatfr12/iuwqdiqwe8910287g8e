runAuthIntroAnimation = function()
    AuthFrame.Position = authFrameIntroStartPosition
    AuthFrame.BackgroundTransparency = 1
    AuthFrameStroke.Transparency = 1
    AuthFrameStroke.Thickness = 0

    AuthTitle.TextTransparency = 1
    AuthCredit.TextTransparency = 1
    AuthSubtitle.TextTransparency = 1
    AuthStatus.TextTransparency = 1
    runtimeInfoLabel.BackgroundTransparency = 1
    runtimeInfoLabel.TextTransparency = 1
    LicenseKeyBox.BackgroundTransparency = 1
    LicenseKeyBox.TextTransparency = 1
    AuthButton.BackgroundTransparency = 1
    AuthButton.TextTransparency = 1
    AuthSuccessLabel.TextTransparency = 1
    AuthSuccessLabel.Visible = false

    playTween(
        AuthFrame,
        TweenInfo.new(0.5, Enum.EasingStyle.Back, Enum.EasingDirection.Out),
        {
            Position = authFrameRestPosition,
            BackgroundTransparency = AUTH_FRAME_GLASS_TRANSPARENCY,
        }
    )

    playTween(
        AuthFrameStroke,
        TweenInfo.new(0.42, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
        {
            Transparency = 0,
            Thickness = 2,
        }
    )

    playTween(AuthTitle, TweenInfo.new(0.32, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {TextTransparency = 0})
    playTween(AuthCredit, TweenInfo.new(0.34, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {TextTransparency = 0})
    playTween(AuthSubtitle, TweenInfo.new(0.32, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {TextTransparency = 0})
    playTween(AuthStatus, TweenInfo.new(0.32, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {TextTransparency = 0})
    playTween(runtimeInfoLabel, TweenInfo.new(0.36, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {BackgroundTransparency = AUTH_SURFACE_GLASS_TRANSPARENCY, TextTransparency = 0})
    playTween(LicenseKeyBox, TweenInfo.new(0.36, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {BackgroundTransparency = AUTH_SURFACE_GLASS_TRANSPARENCY, TextTransparency = 0})
    playTween(AuthButton, TweenInfo.new(0.36, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {BackgroundTransparency = ACTION_BUTTON_GLASS_TRANSPARENCY, TextTransparency = 0})
end

local authIntroStarted = false
function ensureAuthIntroVisible()
    if authIntroStarted then
        return
    end

    authIntroStarted = true
    AuthFrame.Visible = true
    pcall(runAuthIntroAnimation)
end

function typewriteLabelText(label, fullText, charDelay)
    if not label then
        return
    end

    local textValue = tostring(fullText or "")
    label.Text = ""
    for i = 1, string.len(textValue) do
        label.Text = string.sub(textValue, 1, i)
        task.wait(charDelay or 0.06)
    end
end

function runStartupCinematic()
    if not STARTUP_CINEMATIC_ENABLED then
        if introCinematicFrame then
            introCinematicFrame.Visible = false
        end
        ensureAuthIntroVisible()
        return
    end

    AuthFrame.Visible = false
    introCinematicFrame.Visible = true
    introCinematicFrame.ZIndex = 140
    introCinematicFrame.BackgroundTransparency = 1
    introScanlineGlow.Visible = true
    introScanlineGlow.BackgroundTransparency = 1
    introScanlineGlow.Position = UDim2.new(0, 0, 0, -16)
    introScanline.Visible = true
    introScanline.BackgroundTransparency = 1
    introScanline.Position = UDim2.new(0, 0, 0, -6)
    introTitleLabel.Visible = true
    introTitleLabel.ZIndex = 141
    introTitleLabel.Text = ""
    introTitleLabel.TextTransparency = 0
    introCreditLabel.Visible = true
    introCreditLabel.ZIndex = 141
    introCreditLabel.Position = UDim2.new(0, 20, 0.5, 24)
    introCreditLabel.Text = ""
    introCreditLabel.TextTransparency = 0
    introCreditScale.Scale = 1
    introAccessRevealFrame.Visible = false
    introAccessRevealFrame.Size = UDim2.new(0, ACCESS_GRANTED_REVEAL_WIDTH, 0, 42)
    introAccessGrantedLabel.TextTransparency = 0
    introAccessSweepLine.Visible = false
    introAccessSweepLine.Position = UDim2.new(0, 0, 0, -2)
    introAccessSweepLine.BackgroundTransparency = 0.12

    playTween(
        introCinematicFrame,
        TweenInfo.new(0.42, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
        {BackgroundTransparency = 0}
    )

    task.delay(1.35, function()
        if not introCinematicFrame or not introCinematicFrame.Visible then
            return
        end

        playTween(
            introScanlineGlow,
            TweenInfo.new(1.85, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
            {
                Position = UDim2.new(0, 0, 1, 8),
                BackgroundTransparency = 0.9,
            }
        )
        playTween(
            introScanline,
            TweenInfo.new(1.85, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
            {
                Position = UDim2.new(0, 0, 1, -3),
                BackgroundTransparency = 0.25,
            }
        )
    end)

    task.delay(3.35, function()
        if introScanline then
            introScanline.BackgroundTransparency = 1
            introScanline.Visible = false
        end
        if introScanlineGlow then
            introScanlineGlow.BackgroundTransparency = 1
            introScanlineGlow.Visible = false
        end
    end)

    task.wait(0.7)

    typewriteLabelText(introTitleLabel, introTitleFullText, 0.08)
    task.wait(0.35)
    typewriteLabelText(introCreditLabel, introCreditFullText, 0.075)
    task.wait(1.2)

    playTween(introTitleLabel, TweenInfo.new(0.4, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {TextTransparency = 1})
    playTween(introCreditLabel, TweenInfo.new(0.4, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {TextTransparency = 1})
    task.wait(0.5)

    -- Keep the blackout active behind KeyAuth until validation succeeds.
    introTitleLabel.Visible = false
    introCreditLabel.Visible = false
    introScanline.Visible = false
    introScanlineGlow.Visible = false
    introCinematicFrame.BackgroundTransparency = 0
    introCinematicFrame.ZIndex = 0
    ensureAuthIntroVisible()
end

do
    local persisted = loadPersistedSettingsData() or {}
    local settingsData = persisted
    if type(persisted.SavedSettings) == "table" then
        settingsData = persisted.SavedSettings
    end

    if type(settingsData) == "table" and settingsData.StartupCinematicEnabled ~= nil then
        STARTUP_CINEMATIC_ENABLED = settingsData.StartupCinematicEnabled and true or false
    end
    if type(settingsData) == "table" and settingsData.GuiSpawnPosition ~= nil then
        GUI_SPAWN_POSITION_MODE = tostring(settingsData.GuiSpawnPosition)
    end

    applyGuiSpawnPosition(GUI_SPAWN_POSITION_MODE, true)
end

task.defer(function()
    task.delay(8, function()
        if not authIntroStarted then
            warn("[ToeBootstrap] Startup cinematic timeout fallback -> showing auth UI")
            ensureAuthIntroVisible()
        end
    end)

    local ok, err = pcall(runStartupCinematic)
    if not ok then
        warn("[ToeBootstrap] Startup cinematic failed: " .. tostring(err))
        introCinematicFrame.Visible = false
    end

    ensureAuthIntroVisible()
end)

task.delay(12, function()
    if scriptUnloaded or isAuthorized then
        return
    end

    local mainVisible = MainFrame and MainFrame.Visible
    local authVisible = AuthFrame and AuthFrame.Visible
    if mainVisible or authVisible then
        return
    end

    if introCinematicFrame then
        introCinematicFrame.Visible = false
    end

    if AuthFrame then
        AuthFrame.Visible = true
        AuthFrame.BackgroundTransparency = AUTH_FRAME_GLASS_TRANSPARENCY
    end
    if AuthFrameStroke then
        AuthFrameStroke.Transparency = 0
    end
    if AuthStatus then
        AuthStatus.Text = "Startup fallback active. Enter your license key."
    end

    warn("[ToeBootstrap] Emergency startup fallback: forced auth UI visible")
end)

local function setAuthButtonBusy(isBusy, buttonText)
    authBusy = isBusy
    AuthButton.Active = not isBusy
    AuthButton.AutoButtonColor = not isBusy
    if buttonText then
        AuthButton.Text = buttonText
    end
end

showStatus = function(text, isError)
    local function getReadableNotificationTextColor(backgroundColor)
        if typeof(backgroundColor) ~= "Color3" then
            return Color3.fromRGB(245, 245, 245)
        end

        local luminance = (0.299 * backgroundColor.R) + (0.587 * backgroundColor.G) + (0.114 * backgroundColor.B)
        if luminance > 0.58 then
            return Color3.fromRGB(20, 20, 20)
        end

        return Color3.fromRGB(245, 245, 245)
    end

    AuthStatus.Text = text
    AuthStatus.TextColor3 = isError and Color3.fromRGB(255, 140, 140) or Color3.fromRGB(200, 200, 200)
    if TOP_NOTIFICATIONS_ENABLED and Notification then
        Notification.Text = text
        Notification.TextColor3 = isError and Color3.fromRGB(255, 170, 170) or getReadableNotificationTextColor(Notification.BackgroundColor3)
        Notification.Visible = true
    end
    if isError then
        setRuntimeInfoText(buildIdentitySummary() .. "\nStatus: " .. tostring(text))
    elseif refreshIdentityInfo then
        refreshIdentityInfo()
    end
    if TOP_NOTIFICATIONS_ENABLED and Notification then
        task.delay(2, function()
            if Notification.Text == text then
                Notification.Visible = false
            end
        end)
    end
end

local function finishAuthorization(dataOrMessage, licenseKey, statusPrefix)
    isAuthorized = true
    freeAuthSession = string.lower(tostring(licenseKey or "")) == "free"

    local welcomeName = "licensed user"
    if dataOrMessage.info and dataOrMessage.info.username then
        welcomeName = dataOrMessage.info.username
    end

    if licenseKey and licenseKey ~= "" then
        cacheLicenseKey(licenseKey)
    end

    showStatus("Key verified. Loading UI...", false)
    AuthButton.Text = "Verified OK"

    playTween(
        AuthButton,
        TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
        {
            BackgroundColor3 = Color3.fromRGB(54, 196, 110),
            Size = UDim2.new(authButtonRestSize.X.Scale, authButtonRestSize.X.Offset + 10, authButtonRestSize.Y.Scale, authButtonRestSize.Y.Offset + 4),
            Position = UDim2.new(authButtonRestPosition.X.Scale, authButtonRestPosition.X.Offset - 5, authButtonRestPosition.Y.Scale, authButtonRestPosition.Y.Offset - 2),
        }
    )
    playTween(
        AuthFrameStroke,
        TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
        {
            Color = Color3.fromRGB(54, 196, 110),
        }
    )
    playTween(
        AuthFrame,
        TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
        {
            BackgroundColor3 = Color3.fromRGB(24, 64, 38),
        }
    )
    task.wait(0.2)

    playTween(
        AuthButton,
        TweenInfo.new(0.14, Enum.EasingStyle.Back, Enum.EasingDirection.Out),
        {
            Size = authButtonRestSize,
            Position = authButtonRestPosition,
        }
    )
    task.wait(0.16)

    if not STARTUP_CINEMATIC_ENABLED then
        playTween(AuthTitle, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {TextTransparency = 1})
        playTween(AuthCredit, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {TextTransparency = 1})
        playTween(AuthSubtitle, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {TextTransparency = 1})
        playTween(AuthStatus, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {TextTransparency = 1})
        playTween(runtimeInfoLabel, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {BackgroundTransparency = 1, TextTransparency = 1})
        playTween(LicenseKeyBox, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {BackgroundTransparency = 1, TextTransparency = 1})
        playTween(AuthButton, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {BackgroundTransparency = 1, TextTransparency = 1})
        task.wait(0.22)
        AuthButton.Visible = false

        AuthSuccessLabel.Text = "Access granted."
        AuthSuccessLabel.TextColor3 = Color3.fromRGB(120, 235, 155)
        AuthSuccessLabel.TextTransparency = 1
        AuthSuccessLabel.Visible = true
        playTween(AuthSuccessLabel, TweenInfo.new(0.24, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {TextTransparency = 0})
        task.wait(0.88)
        playTween(AuthSuccessLabel, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {TextTransparency = 1})
        task.wait(0.22)
        AuthSuccessLabel.Visible = false

        playTween(
            AuthFrame,
            TweenInfo.new(0.24, Enum.EasingStyle.Quad, Enum.EasingDirection.In),
            {BackgroundTransparency = 1}
        )
        playTween(AuthFrameStroke, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {Transparency = 1})
        task.wait(0.26)
        AuthFrame.Visible = false
    else
        playTween(AuthTitle, TweenInfo.new(0.22, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {TextTransparency = 1})
        playTween(AuthCredit, TweenInfo.new(0.22, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {TextTransparency = 1})
        playTween(AuthSubtitle, TweenInfo.new(0.22, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {TextTransparency = 1})
        playTween(AuthStatus, TweenInfo.new(0.22, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {TextTransparency = 1})
        playTween(runtimeInfoLabel, TweenInfo.new(0.24, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {BackgroundTransparency = 1, TextTransparency = 1})
        playTween(LicenseKeyBox, TweenInfo.new(0.24, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {BackgroundTransparency = 1, TextTransparency = 1})
        playTween(AuthButton, TweenInfo.new(0.24, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {BackgroundTransparency = 1, TextTransparency = 1})
        task.wait(0.26)

        playTween(
            AuthFrame,
            TweenInfo.new(0.28, Enum.EasingStyle.Quad, Enum.EasingDirection.In),
            {
                Position = UDim2.new(authFrameRestPosition.X.Scale, authFrameRestPosition.X.Offset, authFrameRestPosition.Y.Scale, authFrameRestPosition.Y.Offset - 1),
                BackgroundTransparency = 1,
            }
        )
        playTween(AuthFrameStroke, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {Transparency = 1})
        task.wait(0.3)

        AuthFrame.Visible = false
        AuthSuccessLabel.Visible = false

        if introCinematicFrame then
            introCinematicFrame.Visible = true
            introCinematicFrame.ZIndex = 160
            introCinematicFrame.BackgroundTransparency = 0
            introScanline.Visible = false
            introScanlineGlow.Visible = false

            if introAccessRevealFrame and introAccessGrantedLabel then
                introAccessRevealFrame.Visible = true
                introAccessRevealFrame.Size = UDim2.new(0, ACCESS_GRANTED_REVEAL_WIDTH, 0, 0)
                introAccessGrantedLabel.TextTransparency = 0
                if introAccessSweepLine then
                    introAccessSweepLine.Visible = true
                    introAccessSweepLine.Position = UDim2.new(0, 0, 0, -2)
                    introAccessSweepLine.BackgroundTransparency = 0.12
                end

                playTween(
                    introAccessRevealFrame,
                    TweenInfo.new(0.62, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
                    {Size = UDim2.new(0, ACCESS_GRANTED_REVEAL_WIDTH, 0, 42)}
                )
                if introAccessSweepLine then
                    playTween(
                        introAccessSweepLine,
                        TweenInfo.new(0.62, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
                        {
                            Position = UDim2.new(0, 0, 1, -2),
                            BackgroundTransparency = 0.35,
                        }
                    )
                end

                task.wait(1.0)
                playTween(
                    introAccessGrantedLabel,
                    TweenInfo.new(0.22, Enum.EasingStyle.Quad, Enum.EasingDirection.In),
                    {TextTransparency = 1}
                )
                if introAccessSweepLine then
                    playTween(
                        introAccessSweepLine,
                        TweenInfo.new(0.22, Enum.EasingStyle.Quad, Enum.EasingDirection.In),
                        {BackgroundTransparency = 1}
                    )
                end
                task.wait(0.28)
                introAccessRevealFrame.Visible = false
                if introAccessSweepLine then
                    introAccessSweepLine.Visible = false
                end
            end

            playTween(
                introCinematicFrame,
                TweenInfo.new(0.38, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
                {BackgroundTransparency = 1}
            )
            task.wait(0.42)
            introCinematicFrame.Visible = false
        end
    end

    TouchToggleButton.Visible = UserInputService.TouchEnabled
    TransitionOverlay.BackgroundTransparency = 0.6
    TransitionOverlay.Visible = true
    MainFrame.Position = UDim2.new(mainFrameRestPosition.X.Scale, mainFrameRestPosition.X.Offset, mainFrameRestPosition.Y.Scale, mainFrameRestPosition.Y.Offset + 32)
    UIScale.Scale = 0.92
    MainFrame.Visible = true

    local mainFrameTween = playTween(
        MainFrame,
        TweenInfo.new(0.35, Enum.EasingStyle.Back, Enum.EasingDirection.Out),
        {Position = mainFrameRestPosition}
    )
    playTween(UIScale, TweenInfo.new(0.35, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Scale = 1})
    local overlayTween = playTween(TransitionOverlay, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {BackgroundTransparency = 1})
    mainFrameTween.Completed:Wait()
    overlayTween.Completed:Wait()
    TransitionOverlay.Visible = false

    -- Hard cleanup for auth/cinematic surfaces so no stale success frame remains.
    AuthFrame.Visible = false
    AuthSuccessLabel.Visible = false
    if AuthFrameStroke then
        AuthFrameStroke.Transparency = 1
    end
    if introAccessRevealFrame then
        introAccessRevealFrame.Visible = false
    end
    if introAccessSweepLine then
        introAccessSweepLine.Visible = false
    end
    if introCinematicFrame then
        introCinematicFrame.Visible = false
        introCinematicFrame.BackgroundTransparency = 1
    end

    showStatus((statusPrefix or "Authorized as ") .. tostring(welcomeName), false)
    if type(setFreeModeEnabled) == "function" then
        setFreeModeEnabled(freeAuthSession, false)
    else
        freeModeEnabled = freeAuthSession
    end
    sendCoreNotification("Successfully authorized", 4)
    AuthFrame.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
    AuthFrameStroke.Color = activeThemeSecondaryColor
end

sendCoreNotification("Initializing auth gate...", 3)

connectButton(AuthButton, function()
    if isAuthorized or authBusy then
        return
    end

    local licenseKey = tostring(LicenseKeyBox.Text or "")
    licenseKey = licenseKey:gsub("^%s+", ""):gsub("%s+$", "")

    if licenseKey == "" then
        showStatus("License key is required.", true)
        return
    end

    if string.lower(licenseKey) == "free" then
        freeAuthSession = true
        setAuthButtonBusy(true, "Enabling Free...")
        finishAuthorization({info = {username = "free"}}, licenseKey, "Free mode: ")
        if type(setFreeModeEnabled) == "function" then
            setFreeModeEnabled(true, true)
        else
            freeModeEnabled = true
            showStatus("Free mode queued. UI restrictions will apply shortly.", false)
        end
        return
    end

    if keyAuthAppName == "" or keyAuthOwnerId == "" then
        showStatus("Set app name and owner id in the script first.", true)
        return
    end

    setAuthButtonBusy(true, "Verifying...")
    showStatus("Contacting KeyAuth...", false)
    local ok, dataOrMessage = authorizeWithKeyAuth(licenseKey)
    if not ok then
        setAuthButtonBusy(false, "Authorize")
        showStatus("Authorization failed: " .. tostring(dataOrMessage), true)
        sendCoreNotification("Authorization failed", 3)
        return
    end

    if type(setFreeModeEnabled) == "function" then
        freeAuthSession = false
        setFreeModeEnabled(false, false)
    else
        freeModeEnabled = false
        freeAuthSession = false
    end
    finishAuthorization(dataOrMessage, licenseKey, "Authorized as ")
end)

task.defer(function()
    local cachedLicenseKey = loadCachedLicenseKey()
    if not cachedLicenseKey then
        return
    end

    LicenseKeyBox.Text = cachedLicenseKey
    showStatus("Saved key loaded. Press Authorize to validate it.", false)
end)

updateBootstrapStatus("Boot: auth controls ready", false)

