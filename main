-- 3. Add Hitbox ON/OFF switch
-- Duplicate hitbox toggle removed

-- Update UpdatePlayers to respect hitboxEnabled
UpdatePlayers = function()
    if scriptUnloaded then
        return
    end
    local sizeValue = hitboxEnabled and currentHitbox or 2
    local shouldApplyNoBounce = isNoBounceModeCollisionActive()
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            local Root = player.Character:FindFirstChild("HumanoidRootPart")
            if whitelist[player] then
                if Root and Root:IsA("BasePart") then
                    local props = originalHRPProps[player]
                    if not props then
                        props = {
                            Size = Root.Size,
                            Transparency = Root.Transparency,
                            CanCollide = Root.CanCollide,
                            CanTouch = Root.CanTouch,
                            CanQuery = Root.CanQuery,
                            Material = Root.Material,
                            Color = Root.Color,
                            Reflectance = Root.Reflectance,
                        }
                        originalHRPProps[player] = props
                    else
                        if props.Material == nil then
                            props.Material = Root.Material
                        end
                        if props.Color == nil then
                            props.Color = Root.Color
                        end
                        if props.Reflectance == nil then
                            props.Reflectance = Root.Reflectance
                        end
                    end
                    local Size = Vector3.new(sizeValue, sizeValue, sizeValue)
                    Root.Size = Size
                    Root.Transparency = 1
                    if shouldApplyNoBounce then
                        Root.CanCollide = false
                        Root.CanTouch = true
                        Root.CanQuery = true
                    else
                        Root.CanCollide = props.CanCollide
                        Root.CanTouch = props.CanTouch
                        Root.CanQuery = props.CanQuery
                    end
                    applyHitboxVisualStyle(player, Root, showHitboxSelections)
                end
                if shouldApplyNoBounce then
                    setAllPartsNonCollidable(player.Character)
                else
                    restoreCharacterCollisionState(player.Character)
                end
            else
                restoreCharacterCollisionState(player.Character)
                local props = originalHRPProps[player]
                if props and Root and Root:IsA("BasePart") then
                    Root.Size = props.Size
                    Root.Transparency = props.Transparency
                    Root.CanCollide = props.CanCollide
                    Root.CanTouch = props.CanTouch
                    Root.CanQuery = props.CanQuery
                    restoreHitboxVisualStyle(player, Root, props)
                else
                    clearHitboxOutline(player)
                end
            end
        end
    end

    pcall(updateAffectedPlayersCountText)
end

end

emitRuntimeSignal("chunk loaded", false)
setEarlyStatus("Chunk loaded. Starting main...", false)
local ok, runtimeError = xpcall(main, runtimeErrorHandler)
if not ok then
    emitRuntimeSignal("startup aborted", true)
end
