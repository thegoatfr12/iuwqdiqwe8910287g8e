local applyAttackSpeedToLocalLive
local applyThemeColors
local setMainUiTransparency
local setWeaveGlideEnabledState
local hitboxColorLabel
local hitboxColorButton
local hitboxColorDropdownFrame
local setHitboxColorControlState

local function trimText(value)
    return tostring(value or ""):match("^%s*(.-)%s*$")
end

local function getSavedSettingsBlock(data)
    if type(data) ~= "table" then
        return nil
    end

    if type(data.SavedSettings) == "table" then
        return data.SavedSettings
    end

    return data
end

local function getCustomPresetBlock(data)
    if type(data) ~= "table" or type(data.CustomPreset) ~= "table" then
        return nil
    end

    return data.CustomPreset
end

local function serializeSettingsColor(color)
    if typeof(color) ~= "Color3" then
        return nil
    end

    return {
        R = math.floor(color.R * 255 + 0.5),
        G = math.floor(color.G * 255 + 0.5),
        B = math.floor(color.B * 255 + 0.5),
    }
end

local function parseSettingsColor(snapshotColor, fallback)
    if type(snapshotColor) ~= "table" then
        return fallback
    end

    local r = tonumber(snapshotColor.R)
    local g = tonumber(snapshotColor.G)
    local b = tonumber(snapshotColor.B)
    if not r or not g or not b then
        return fallback
    end

    return Color3.fromRGB(math.clamp(r, 0, 255), math.clamp(g, 0, 255), math.clamp(b, 0, 255))
end

local function buildSettingsSnapshot()
    return {
        HitboxSize = currentHitbox,
        ShowSelections = showHitboxSelections,
        HitboxOutlineColor = serializeSettingsColor(HITBOX_TRANSPARENT_COLOR),
        PunchSpeed = currentPunchSpeed,
        StompSpeed = currentStompSpeed,
        UIToggleKey = toggleKeyBox.Text,
        PanicKey = panicKeyBox and panicKeyBox.Text or panicKeyCode.Name,
        HitboxToggleHotkey = hitboxToggleHotkeyBox and tostring(hitboxToggleHotkeyBox.Text or "") or (hitboxToggleHotkeyCode and hitboxToggleHotkeyCode.Name or ""),
        WeaveGlideToggleHotkey = weaveGlideToggleHotkeyBox and tostring(weaveGlideToggleHotkeyBox.Text or "") or (weaveGlideToggleHotkeyCode and weaveGlideToggleHotkeyCode.Name or ""),
        AntiWeaveToggleHotkey = antiWeaveToggleHotkeyBox and tostring(antiWeaveToggleHotkeyBox.Text or "") or (antiWeaveToggleHotkeyCode and antiWeaveToggleHotkeyCode.Name or ""),
        HitboxEnabled = hitboxEnabled,
        NoBounceModeEnabled = noBounceModeEnabled,
        IncludeGroundedTargets = includeGroundedTargets,
        AntiWeaveEnabled = antiWeaveEnabled,
        HeadHidden = headHidden,
        LowGraphicsEnabled = lowGraphicsEnabled,
        StretchResEnabled = stretchResEnabled,
        StretchResValue = STRETCH_RESOLUTION,
        LookSensitivityEnabled = lookSensitivityEnabled,
        LookSensitivity = mouseSensitivityMultiplier,
        MouseSensitivity = mouseSensitivityMultiplier,
        WalkSpeed = currentWalkSpeed,
        LoopWalkSpeedEnabled = loopWalkSpeedEnabled,
        WeaveGlideEnabled = weaveGlideEnabled,
        WeaveGlideStrength = weaveGlideStrength,
        StartupCinematicEnabled = STARTUP_CINEMATIC_ENABLED,
        GuiSpawnPosition = GUI_SPAWN_POSITION_MODE,
    }
end

presetUiSavePrompt.serializeColor = function(color)
    if typeof(color) ~= "Color3" then
        return nil
    end

    return {
        R = math.floor(color.R * 255 + 0.5),
        G = math.floor(color.G * 255 + 0.5),
        B = math.floor(color.B * 255 + 0.5),
    }
end

presetUiSavePrompt.buildUiCustomizationSnapshot = function()
    return {
        MainColor = presetUiSavePrompt.serializeColor(activeThemeMainColor),
        SecondaryColor = presetUiSavePrompt.serializeColor(activeThemeSecondaryColor),
        TextColor = presetUiSavePrompt.serializeColor(activeThemeTextColor),
        MainUiTransparency = currentMainUiTransparency,
    }
end

local function updateCustomPresetUI(presetName)
    local resolvedName = trimText(presetName)
    if resolvedName == "" then
        customPresetButton.Text = DEFAULT_CUSTOM_PRESET_NAME
        customPresetButton.Visible = false
        return
    end

    customPresetButton.Text = resolvedName
    customPresetButton.Visible = true
end

local function setPresetNameMenuVisible(isVisible)
    presetNameOverlay.Visible = isVisible and true or false
    presetNameModal.Visible = isVisible and true or false
    if isVisible then
        presetUiSavePrompt.setMode("name")
    else
        presetNameInput:ReleaseFocus()
    end
end

-- Preset logic (after all UI elements are defined)
local function applyPreset(punch, stomp, hitbox, showSelections)
    -- Update all state variables
    currentPunchSpeed = punch
    currentStompSpeed = stomp
    currentHitbox = hitbox
    if showSelections ~= nil then
        showHitboxSelections = showSelections and true or false
        if showSelectionsToggle and showSelectionsToggleKnob then
            setToggleSwitchState(showSelectionsToggle, showSelectionsToggleKnob, showHitboxSelections)
        end
    end

    -- Update Combat tab UI (even if not visible)
    -- Hitbox
    hitboxTextBox.Text = tostring(currentHitbox)
    hitboxValueLabel.Text = tostring(currentHitbox)
    local hitboxRel = (currentHitbox - HITBOX_MIN) / (HITBOX_MAX - HITBOX_MIN)
    hitboxSliderFill.Size = UDim2.new(hitboxRel, 0, 1, 0)

    -- Punch Speed
    punchTextBox.Text = tostring(currentPunchSpeed)
    punchValueLabel.Text = tostring(currentPunchSpeed)
    local punchRel = (currentPunchSpeed - PUNCH_MIN) / (PUNCH_MAX - PUNCH_MIN)
    punchSliderFill.Size = UDim2.new(punchRel, 0, 1, 0)
    -- Force UI update in next frame (Roblox UI bug workaround)
    task.defer(function()
        punchSliderFill.Size = UDim2.new(punchRel, 0, 1, 0)
        punchValueLabel.Text = tostring(currentPunchSpeed)
    end)

    -- Stomp Speed
    stompSlider.TextBox.Text = tostring(currentStompSpeed)
    stompSlider.ValueLabel.Text = tostring(currentStompSpeed)
    local stompRel = (currentStompSpeed - STOMP_MIN) / (STOMP_MAX - STOMP_MIN)
    stompSlider.Fill.Size = UDim2.new(stompRel, 0, 1, 0)

    applyLocalRootVisibility()

    -- Apply to other players
    pcall(UpdatePlayers)
    -- Apply attack speed logic
    applyAttackSpeedToLocalLive()
end

local function applyLegitSettingsPreset()
    applyPreset(1.86, 1.14, 5, true)

    hitboxEnabled = true
    includeGroundedTargets = true
    if setWeaveGlideEnabledState then
        setWeaveGlideEnabledState(true)
    else
        weaveGlideEnabled = true
    end
    setToggleSwitchState(hitboxToggle, hitboxToggleKnob, hitboxEnabled)
    setToggleSwitchState(hitboxSmartModeToggle, hitboxSmartModeToggleKnob, includeGroundedTargets)
    setToggleSwitchState(weaveGlideToggle, weaveGlideToggleKnob, weaveGlideEnabled)
    if setWeaveGlideStrengthValue then
        setWeaveGlideStrengthValue(2)
    else
        weaveGlideStrength = 2
        if weaveGlideStrengthBox then
            weaveGlideStrengthBox.Text = tostring(weaveGlideStrength)
        end
    end
    pcall(UpdatePlayers)

    if applyThemeColors then
        applyThemeColors(
            Color3.fromRGB(10, 10, 12),
            Color3.fromRGB(230, 50, 50),
            Color3.fromRGB(245, 245, 245),
            "Liquid Black",
            "manual"
        )
    end
    if setMainUiTransparency then
        setMainUiTransparency(MAIN_FRAME_GLASS_TRANSPARENCY)
    end
end

local function applyVeloSettingsPreset()
    applyPreset(2.1, 1.5, 8, true)

    hitboxEnabled = true
    includeGroundedTargets = true
    antiWeaveEnabled = true
    setToggleSwitchState(hitboxToggle, hitboxToggleKnob, hitboxEnabled)
    setToggleSwitchState(hitboxSmartModeToggle, hitboxSmartModeToggleKnob, includeGroundedTargets)
    setToggleSwitchState(ApplyButton, applyToggleKnob, antiWeaveEnabled)
    pcall(UpdatePlayers)

    if applyThemeColors then
        applyThemeColors(
            Color3.fromRGB(10, 10, 12),
            Color3.fromRGB(230, 50, 50),
            Color3.fromRGB(245, 245, 245),
            "Liquid Black",
            "manual"
        )
    end
    if setMainUiTransparency then
        setMainUiTransparency(MAIN_FRAME_GLASS_TRANSPARENCY)
    end
end

connectButton(legitButton, applyLegitSettingsPreset)
connectButton(veloButton, applyVeloSettingsPreset)

updateCustomPresetUI(nil)

