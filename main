weaveGlideTierPopup.Label.TextSize = 12
weaveGlideTierPopup.Label.TextTransparency = 1
weaveGlideTierPopup.HideToken = 0
weaveGlideTierPopup.IsVisible = false
weaveGlideTierPopup.CurrentTier = nil

weaveGlideStrengthDragging = false

function setWeaveGlideStrengthValue(value)
    weaveGlideStrength = math.clamp(math.floor(((tonumber(value) or 1) * 10) + 0.5) / 10, 1, 15)
    weaveGlideStrengthBox.Text = tostring(weaveGlideStrength)
    weaveGlideStrengthValueLabel.Text = tostring(weaveGlideStrength)
    local rel = (weaveGlideStrength - 1) / 14
    weaveGlideStrengthSliderFill.Size = UDim2.new(rel, 0, 1, 0)

    -- Re-apply weave distance immediately so slider updates are felt live.
    if type(applyWeaveGlideBoost) == "function" then
        pcall(applyWeaveGlideBoost)
    end
end

function weaveGlidePosToValue(px)
    local absX = weaveGlideStrengthSliderBar.AbsolutePosition.X
    local w = weaveGlideStrengthSliderBar.AbsoluteSize.X
    local rel = math.clamp((px - absX) / math.max(w, 1), 0, 1)
    local raw = 1 + (14 * rel)
    return math.clamp(math.floor((raw * 10) + 0.5) / 10, 1, 15)
end

local function getWeaveGlideTierLabelAndColor(value)
    if value <= 3 then
        return "Legit", Color3.fromRGB(90, 220, 120)
    elseif value <= 6 then
        return "dangerous", Color3.fromRGB(255, 174, 84)
    end
    return "blatant", Color3.fromRGB(255, 92, 92)
end

local function hideWeaveGlideTierPopup(delayTime)
    if not weaveGlideTierPopup or not weaveGlideTierPopup.Frame or not weaveGlideTierPopup.Label then
        return
    end

    weaveGlideTierPopup.HideToken = (weaveGlideTierPopup.HideToken or 0) + 1
    local token = weaveGlideTierPopup.HideToken

    task.delay(delayTime or 0, function()
        if not weaveGlideTierPopup or token ~= weaveGlideTierPopup.HideToken or not weaveGlideTierPopup.IsVisible then
            return
        end

        local _, _, exitPos = getTierPopupPositionsForSlider(weaveGlideStrengthSliderBar, weaveGlideTierPopup.Frame, -24, 8, 6, 0)

        playTween(
            weaveGlideTierPopup.Frame,
            TweenInfo.new(0.14, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
            {
                Position = exitPos,
                BackgroundTransparency = 1,
            }
        )
        playTween(
            weaveGlideTierPopup.Label,
            TweenInfo.new(0.14, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
            {
                TextTransparency = 1,
            }
        )

        task.delay(0.15, function()
            if weaveGlideTierPopup and token == weaveGlideTierPopup.HideToken and weaveGlideTierPopup.Frame then
                weaveGlideTierPopup.Frame.Visible = false
                weaveGlideTierPopup.IsVisible = false
            end
        end)
    end)
end

local function showWeaveGlideTierPopup(value, holdOpen)
    if not weaveGlideTierPopup or not weaveGlideTierPopup.Frame or not weaveGlideTierPopup.Label then
        return
    end

    local tierText, tierColor = getWeaveGlideTierLabelAndColor(value)
    local sameTier = weaveGlideTierPopup.CurrentTier == tierText
    weaveGlideTierPopup.CurrentTier = tierText
    weaveGlideTierPopup.HideToken = (weaveGlideTierPopup.HideToken or 0) + 1

    weaveGlideTierPopup.Label.Text = tierText
    weaveGlideTierPopup.Label.TextColor3 = tierColor

    if not weaveGlideTierPopup.IsVisible then
        local enterPos, shownPos = getTierPopupPositionsForSlider(weaveGlideStrengthSliderBar, weaveGlideTierPopup.Frame, -24, 8, 6, 0)
        weaveGlideTierPopup.Frame.Visible = true
        weaveGlideTierPopup.Frame.Position = enterPos
        weaveGlideTierPopup.Frame.BackgroundTransparency = 1
        weaveGlideTierPopup.Label.TextTransparency = 1

        playTween(
            weaveGlideTierPopup.Frame,
            TweenInfo.new(0.12, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
            {
                Position = shownPos,
                BackgroundTransparency = 0.14,
            }
        )
        playTween(
            weaveGlideTierPopup.Label,
            TweenInfo.new(0.12, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
            {
                TextTransparency = 0,
            }
        )
        weaveGlideTierPopup.IsVisible = true
    elseif not sameTier then
        local _, shownPos = getTierPopupPositionsForSlider(weaveGlideStrengthSliderBar, weaveGlideTierPopup.Frame, -24, 8, 6, 0)
        weaveGlideTierPopup.Frame.Position = shownPos
        weaveGlideTierPopup.Frame.BackgroundTransparency = 0.14
        weaveGlideTierPopup.Label.TextTransparency = 0
    end

    if not holdOpen then
        hideWeaveGlideTierPopup(0.5)
    end
end

setWeaveGlideStrengthValue(weaveGlideStrength)

weaveGlideStrengthSliderBar.InputBegan:Connect(function(inp)
    if freeModeShouldBlockControl(weaveGlideStrengthSliderBar, true) then
        return
    end

    if inp.UserInputType == Enum.UserInputType.MouseButton1 then
        weaveGlideStrengthDragging = true
        local v = weaveGlidePosToValue(inp.Position.X)
        setWeaveGlideStrengthValue(v)
        showWeaveGlideTierPopup(v, true)
    end
end)
weaveGlideStrengthSliderBar.InputEnded:Connect(function(inp)
    if inp.UserInputType == Enum.UserInputType.MouseButton1 then
        weaveGlideStrengthDragging = false
        hideWeaveGlideTierPopup(0.12)
    end
end)
UserInputService.InputChanged:Connect(function(inp)
    if weaveGlideStrengthDragging and inp.UserInputType == Enum.UserInputType.MouseMovement then
        local v = weaveGlidePosToValue(inp.Position.X)
        setWeaveGlideStrengthValue(v)
        showWeaveGlideTierPopup(v, true)
    end
end)
UserInputService.InputEnded:Connect(function(inp)
    if weaveGlideStrengthDragging and inp.UserInputType == Enum.UserInputType.MouseButton1 then
        weaveGlideStrengthDragging = false
        hideWeaveGlideTierPopup(0.12)
    end
end)

