    if freeModeShouldBlockControl(stretchResSliderLabel, true) then
        stretchResSliderLabel.Text = string.format("%.2f", STRETCH_RESOLUTION)
        return
    end

    local parsed = tonumber(tostring(stretchResSliderLabel.Text or ""))
    if parsed then
        setStretchResResolution(parsed)
        persistStretchResSetting()
    else
        stretchResSliderLabel.Text = string.format("%.2f", STRETCH_RESOLUTION)
        showStatus("Invalid stretch amount.", true)
    end
end)

