    if mouseSensitivitySliderDragging and inp.UserInputType == Enum.UserInputType.MouseButton1 then
        mouseSensitivitySliderDragging = false
        persistMouseSensitivitySetting()
        if mouseSensitivitySupported == false then
            showStatus("Mouse override blocked; native controller/touch setting + fallback boost still use this slider.", true)
        end
    end
end)

