-- Save/Load logic (using SetAttribute for persistence in PlayerGui)
local function saveSettings()
    local persisted = loadPersistedSettingsData() or {}
    local customPreset = getCustomPresetBlock(persisted)

    presetUiSavePrompt.pendingName = nil
    presetUiSavePrompt.setMode("name")
    presetNameInput.Text = customPreset and customPreset.Name or ""
    setPresetNameMenuVisible(true)
end

presetUiSavePrompt.persist = function(includeUiCustomization)
    local presetName = trimText(presetUiSavePrompt.pendingName)
    if presetName == "" then
        showStatus("Enter a preset name first.", true)
        setPresetNameMenuVisible(true)
        return
    end

    ScreenGui:SetAttribute("HitboxSize", currentHitbox)
    ScreenGui:SetAttribute("ShowSelections", showHitboxSelections)
    ScreenGui:SetAttribute("PunchSpeed", currentPunchSpeed)
    ScreenGui:SetAttribute("StompSpeed", currentStompSpeed)
    ScreenGui:SetAttribute("UIToggleKey", toggleKeyBox.Text)
    ScreenGui:SetAttribute("PanicKey", panicKeyCode.Name)
    ScreenGui:SetAttribute("HitboxToggleHotkey", hitboxToggleHotkeyCode and hitboxToggleHotkeyCode.Name or "")
    ScreenGui:SetAttribute("WeaveGlideToggleHotkey", weaveGlideToggleHotkeyCode and weaveGlideToggleHotkeyCode.Name or "")
    ScreenGui:SetAttribute("AntiWeaveToggleHotkey", antiWeaveToggleHotkeyCode and antiWeaveToggleHotkeyCode.Name or "")
    ScreenGui:SetAttribute("HitboxEnabled", hitboxEnabled)
    ScreenGui:SetAttribute("NoBounceModeEnabled", noBounceModeEnabled)
    ScreenGui:SetAttribute("IncludeGroundedTargets", includeGroundedTargets)
    ScreenGui:SetAttribute("WeaveGlideEnabled", weaveGlideEnabled)
    ScreenGui:SetAttribute("WeaveGlideStrength", weaveGlideStrength)
    ScreenGui:SetAttribute("HeadHidden", headHidden)
    ScreenGui:SetAttribute("LowGraphicsEnabled", lowGraphicsEnabled)
    ScreenGui:SetAttribute("StretchResEnabled", stretchResEnabled)
    ScreenGui:SetAttribute("LookSensitivityEnabled", lookSensitivityEnabled)
    ScreenGui:SetAttribute("LookSensitivity", mouseSensitivityMultiplier)
    ScreenGui:SetAttribute("MouseSensitivity", mouseSensitivityMultiplier)
    ScreenGui:SetAttribute("StartupCinematicEnabled", STARTUP_CINEMATIC_ENABLED)
    ScreenGui:SetAttribute("GuiSpawnPosition", GUI_SPAWN_POSITION_MODE)

    local customPresetPayload = {
        Name = presetName,
        Settings = buildSettingsSnapshot(),
    }
    if includeUiCustomization then
        customPresetPayload.UICustomization = presetUiSavePrompt.buildUiCustomizationSnapshot()
    end

    local ok = persistSettingsData({
        SavedSettings = buildSettingsSnapshot(),
        CustomPreset = customPresetPayload,
        updatedAt = os.time(),
    })

    presetUiSavePrompt.pendingName = nil
    if ok then
        updateCustomPresetUI(presetName)
        setPresetNameMenuVisible(false)
        showStatus("Settings saved.", false)
    else
        setPresetNameMenuVisible(false)
        showStatus("Settings saved for this run only.", false)
    end
end

local function confirmPresetSave()
    if presetUiSavePrompt.mode == "ui_confirm" then
        presetUiSavePrompt.persist(true)
        return
    end

    local presetName = trimText(presetNameInput.Text)
    if presetName == "" then
        showStatus("Enter a preset name first.", true)
        return
    end

    presetUiSavePrompt.pendingName = presetName
    presetUiSavePrompt.setMode("ui_confirm")
end

local function applySettingsData(settingsData, silent, successMessage, emptyMessage)
    local h = settingsData and settingsData.HitboxSize or nil
    local savedShowSelections = settingsData and settingsData.ShowSelections
    local legacyTransparency = settingsData and settingsData.Transparency or nil
    local savedHitboxOutlineColor = settingsData and settingsData.HitboxOutlineColor or nil
    local p = settingsData and settingsData.PunchSpeed or nil
    local s = settingsData and settingsData.StompSpeed or nil
    local k = settingsData and settingsData.UIToggleKey or nil
    local savedPanicKey = settingsData and settingsData.PanicKey or nil
    local savedHitboxToggleHotkey = settingsData and settingsData.HitboxToggleHotkey or nil
    local savedWeaveGlideToggleHotkey = settingsData and settingsData.WeaveGlideToggleHotkey or nil
    local savedAntiWeaveToggleHotkey = settingsData and settingsData.AntiWeaveToggleHotkey or nil
    local savedHitboxEnabled = settingsData and settingsData.HitboxEnabled or nil
    local savedNoBounceModeEnabled = settingsData and settingsData.NoBounceModeEnabled or nil
    local savedIncludeGroundedTargets = settingsData and settingsData.IncludeGroundedTargets or nil
    local savedWeaveGlideEnabled = settingsData and settingsData.WeaveGlideEnabled or nil
    local savedWeaveGlideStrength = settingsData and settingsData.WeaveGlideStrength or nil
    local savedAntiWeaveEnabled = settingsData and settingsData.AntiWeaveEnabled or nil
    local savedHeadHidden = settingsData and settingsData.HeadHidden or nil
    local savedLowGraphicsEnabled = settingsData and settingsData.LowGraphicsEnabled or nil
    local savedStretchResEnabled = settingsData and settingsData.StretchResEnabled or nil
    local savedStretchResValue = settingsData and settingsData.StretchResValue or nil
    local savedLookSensitivityEnabled = settingsData and settingsData.LookSensitivityEnabled or nil
    local savedLookSensitivity = settingsData and (settingsData.LookSensitivity ~= nil and settingsData.LookSensitivity or settingsData.MouseSensitivity) or nil
    local savedWalkSpeed = settingsData and settingsData.WalkSpeed or nil
    local savedLoopWalkSpeedEnabled = settingsData and settingsData.LoopWalkSpeedEnabled or nil
    local savedGuiSpawnPosition = settingsData and settingsData.GuiSpawnPosition or nil
    local loadedAny = false

    if h ~= nil then
        local parsedHitbox = tonumber(h)
        if parsedHitbox then
            parsedHitbox = math.clamp(math.floor((parsedHitbox * 10) + 0.5) / 10, HITBOX_MIN, HITBOX_MAX)
            currentHitbox = parsedHitbox
            hitboxTextBox.Text = tostring(currentHitbox)
            hitboxValueLabel.Text = tostring(currentHitbox)
            local rel = (currentHitbox - HITBOX_MIN) / (HITBOX_MAX - HITBOX_MIN)
            hitboxSliderFill.Size = UDim2.new(rel, 0, 1, 0)
            loadedAny = true
        end
    end
    if savedShowSelections == nil and legacyTransparency ~= nil then
        local parsedLegacyTransparency = tonumber(legacyTransparency)
        if parsedLegacyTransparency ~= nil then
            savedShowSelections = parsedLegacyTransparency > 0
        end
    end
    if savedShowSelections ~= nil then
        showHitboxSelections = savedShowSelections and true or false
        if showSelectionsToggle and showSelectionsToggleKnob then
            setToggleSwitchState(showSelectionsToggle, showSelectionsToggleKnob, showHitboxSelections)
        end
        loadedAny = true
    end
    if savedHitboxOutlineColor ~= nil then
        HITBOX_TRANSPARENT_COLOR = parseSettingsColor(savedHitboxOutlineColor, HITBOX_TRANSPARENT_COLOR)
        if setHitboxColorControlState then
            setHitboxColorControlState(HITBOX_TRANSPARENT_COLOR)
        end
        if type(UpdatePlayers) == "function" then
            pcall(UpdatePlayers)
        end
        loadedAny = true
    end
    if p then
        currentPunchSpeed = p
        punchTextBox.Text = tostring(p)
        punchValueLabel.Text = tostring(p)
        local rel = (p - PUNCH_MIN) / (PUNCH_MAX - PUNCH_MIN)
        punchSliderFill.Size = UDim2.new(rel, 0, 1, 0)
        loadedAny = true
    end
    if s then
        currentStompSpeed = s
        stompSlider.TextBox.Text = tostring(s)
        stompSlider.ValueLabel.Text = tostring(s)
        local rel = (s - STOMP_MIN) / (STOMP_MAX - STOMP_MIN)
        stompSlider.Fill.Size = UDim2.new(rel, 0, 1, 0)
        loadedAny = true
    end
    if k and #k > 0 then
        toggleKeyBox.Text = k
        toggleKey = tostring(k):upper()
        loadedAny = true
    end
    if savedPanicKey and #tostring(savedPanicKey) > 0 then
        local parsedPanicKeyCode = parseKeyCodeFromText(savedPanicKey)
        if parsedPanicKeyCode then
            panicKeyCode = parsedPanicKeyCode
            if panicKeyBox then
                panicKeyBox.Text = panicKeyCode.Name
            end
            loadedAny = true
        end
    end
    if savedHitboxToggleHotkey ~= nil then
        local parsed = parseKeyCodeFromText(savedHitboxToggleHotkey)
        hitboxToggleHotkeyCode = parsed
        if hitboxToggleHotkeyBox then
            hitboxToggleHotkeyBox.Text = parsed and parsed.Name or ""
        end
        loadedAny = true
    end
    if savedWeaveGlideToggleHotkey ~= nil then
        local parsed = parseKeyCodeFromText(savedWeaveGlideToggleHotkey)
        weaveGlideToggleHotkeyCode = parsed
        if weaveGlideToggleHotkeyBox then
            weaveGlideToggleHotkeyBox.Text = parsed and parsed.Name or ""
        end
        loadedAny = true
    end
    if savedAntiWeaveToggleHotkey ~= nil then
        local parsed = parseKeyCodeFromText(savedAntiWeaveToggleHotkey)
        antiWeaveToggleHotkeyCode = parsed
        if antiWeaveToggleHotkeyBox then
            antiWeaveToggleHotkeyBox.Text = parsed and parsed.Name or ""
        end
        loadedAny = true
    end
    if savedWalkSpeed ~= nil then
        local resolvedWalkSpeed = tonumber(savedWalkSpeed)
        if resolvedWalkSpeed then
            currentWalkSpeed = math.clamp(math.floor(resolvedWalkSpeed * 100) / 100, 0, 300)
            walkSpeedBox.Text = tostring(currentWalkSpeed)
            loadedAny = true
        end
    end
    if savedHitboxEnabled ~= nil then
        hitboxEnabled = savedHitboxEnabled and true or false
        setToggleSwitchState(hitboxToggle, hitboxToggleKnob, hitboxEnabled)
        loadedAny = true
    end
    if savedNoBounceModeEnabled ~= nil then
        noBounceModeEnabled = savedNoBounceModeEnabled and true or false
        noBounceModeExpireAt = 0
        noBounceModeCollisionApplied = false
        if noBounceToggle and noBounceToggleKnob then
            setToggleSwitchState(noBounceToggle, noBounceToggleKnob, noBounceModeEnabled)
        end
        loadedAny = true
    end
    if savedIncludeGroundedTargets ~= nil then
        includeGroundedTargets = savedIncludeGroundedTargets and true or false
        setToggleSwitchState(hitboxSmartModeToggle, hitboxSmartModeToggleKnob, includeGroundedTargets)
        loadedAny = true
    end
    if savedWeaveGlideEnabled ~= nil then
        local weaveEnabled = savedWeaveGlideEnabled and true or false
        if setWeaveGlideEnabledState then
            setWeaveGlideEnabledState(weaveEnabled)
        else
            weaveGlideEnabled = weaveEnabled
            setToggleSwitchState(weaveGlideToggle, weaveGlideToggleKnob, weaveGlideEnabled)
        end
        loadedAny = true
    end
    if savedWeaveGlideStrength ~= nil then
        local parsedStrength = tonumber(savedWeaveGlideStrength)
        if parsedStrength then
            setWeaveGlideStrengthValue(parsedStrength)
            loadedAny = true
        end
    end
    if savedAntiWeaveEnabled ~= nil then
        antiWeaveEnabled = savedAntiWeaveEnabled and true or false
        setToggleSwitchState(ApplyButton, applyToggleKnob, antiWeaveEnabled)
        loadedAny = true
    end
    if savedHeadHidden ~= nil then
        headHidden = savedHeadHidden and true or false
        setToggleSwitchState(hideHeadToggle, hideHeadToggleKnob, headHidden)
        loadedAny = true
    end
    if savedLowGraphicsEnabled ~= nil then
        setLowGraphicsMode(savedLowGraphicsEnabled and true or false)
        updateLowGraphicsToggleVisual()
        loadedAny = true
    end
    if savedStretchResValue ~= nil then
        local parsedStretchResValue = tonumber(savedStretchResValue)
        if parsedStretchResValue then
            setStretchResResolution(parsedStretchResValue)
            loadedAny = true
        end
    end
    if savedStretchResEnabled ~= nil then
        setStretchResEnabledState(savedStretchResEnabled and true or false, false)
        loadedAny = true
    end
    if savedLookSensitivity ~= nil then
        local parsedMouseSensitivity = tonumber(savedLookSensitivity)
        if parsedMouseSensitivity then
            setMouseSensitivityMultiplier(parsedMouseSensitivity)
            loadedAny = true
        end
    end
    if savedLookSensitivityEnabled ~= nil then
        setLookSensitivityEnabledState(savedLookSensitivityEnabled and true or false, false)
        loadedAny = true
    end
    if savedLoopWalkSpeedEnabled ~= nil then
        loopWalkSpeedEnabled = savedLoopWalkSpeedEnabled and true or false
        setToggleSwitchState(loopWalkSpeedToggle, loopWalkSpeedToggleKnob, loopWalkSpeedEnabled)
        local humanoid = getLocalHumanoid()
        if humanoid then
            if loopWalkSpeedEnabled then
                humanoid.WalkSpeed = currentWalkSpeed
            else
                humanoid.WalkSpeed = defaultWalkSpeed
            end
        end
        loadedAny = true
    end
    if settingsData and settingsData.StartupCinematicEnabled ~= nil then
        STARTUP_CINEMATIC_ENABLED = settingsData.StartupCinematicEnabled and true or false
        if startupAnimationToggle and startupAnimationToggleKnob then
            setToggleSwitchState(startupAnimationToggle, startupAnimationToggleKnob, STARTUP_CINEMATIC_ENABLED)
        end
        loadedAny = true
    end
    if savedGuiSpawnPosition ~= nil then
        applyGuiSpawnPosition(savedGuiSpawnPosition, true)
        loadedAny = true
    end

    applyLocalHeadVisibility()
    refreshHeadVisibilityHook()
    applyLocalRootVisibility()
    applyAttackSpeedToLocalLive()
    pcall(UpdatePlayers)
    refreshQuickHud()

    if not silent then
        if loadedAny then
            showStatus(successMessage or "Saved settings loaded.", false)
        else
            showStatus(emptyMessage or "No saved settings found.", true)
        end
    end
end

local function loadSettings(silent, successMessage, emptyMessage)
    local persisted = loadPersistedSettingsData() or {}
    local settingsData = getSavedSettingsBlock(persisted)
    applySettingsData(settingsData, silent, successMessage, emptyMessage)
end

SHARE_CODE_PREFIX = "TOE-SHARE-1:"

function buildCombatShareSnapshot()
    return {
        HitboxSize = currentHitbox,
        ShowSelections = showHitboxSelections,
        HitboxOutlineColor = serializeSettingsColor(HITBOX_TRANSPARENT_COLOR),
        PunchSpeed = currentPunchSpeed,
        StompSpeed = currentStompSpeed,
        HitboxEnabled = hitboxEnabled,
        NoBounceModeEnabled = noBounceModeEnabled,
        IncludeGroundedTargets = includeGroundedTargets,
        AntiWeaveEnabled = antiWeaveEnabled,
        WalkSpeed = currentWalkSpeed,
        LoopWalkSpeedEnabled = loopWalkSpeedEnabled,
        WeaveGlideEnabled = weaveGlideEnabled,
        WeaveGlideStrength = weaveGlideStrength,
    }
end

function buildShareCodeForMode(mode)
    local payload = {
        Version = 1,
        Type = mode,
        Data = nil,
    }

    if mode == "combat" then
        payload.Data = buildCombatShareSnapshot()
    elseif mode == "customization" then
        payload.Data = presetUiSavePrompt.buildUiCustomizationSnapshot()
    else
        return nil
    end

    local ok, encoded = pcall(function()
        return SHARE_CODE_PREFIX .. HttpService:JSONEncode(payload)
    end)
    if not ok then
        return nil
    end
    return encoded
end

function exportShareCode(mode, targetBox)
    local code = buildShareCodeForMode(mode)
    if not code then
        showStatus("Failed to build share code.", true)
        return
    end

    local copied = false
    if type(setclipboard) == "function" then
        copied = pcall(function()
            setclipboard(code)
        end)
    end

    if copied then
        showStatus((mode == "combat" and "Combat" or "Customization") .. " code copied to clipboard.", false)
    else
        showStatus("Clipboard unavailable in this executor.", true)
    end
end

function importShareCode(mode, sourceBox)
    if not sourceBox or not sourceBox:IsA("TextBox") then
        showStatus("Share code box is unavailable.", true)
        return
    end

    local raw = trimText(sourceBox.Text)
    if raw == "" then
        showStatus("Paste a share code first.", true)
        return
    end

    if string.sub(raw, 1, #SHARE_CODE_PREFIX) ~= SHARE_CODE_PREFIX then
        showStatus("Invalid share code format.", true)
        return
    end

    local jsonPayload = string.sub(raw, #SHARE_CODE_PREFIX + 1)
    local ok, decoded = pcall(function()
        return HttpService:JSONDecode(jsonPayload)
    end)
    if not ok or type(decoded) ~= "table" or type(decoded.Data) ~= "table" then
        showStatus("Share code parse failed.", true)
        return
    end

    local codeType = tostring(decoded.Type or "")
    if mode == "combat" and codeType ~= "combat" then
        showStatus("This is not a combat share code.", true)
        return
    end
    if mode == "customization" and codeType ~= "customization" then
        showStatus("This is not a customization share code.", true)
        return
    end

    if mode == "combat" then
        applySettingsData(decoded.Data, false, "Combat share code loaded.", "Invalid combat code.")
        return
    end

    if applyUiCustomizationData then
        applyUiCustomizationData(decoded.Data)
        showStatus("Customization share code loaded.", false)
    else
        showStatus("Customization loader unavailable.", true)
    end
end

function updateShareCodeBoxAlignment(box)
    if not box or not box:IsA("TextBox") then
        return
    end

    local hasText = trimText(box.Text) ~= ""
    box.TextXAlignment = hasText and Enum.TextXAlignment.Left or Enum.TextXAlignment.Center
end

function hookShareCodeBox(box)
    if not box or not box:IsA("TextBox") then
        return
    end

    pcall(function()
        box.TextTruncate = Enum.TextTruncate.AtEnd
    end)

    updateShareCodeBoxAlignment(box)

    box:GetPropertyChangedSignal("Text"):Connect(function()
        updateShareCodeBoxAlignment(box)
    end)

    box.Focused:Connect(function()
        box.TextXAlignment = Enum.TextXAlignment.Left
    end)

    box.FocusLost:Connect(function()
        updateShareCodeBoxAlignment(box)
    end)
end

