local MAIN_FRAME_WIDTH = 360
local MAIN_FRAME_HEIGHT = 740

isMobileClient = UserInputService.TouchEnabled and not UserInputService.KeyboardEnabled
if isMobileClient then
    MAIN_FRAME_WIDTH = 320
    MAIN_FRAME_HEIGHT = 620
end

MainFrame = Instance.new("Frame")
MainFrame.Size = UDim2.new(0, MAIN_FRAME_WIDTH, 0, MAIN_FRAME_HEIGHT)
MainFrame.Position = UDim2.new(0.5, -math.floor(MAIN_FRAME_WIDTH / 2), 0.5, -math.floor(MAIN_FRAME_HEIGHT / 2))
MainFrame.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
MainFrame.BackgroundTransparency = currentMainUiTransparency
MainFrame.BorderSizePixel = 0
MainFrame.Visible = false
MainFrame.Active = true
MainFrame.Draggable = false
MainFrame.Parent = ScreenGui

UIScale = Instance.new("UIScale")
UIScale.Scale = 1
UIScale.Parent = MainFrame

if isMobileClient then
    UIScale.Scale = 0.9
    MainFrame.Position = UDim2.new(0.5, -math.floor((MAIN_FRAME_WIDTH * UIScale.Scale) / 2), 0.5, -math.floor((MAIN_FRAME_HEIGHT * UIScale.Scale) / 2))
end

function getMobileViewportScale()
    if not isMobileClient then
        return 1
    end

    local camera = Workspace.CurrentCamera
    local viewport = camera and camera.ViewportSize
    if not viewport or viewport.X <= 0 or viewport.Y <= 0 then
        return 0.9
    end

    local widthScale = viewport.X / 360
    local heightScale = viewport.Y / 740
    return math.clamp(math.min(widthScale, heightScale), 0.78, 1.05)
end

function applyMobileTextAndLineSizing()
    if not isMobileClient or not MainFrame then
        return
    end

    local viewportScale = getMobileViewportScale()

    if UIScale then
        UIScale.Scale = math.clamp(0.78 + (viewportScale * 0.14), 0.86, 0.93)
        MainFrame.Position = UDim2.new(
            0.5,
            -math.floor((MAIN_FRAME_WIDTH * UIScale.Scale) / 2),
            0.5,
            -math.floor((MAIN_FRAME_HEIGHT * UIScale.Scale) / 2)
        )
    end

    local textScale = math.clamp(viewportScale * 0.98, 0.84, 0.98)
    local lineScale = math.clamp(1.02 + ((1 - viewportScale) * 0.18), 1.02, 1.16)

    for _, obj in ipairs(MainFrame:GetDescendants()) do
        if (obj:IsA("TextLabel") or obj:IsA("TextButton") or obj:IsA("TextBox")) and not obj.TextScaled then
            local baseTextSize = obj:GetAttribute("MobileBaseTextSize")
            if type(baseTextSize) ~= "number" then
                baseTextSize = obj.TextSize
                obj:SetAttribute("MobileBaseTextSize", baseTextSize)
            end
            if type(baseTextSize) == "number" and baseTextSize > 0 then
                obj.TextSize = math.max(10, math.floor(baseTextSize * textScale + 0.5))

                local availableWidth = obj.AbsoluteSize.X - 8
                local availableHeight = obj.AbsoluteSize.Y - 4
                if availableWidth > 0 and availableHeight > 0 then
                    local fittedSize = obj.TextSize
                    while fittedSize > 10 and (obj.TextBounds.X > availableWidth or obj.TextBounds.Y > availableHeight) do
                        fittedSize = fittedSize - 1
                        obj.TextSize = fittedSize
                    end
                end
            end
        elseif obj:IsA("Frame") then
            local nameLower = string.lower(obj.Name or "")
            local isLineFrame = false

            if nameLower:find("underline", 1, true) or nameLower:find("divider", 1, true) then
                isLineFrame = true
            elseif obj.Size.Y.Scale == 0 and obj.Size.Y.Offset > 0 and obj.Size.Y.Offset <= 2 and obj.Size.X.Scale == 0 and obj.Size.X.Offset >= 40 then
                isLineFrame = true
            end

            if isLineFrame then
                local baseLineHeight = obj:GetAttribute("MobileBaseLineHeight")
                if type(baseLineHeight) ~= "number" then
                    baseLineHeight = obj.Size.Y.Offset
                    obj:SetAttribute("MobileBaseLineHeight", baseLineHeight)
                end

                local baseLineWidth = obj:GetAttribute("MobileBaseLineWidth")
                if type(baseLineWidth) ~= "number" then
                    baseLineWidth = obj.Size.X.Offset
                    obj:SetAttribute("MobileBaseLineWidth", baseLineWidth)
                end

                local targetHeight = math.max(2, math.floor(baseLineHeight * lineScale + 0.5))
                local targetWidth = obj.Size.X.Offset
                if obj.Size.X.Scale == 0 and type(baseLineWidth) == "number" and baseLineWidth >= 40 then
                    targetWidth = math.max(40, math.floor(baseLineWidth * math.clamp(viewportScale, 0.86, 1) + 0.5))
                end

                obj.Size = UDim2.new(obj.Size.X.Scale, targetWidth, obj.Size.Y.Scale, targetHeight)
            end
        end
    end
end

UICorner = Instance.new("UICorner", MainFrame)
UICorner.CornerRadius = UDim.new(0, 10)

MainFrameStroke = Instance.new("UIStroke")
