walkSpeedBox = Instance.new("TextBox", tabFrames["Combat"])
walkSpeedBox.Text = tostring(currentWalkSpeed)
walkSpeedBox.Size = UDim2.new(0, 80, 0, 22)
walkSpeedBox.Position = UDim2.new(0, 10, 0, 596)
