hitboxTierPopup = {}
hitboxTierPopup.Frame = Instance.new("Frame", tabFrames["Combat"])
hitboxTierPopup.Frame.Size = UDim2.new(0, 120, 0, 20)
hitboxTierPopup.Frame.Position = UDim2.new(0, 110, 0, 144)
hitboxTierPopup.Frame.BackgroundColor3 = Color3.fromRGB(24, 24, 24)
hitboxTierPopup.Frame.BackgroundTransparency = 1
hitboxTierPopup.Frame.BorderSizePixel = 0
hitboxTierPopup.Frame.Visible = false
hitboxTierPopup.Frame.ZIndex = 8
Instance.new("UICorner", hitboxTierPopup.Frame).CornerRadius = UDim.new(0, 6)

hitboxTierPopup.Label = Instance.new("TextLabel", hitboxTierPopup.Frame)
hitboxTierPopup.Label.Size = UDim2.new(1, 0, 1, 0)
hitboxTierPopup.Label.BackgroundTransparency = 1
hitboxTierPopup.Label.Text = "Legit"
hitboxTierPopup.Label.TextColor3 = Color3.fromRGB(90, 220, 120)
hitboxTierPopup.Label.Font = Enum.Font.GothamBold
hitboxTierPopup.Label.TextSize = 12
hitboxTierPopup.Label.TextTransparency = 1
hitboxTierPopup.HideToken = 0
hitboxTierPopup.IsVisible = false
hitboxTierPopup.CurrentTier = nil

hitboxDragging = false
hitboxDragInput = nil
local HITBOX_MIN, HITBOX_MAX = 1, 10

local function hitboxPosToValue(px)
    local absX = hitboxSliderBar.AbsolutePosition.X
    local w = hitboxSliderBar.AbsoluteSize.X
    local rel = math.clamp((px - absX) / math.max(w, 1), 0, 1)
    local raw = HITBOX_MIN + (HITBOX_MAX - HITBOX_MIN) * rel
    return math.clamp(math.floor((raw * 10) + 0.5) / 10, HITBOX_MIN, HITBOX_MAX)
end

local function getHitboxTierLabelAndColor(value)
    if value <= 4 then
        return "Legit", Color3.fromRGB(90, 220, 120)
    elseif value <= 7 then
        return "dangerous", Color3.fromRGB(255, 174, 84)
    end
    return "blatant", Color3.fromRGB(255, 92, 92)
end

local function getTierPopupPositionsForSlider(sliderBar, popupFrame, visibleYOffset, enterDelta, exitDelta, xOffset)
    local fallback = popupFrame and popupFrame.Position or UDim2.new(0, 0, 0, 0)
    if not sliderBar or not popupFrame or not popupFrame.Parent then
        return fallback, fallback, fallback
    end

    local parentAbs = popupFrame.Parent.AbsolutePosition
    local barAbs = sliderBar.AbsolutePosition
    local visibleX = math.floor((barAbs.X - parentAbs.X) + (xOffset or 0) + 0.5)
    local visibleY = math.floor((barAbs.Y - parentAbs.Y) + (visibleYOffset or -24) + 0.5)
    local shown = UDim2.new(0, visibleX, 0, visibleY)
    local enter = UDim2.new(0, visibleX, 0, visibleY + (enterDelta or 8))
    local exit = UDim2.new(0, visibleX, 0, visibleY - (exitDelta or 6))
    return enter, shown, exit
end

local function hideHitboxTierPopup(delayTime)
    if not hitboxTierPopup or not hitboxTierPopup.Frame or not hitboxTierPopup.Label then
        return
    end

    hitboxTierPopup.HideToken = (hitboxTierPopup.HideToken or 0) + 1
    local token = hitboxTierPopup.HideToken

    task.delay(delayTime or 0, function()
        if not hitboxTierPopup or token ~= hitboxTierPopup.HideToken or not hitboxTierPopup.IsVisible then
            return
        end

        local _, _, exitPos = getTierPopupPositionsForSlider(hitboxSliderBar, hitboxTierPopup.Frame, -31, 8, 6, 0)

        playTween(
            hitboxTierPopup.Frame,
            TweenInfo.new(0.14, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
            {
                Position = exitPos,
                BackgroundTransparency = 1,
            }
        )
        playTween(
            hitboxTierPopup.Label,
            TweenInfo.new(0.14, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
            {
                TextTransparency = 1,
            }
        )

        task.delay(0.15, function()
            if hitboxTierPopup and token == hitboxTierPopup.HideToken and hitboxTierPopup.Frame then
                hitboxTierPopup.Frame.Visible = false
                hitboxTierPopup.IsVisible = false
            end
        end)
    end)
end

local function showHitboxTierPopup(value, holdOpen)
    if not hitboxTierPopup or not hitboxTierPopup.Frame or not hitboxTierPopup.Label then
        return
    end

    local tierText, tierColor = getHitboxTierLabelAndColor(value)
    local sameTier = hitboxTierPopup.CurrentTier == tierText
    hitboxTierPopup.CurrentTier = tierText
    hitboxTierPopup.HideToken = (hitboxTierPopup.HideToken or 0) + 1

    hitboxTierPopup.Label.Text = tierText
    hitboxTierPopup.Label.TextColor3 = tierColor

    if not hitboxTierPopup.IsVisible then
        local enterPos, shownPos = getTierPopupPositionsForSlider(hitboxSliderBar, hitboxTierPopup.Frame, -31, 8, 6, 0)
        hitboxTierPopup.Frame.Visible = true
        hitboxTierPopup.Frame.Position = enterPos
        hitboxTierPopup.Frame.BackgroundTransparency = 1
        hitboxTierPopup.Label.TextTransparency = 1

        playTween(
            hitboxTierPopup.Frame,
            TweenInfo.new(0.12, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
            {
                Position = shownPos,
                BackgroundTransparency = 0.14,
            }
        )
        playTween(
            hitboxTierPopup.Label,
            TweenInfo.new(0.12, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
            {
                TextTransparency = 0,
            }
        )
        hitboxTierPopup.IsVisible = true
    elseif not sameTier then
        local _, shownPos = getTierPopupPositionsForSlider(hitboxSliderBar, hitboxTierPopup.Frame, -31, 8, 6, 0)
        hitboxTierPopup.Frame.Position = shownPos
        hitboxTierPopup.Frame.BackgroundTransparency = 0.14
        hitboxTierPopup.Label.TextTransparency = 0
    end

    if not holdOpen then
        hideHitboxTierPopup(0.5)
    end
end

function applyHitboxValueFromPointerX(pointerX, holdPopup)
    local v = hitboxPosToValue(pointerX)
    local rel = (v - HITBOX_MIN) / (HITBOX_MAX - HITBOX_MIN)
    hitboxSliderFill.Size = UDim2.new(rel, 0, 1, 0)
    hitboxValueLabel.Text = tostring(v)
    hitboxTextBox.Text = tostring(v)
    currentHitbox = v
    if holdPopup then
        showHitboxTierPopup(v, true)
    end
    pcall(UpdatePlayers)
end

function beginHitboxDrag(inp)
    local inputType = inp.UserInputType
    if inputType ~= Enum.UserInputType.MouseButton1 and inputType ~= Enum.UserInputType.Touch then
        return
    end

    hitboxDragging = true
    hitboxDragInput = (inputType == Enum.UserInputType.Touch) and inp or nil
    applyHitboxValueFromPointerX(inp.Position.X, true)
end

function endHitboxDrag(inp)
    if not hitboxDragging then
        return
    end

    if hitboxDragInput then
        if inp.UserInputType ~= Enum.UserInputType.Touch or inp ~= hitboxDragInput then
            return
        end
    elseif inp.UserInputType ~= Enum.UserInputType.MouseButton1 then
        return
    end

    hitboxDragging = false
    hitboxDragInput = nil
    hideHitboxTierPopup(0.12)
end

hitboxSliderFill.Size = UDim2.new((currentHitbox - HITBOX_MIN) / (HITBOX_MAX - HITBOX_MIN), 0, 1, 0)
hitboxValueLabel.Text = tostring(currentHitbox)
hitboxTextBox.Text = tostring(currentHitbox)

hitboxSliderBar.InputBegan:Connect(beginHitboxDrag)
hitboxSliderFill.InputBegan:Connect(beginHitboxDrag)
if hitboxSliderKnob then
    hitboxSliderKnob.InputBegan:Connect(beginHitboxDrag)
end

hitboxSliderBar.InputEnded:Connect(endHitboxDrag)
hitboxSliderFill.InputEnded:Connect(endHitboxDrag)
if hitboxSliderKnob then
    hitboxSliderKnob.InputEnded:Connect(endHitboxDrag)
end

UserInputService.InputChanged:Connect(function(inp)
    if not hitboxDragging then
        return
    end

    if hitboxDragInput then
        if inp.UserInputType ~= Enum.UserInputType.Touch or inp ~= hitboxDragInput then
            return
        end
    elseif inp.UserInputType ~= Enum.UserInputType.MouseMovement then
        return
    end

    applyHitboxValueFromPointerX(inp.Position.X, true)
end)

UserInputService.InputEnded:Connect(endHitboxDrag)
-- Hitbox TextBox sync
hitboxTextBox.FocusLost:Connect(function(enterPressed)
    local v = tonumber(hitboxTextBox.Text)
    if v then
        v = math.clamp(math.floor((v * 10) + 0.5) / 10, HITBOX_MIN, HITBOX_MAX)
        currentHitbox = v
        hitboxValueLabel.Text = tostring(v)
        local rel = (v - HITBOX_MIN) / (HITBOX_MAX - HITBOX_MIN)
        hitboxSliderFill.Size = UDim2.new(rel, 0, 1, 0)
        hitboxTextBox.Text = tostring(v)
        pcall(UpdatePlayers)
    else
        hitboxTextBox.Text = tostring(currentHitbox)
    end
end)

