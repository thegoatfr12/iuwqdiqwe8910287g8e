function getGuiSpawnPositions(mode)
    if mode == "Top Left" then
        return UDim2.new(0, 16, 0, 86), UDim2.new(0, 16, 0, 86)
    end
    if mode == "Top Right" then
        return UDim2.new(1, -MAIN_FRAME_WIDTH - 16, 0, 86), UDim2.new(1, -376, 0, 86)
    end
    if mode == "Bottom Left" then
        return UDim2.new(0, 16, 1, -MAIN_FRAME_HEIGHT - 18), UDim2.new(0, 16, 1, -276)
    end
    if mode == "Bottom Right" then
        return UDim2.new(1, -MAIN_FRAME_WIDTH - 16, 1, -MAIN_FRAME_HEIGHT - 18), UDim2.new(1, -376, 1, -276)
    end

    return UDim2.new(0.5, -math.floor(MAIN_FRAME_WIDTH / 2), 0.5, -math.floor(MAIN_FRAME_HEIGHT / 2)), UDim2.new(0.5, -180, 0.5, -121)
end

function applyGuiSpawnPosition(mode, syncCurrent)
    if type(mode) == "string" and mode ~= "" then
        GUI_SPAWN_POSITION_MODE = mode
    end

    if GUI_SPAWN_POSITION_MODE ~= "Center"
        and GUI_SPAWN_POSITION_MODE ~= "Top Left"
        and GUI_SPAWN_POSITION_MODE ~= "Top Right"
        and GUI_SPAWN_POSITION_MODE ~= "Bottom Left"
        and GUI_SPAWN_POSITION_MODE ~= "Bottom Right" then
        GUI_SPAWN_POSITION_MODE = "Center"
    end

    local mainPos, authPos = getGuiSpawnPositions(GUI_SPAWN_POSITION_MODE)
    mainFrameRestPosition = mainPos
    authFrameRestPosition = authPos
    authFrameIntroStartPosition = UDim2.new(authPos.X.Scale, authPos.X.Offset, authPos.Y.Scale, authPos.Y.Offset - 25)

    if syncCurrent then
        if MainFrame and not MainFrame.Visible then
            MainFrame.Position = mainFrameRestPosition
        end
        if AuthFrame and not isAuthorized then
            AuthFrame.Position = authFrameRestPosition
        end
    end

    if guiSpawnPositionButton then
        guiSpawnPositionButton.Text = tostring(GUI_SPAWN_POSITION_MODE)
    end
end

applyGuiSpawnPosition(GUI_SPAWN_POSITION_MODE, true)

