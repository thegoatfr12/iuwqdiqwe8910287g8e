    local function updateTesterDividerMidpoints()
        if not socialsTestersText then
            return
        end

        local boundsY = socialsTestersText.TextBounds.Y
        if boundsY <= 0 then
            return
        end

        local lines = {}
        for line in (tostring(socialsTestersText.Text or "") .. "\n"):gmatch("(.-)\n") do
            table.insert(lines, line)
        end

        local headerLineIndices = {}
        for i, line in ipairs(lines) do
            if line:match("^%s*%-%s*[^:]+:%s*$") then
                table.insert(headerLineIndices, i)
            end
        end

        if #headerLineIndices < 2 then
            return
        end

        local lineHeight = boundsY / math.max(#lines, 1)
        local topY = socialsTestersText.Position.Y.Offset
        local dividerList = {socialsTestersNameDivider, socialsTestersNameDividerTwo, socialsTestersNameDividerThree, socialsTestersNameDividerFour, socialsTestersNameDividerFive}

        for i = 1, math.min(#dividerList, #headerLineIndices - 1) do
            local currentHeader = headerLineIndices[i]
            local nextHeader = headerLineIndices[i + 1]

            local currentBlockEnd = nextHeader - 1
            while currentBlockEnd > currentHeader and tostring(lines[currentBlockEnd] or "") == "" do
                currentBlockEnd = currentBlockEnd - 1
            end

            local midpointLine = ((currentBlockEnd + nextHeader) * 0.5) - 0.5
            local dividerY = math.floor((topY + (midpointLine * lineHeight)) + 0.5)

            if dividerList[i] then
                dividerList[i].Position = UDim2.new(0, 10, 0, dividerY)
            end
        end
    end

