pinchTouches = {}
pinchStartDist = nil
pinchStartScale = UIScale.Scale
pinchStartPos = MainFrame.Position

connectButton(TouchToggleButton, function()
    if not isAuthorized then
        return
    end

    if mainUiCollapsed then
        expandMainUi()
        return
    end

    MainFrame.Visible = not MainFrame.Visible
end)

UserInputService.TouchStarted:Connect(function(input)
    if not isAuthorized then
        return
    end

    table.insert(pinchTouches, input)
    if #pinchTouches == 2 then
        pinchStartDist = (pinchTouches[1].Position - pinchTouches[2].Position).Magnitude
        pinchStartScale = UIScale.Scale
        pinchStartPos = MainFrame.Position
    end
end)

UserInputService.TouchEnded:Connect(function(input)
    for i, touchInput in ipairs(pinchTouches) do
        if touchInput == input then
            table.remove(pinchTouches, i)
            break
        end
    end

    if #pinchTouches < 2 then
        pinchStartDist = nil
    end
end)

UserInputService.TouchMoved:Connect(function()
    if not isAuthorized or not MainFrame.Visible or #pinchTouches ~= 2 or not pinchStartDist then
        return
    end

    local touchOne = pinchTouches[1]
    local touchTwo = pinchTouches[2]
    if not touchOne or not touchTwo then
        return
    end

    local newDist = (touchOne.Position - touchTwo.Position).Magnitude
    local scale = math.clamp(newDist / pinchStartDist, 0.5, 2)
    UIScale.Scale = math.clamp(pinchStartScale * scale, 0.5, 2)
    MainFrame.Position = UDim2.new(
        pinchStartPos.X.Scale,
        math.floor(pinchStartPos.X.Offset),
        pinchStartPos.Y.Scale,
        math.floor(pinchStartPos.Y.Offset)
    )
end)

