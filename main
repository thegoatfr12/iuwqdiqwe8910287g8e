weaveGlideTierPopup.Label = Instance.new("TextLabel", weaveGlideTierPopup.Frame)
weaveGlideTierPopup.Label.Size = UDim2.new(1, 0, 1, 0)
weaveGlideTierPopup.Label.BackgroundTransparency = 1
weaveGlideTierPopup.Label.Text = "Legit"
weaveGlideTierPopup.Label.TextColor3 = Color3.fromRGB(90, 220, 120)
