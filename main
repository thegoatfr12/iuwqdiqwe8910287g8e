function setStretchResEnabledState(enabled, animate)
    local shouldEnable = enabled and true or false

    if stretchResConnection then
        pcall(function()
            stretchResConnection:Disconnect()
        end)
        stretchResConnection = nil
    end

    stretchResEnabled = shouldEnable

    if stretchResEnabled then
        stretchResConnection = RunService.RenderStepped:Connect(function()
            local camera = Workspace.CurrentCamera
            if not camera then
                return
            end

            stretchResLastBaseCFrame = camera.CFrame
            camera.CFrame = camera.CFrame * CFrame.new(0, 0, 0, 1, 0, 0, 0, STRETCH_RESOLUTION, 0, 0, 0, 1)
        end)
    else
        local camera = Workspace.CurrentCamera
        if camera and stretchResLastBaseCFrame then
            pcall(function()
                camera.CFrame = stretchResLastBaseCFrame
            end)
        end
        stretchResLastBaseCFrame = nil
    end

    if stretchResToggle and stretchResToggleKnob then
        setToggleSwitchState(stretchResToggle, stretchResToggleKnob, stretchResEnabled, animate)
    end
end

function setStretchResResolution(value)
    local clamped = math.clamp(math.floor((tonumber(value) or STRETCH_RESOLUTION) * 100) / 100, STRETCH_RESOLUTION_MIN, STRETCH_RESOLUTION_MAX)
    STRETCH_RESOLUTION = clamped

    if stretchResSliderLabel then
        stretchResSliderLabel.Text = string.format("%.2f", STRETCH_RESOLUTION)
    end

    if stretchResSliderFill then
        local rel = (STRETCH_RESOLUTION_MAX - STRETCH_RESOLUTION) / math.max((STRETCH_RESOLUTION_MAX - STRETCH_RESOLUTION_MIN), 0.0001)
        stretchResSliderFill.Size = UDim2.new(rel, 0, 1, 0)
    end
    if stretchResSliderValueLabel then
        stretchResSliderValueLabel.Text = string.format("%.2f", STRETCH_RESOLUTION)
    end
end

function stretchResPosToValue(px)
    if not stretchResSliderBar then
        return STRETCH_RESOLUTION
    end

    local absX = stretchResSliderBar.AbsolutePosition.X
    local w = stretchResSliderBar.AbsoluteSize.X
    local rel = math.clamp((px - absX) / math.max(w, 1), 0, 1)
    local raw = STRETCH_RESOLUTION_MAX - ((STRETCH_RESOLUTION_MAX - STRETCH_RESOLUTION_MIN) * rel)
    return math.clamp(math.floor(raw * 100) / 100, STRETCH_RESOLUTION_MIN, STRETCH_RESOLUTION_MAX)
end

function applyMouseSensitivityMultiplier()
    local ok = pcall(function()
        UserInputService.MouseDeltaSensitivity = mouseSensitivityMultiplier
    end)
    mouseSensitivitySupported = ok
    return ok
end

function applyNativeLookSensitivityMultiplier()
    local gamepadOk = false
    local touchOk = false

    pcall(function()
        local userSettings = UserSettings()
        if not userSettings or type(userSettings.GetService) ~= "function" then
            return
        end

        local gameSettings = userSettings:GetService("UserGameSettings")
        if not gameSettings then
            return
        end

        if gameSettings.GamepadCameraSensitivity ~= nil then
            local okSetGamepad = pcall(function()
                gameSettings.GamepadCameraSensitivity = mouseSensitivityMultiplier
            end)
            gamepadOk = okSetGamepad and true or false
        end

        if gameSettings.TouchCameraSensitivity ~= nil then
            local okSetTouch = pcall(function()
                gameSettings.TouchCameraSensitivity = mouseSensitivityMultiplier
            end)
            touchOk = okSetTouch and true or false
        end
    end)

    return gamepadOk, touchOk
end

function isGamepadInputType(userInputType)
    return userInputType == Enum.UserInputType.Gamepad1
        or userInputType == Enum.UserInputType.Gamepad2
        or userInputType == Enum.UserInputType.Gamepad3
        or userInputType == Enum.UserInputType.Gamepad4
        or userInputType == Enum.UserInputType.Gamepad5
        or userInputType == Enum.UserInputType.Gamepad6
        or userInputType == Enum.UserInputType.Gamepad7
        or userInputType == Enum.UserInputType.Gamepad8
end

function extractLookVector2(raw)
    if typeof(raw) == "Vector2" then
        return raw
    end
    if typeof(raw) == "Vector3" then
        local yAxis = raw.Y
        if math.abs(raw.Z) > math.abs(yAxis) then
            yAxis = raw.Z
        end
        return Vector2.new(raw.X, yAxis)
    end
    return Vector2.new(0, 0)
end

function sampleConnectedGamepadLookVector()
    local connected = nil
    local okConnected = pcall(function()
        connected = UserInputService:GetConnectedGamepads()
    end)
    if not okConnected or type(connected) ~= "table" then
        return lookSensitivityGamepadVector
    end

    for _, padType in ipairs(connected) do
        local states = nil
        local okStates = pcall(function()
            states = UserInputService:GetGamepadState(padType)
        end)
        if okStates and type(states) == "table" then
            for _, state in ipairs(states) do
                if state and state.KeyCode == Enum.KeyCode.Thumbstick2 then
                    return extractLookVector2(state.Position)
                end
            end
        end
    end

    return Vector2.new(0, 0)
end

function ensureLookSensitivityHooks()
    if not lookSensitivityTouchMovedConn then
        lookSensitivityTouchMovedConn = UserInputService.TouchMoved:Connect(function(input)
            if scriptUnloaded then
                return
            end
            if input and input.Delta then
                lookSensitivityTouchDelta = lookSensitivityTouchDelta + input.Delta
            end
        end)
    end

    if not lookSensitivityInputChangedConn then
        lookSensitivityInputChangedConn = UserInputService.InputChanged:Connect(function(input)
            if scriptUnloaded then
                return
            end

            if isGamepadInputType(input.UserInputType) and input.KeyCode == Enum.KeyCode.Thumbstick2 then
                lookSensitivityGamepadVector = extractLookVector2(input.Position)
            end
        end)
    end

    if not lookSensitivityInputEndedConn then
        lookSensitivityInputEndedConn = UserInputService.InputEnded:Connect(function(input)
            if scriptUnloaded then
                return
            end

            if isGamepadInputType(input.UserInputType) and input.KeyCode == Enum.KeyCode.Thumbstick2 then
                lookSensitivityGamepadVector = Vector2.new(0, 0)
            end
        end)
    end
end

function updateLookSensitivityBinding()
    if not lookSensitivityEnabled then
        if lookSensitivityRenderBound then
            pcall(function()
                RunService:UnbindFromRenderStep(LOOK_SENS_RENDER_STEP_NAME)
            end)
            lookSensitivityRenderBound = false
        end
        return
    end

    ensureLookSensitivityHooks()

    local extraMultiplier = math.max(mouseSensitivityMultiplier - 1, 0)
    if extraMultiplier <= 0 then
        if lookSensitivityRenderBound then
            pcall(function()
                RunService:UnbindFromRenderStep(LOOK_SENS_RENDER_STEP_NAME)
            end)
            lookSensitivityRenderBound = false
        end
        return
    end

    if lookSensitivityRenderBound then
        return
    end

    RunService:BindToRenderStep(LOOK_SENS_RENDER_STEP_NAME, Enum.RenderPriority.Last.Value, function(dt)
        if scriptUnloaded then
            return
        end

        local camera = Workspace.CurrentCamera
        if not camera then
            lookSensitivityTouchDelta = Vector2.new(0, 0)
            return
        end

        local extra = math.max(mouseSensitivityMultiplier - 1, 0)
        if extra <= 0 then
            lookSensitivityTouchDelta = Vector2.new(0, 0)
            return
        end

        local yawDelta = 0
        local pitchDelta = 0

        if lookSensitivityTouchDelta.X ~= 0 or lookSensitivityTouchDelta.Y ~= 0 then
            yawDelta = yawDelta - (lookSensitivityTouchDelta.X * LOOK_SENS_TOUCH_BOOST_PER_PIXEL * extra)
            pitchDelta = pitchDelta - (lookSensitivityTouchDelta.Y * LOOK_SENS_TOUCH_BOOST_PER_PIXEL * extra)
            lookSensitivityTouchDelta = Vector2.new(0, 0)
        end

        lookSensitivityGamepadVector = sampleConnectedGamepadLookVector()

        if lookSensitivityGamepadVector.Magnitude > 0.06 then
            local frameScale = dt * 60
            yawDelta = yawDelta - (lookSensitivityGamepadVector.X * LOOK_SENS_GAMEPAD_BOOST_PER_TICK * extra * frameScale)
            pitchDelta = pitchDelta - (lookSensitivityGamepadVector.Y * LOOK_SENS_GAMEPAD_BOOST_PER_TICK * extra * frameScale)
        end

        if yawDelta ~= 0 or pitchDelta ~= 0 then
            yawDelta = math.clamp(yawDelta, -0.4, 0.4)
            pitchDelta = math.clamp(pitchDelta, -0.4, 0.4)
            camera.CFrame = camera.CFrame * CFrame.Angles(pitchDelta, yawDelta, 0)
        end
    end)

    lookSensitivityRenderBound = true
end

function setLookSensitivityEnabledState(enabled, animate)
    lookSensitivityEnabled = enabled and true or false

    if lookSensitivityEnabled then
        applyMouseSensitivityMultiplier()
        applyNativeLookSensitivityMultiplier()
        updateLookSensitivityBinding()
    else
        pcall(function()
            UserInputService.MouseDeltaSensitivity = 1
        end)
        pcall(function()
            local userSettings = UserSettings()
            if userSettings and type(userSettings.GetService) == "function" then
                local gameSettings = userSettings:GetService("UserGameSettings")
                if gameSettings then
                    pcall(function()
                        gameSettings.GamepadCameraSensitivity = 1
                    end)
                    pcall(function()
                        gameSettings.TouchCameraSensitivity = 1
                    end)
                end
            end
        end)

        if lookSensitivityRenderBound then
            pcall(function()
                RunService:UnbindFromRenderStep(LOOK_SENS_RENDER_STEP_NAME)
            end)
            lookSensitivityRenderBound = false
        end

        lookSensitivityTouchDelta = Vector2.new(0, 0)
        lookSensitivityGamepadVector = Vector2.new(0, 0)
    end

    if lookSensitivityToggle and lookSensitivityToggleKnob then
        setToggleSwitchState(lookSensitivityToggle, lookSensitivityToggleKnob, lookSensitivityEnabled, animate)
    end
end

function setMouseSensitivityMultiplier(value)
    local clamped = math.clamp(math.floor((tonumber(value) or mouseSensitivityMultiplier) * 100) / 100, MOUSE_SENSITIVITY_MIN, MOUSE_SENSITIVITY_MAX)
    mouseSensitivityMultiplier = clamped

    if mouseSensitivitySliderFill then
        local rel = (mouseSensitivityMultiplier - MOUSE_SENSITIVITY_MIN) / math.max((MOUSE_SENSITIVITY_MAX - MOUSE_SENSITIVITY_MIN), 0.0001)
        mouseSensitivitySliderFill.Size = UDim2.new(rel, 0, 1, 0)
    end
    if mouseSensitivitySliderLabel then
        mouseSensitivitySliderLabel.Text = string.format("%.2f", mouseSensitivityMultiplier)
    end
    if mouseSensitivitySliderValueLabel then
        mouseSensitivitySliderValueLabel.Text = string.format("%.2f", mouseSensitivityMultiplier)
    end

    if lookSensitivityEnabled then
        applyMouseSensitivityMultiplier()
        applyNativeLookSensitivityMultiplier()
        updateLookSensitivityBinding()
    end
end

function mouseSensitivityPosToValue(px)
    if not mouseSensitivitySliderBar then
        return mouseSensitivityMultiplier
    end

    local absX = mouseSensitivitySliderBar.AbsolutePosition.X
    local w = mouseSensitivitySliderBar.AbsoluteSize.X
    local rel = math.clamp((px - absX) / math.max(w, 1), 0, 1)
    local raw = MOUSE_SENSITIVITY_MIN + ((MOUSE_SENSITIVITY_MAX - MOUSE_SENSITIVITY_MIN) * rel)
    return math.clamp(math.floor(raw * 100) / 100, MOUSE_SENSITIVITY_MIN, MOUSE_SENSITIVITY_MAX)
end

function persistMouseSensitivitySetting()
    local persisted = loadPersistedSettingsData() or {}
    local settingsData = persisted
    if type(persisted.SavedSettings) == "table" then
        settingsData = persisted.SavedSettings
    elseif type(settingsData) ~= "table" then
        settingsData = {}
        persisted = {SavedSettings = settingsData}
    end

    settingsData.LookSensitivityEnabled = lookSensitivityEnabled
    settingsData.LookSensitivity = mouseSensitivityMultiplier
    settingsData.MouseSensitivity = mouseSensitivityMultiplier
    persistSettingsData(persisted)
end

function persistCombatToggleHotkeys()
    local persisted = loadPersistedSettingsData() or {}
    local settingsData = persisted
    if type(persisted.SavedSettings) == "table" then
        settingsData = persisted.SavedSettings
    elseif type(settingsData) ~= "table" then
        settingsData = {}
        persisted = {SavedSettings = settingsData}
    end

    settingsData.HitboxToggleHotkey = hitboxToggleHotkeyCode and hitboxToggleHotkeyCode.Name or ""
    settingsData.WeaveGlideToggleHotkey = weaveGlideToggleHotkeyCode and weaveGlideToggleHotkeyCode.Name or ""
    settingsData.AntiWeaveToggleHotkey = antiWeaveToggleHotkeyCode and antiWeaveToggleHotkeyCode.Name or ""
    persistSettingsData(persisted)
end

function persistStretchResSetting()
