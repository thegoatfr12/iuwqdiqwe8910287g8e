-- UI Toggle Key Logic
local function updateToggleKey()
    local key = toggleKeyBox.Text:upper()
    if #key > 0 then
        toggleKey = key
    end
end

local function updatePanicKey()
    if not panicKeyBox then
        return
    end

    local parsedKeyCode = parseKeyCodeFromText(panicKeyBox.Text)
    if parsedKeyCode then
        panicKeyCode = parsedKeyCode
        panicKeyBox.Text = string.upper(parsedKeyCode.Name)
    else
        panicKeyBox.Text = string.upper(panicKeyCode.Name)
        showStatus("Invalid panic key.", true)
    end
end

local function parseOptionalHotkeyFromBox(box, invalidMessage)
    if not box then
        return nil
    end

    local raw = trimText(box.Text)
    if raw == "" then
        box.Text = ""
        return nil
    end

    local parsed = parseKeyCodeFromText(raw)
    if parsed then
        box.Text = string.upper(parsed.Name)
        return parsed
    end

    box.Text = ""
    if invalidMessage then
        showStatus(invalidMessage, true)
    end
    return nil
end

local function updateCombatToggleHotkeys()
    hitboxToggleHotkeyCode = parseOptionalHotkeyFromBox(hitboxToggleHotkeyBox, "Invalid hitbox hotkey.")
    weaveGlideToggleHotkeyCode = parseOptionalHotkeyFromBox(weaveGlideToggleHotkeyBox, "Invalid weave glide hotkey.")
    antiWeaveToggleHotkeyCode = parseOptionalHotkeyFromBox(antiWeaveToggleHotkeyBox, "Invalid antiweave hotkey.")
    persistCombatToggleHotkeys()
end

activeHotkeyCaptureBox = nil
activeHotkeyCaptureApply = nil
activeHotkeyCapturePreviousText = nil

function beginHotkeyCapture(box, config)
    if not box then
        return
    end

    local options = config or {}
    box.ClearTextOnFocus = false

    box.Focused:Connect(function()
        if options.blocked and options.blocked() then
            task.defer(function()
                if box and box.Parent then
                    box:ReleaseFocus(false)
                end
            end)
            return
        end

        activeHotkeyCaptureBox = box
        activeHotkeyCaptureApply = options.onApply
        activeHotkeyCapturePreviousText = tostring(box.Text or "")
        box.Text = ""
        box.PlaceholderText = "Press a key..."
    end)

    box.FocusLost:Connect(function()
        if activeHotkeyCaptureBox == box then
            activeHotkeyCaptureBox = nil
            activeHotkeyCaptureApply = nil
        end

        if trimText(box.Text) == "" then
            box.Text = activeHotkeyCapturePreviousText or ""
        end
        activeHotkeyCapturePreviousText = nil

        if options.onCommit then
            options.onCommit()
        end

        box.PlaceholderText = options.placeholderText or "Enter hotkey..."
    end)
end

function rebuildFreeModeWhitelist()
    local combatPageNav = MainFrame and MainFrame:FindFirstChild("CombatPageNav", true) or nil
    freeModeWhitelist = {
        (freeModeHitboxToggleButton and freeModeHitboxToggleButton.Parent) or freeModeHitboxToggleButton,
        (freeModeShowHitboxVisualsToggleButton and freeModeShowHitboxVisualsToggleButton.Parent) or freeModeShowHitboxVisualsToggleButton,
        (freeModeHeadlessToggleButton and freeModeHeadlessToggleButton.Parent) or freeModeHeadlessToggleButton,
        hitboxSliderFrame,
        hitboxTextBox,
        hitboxTierPopup and hitboxTierPopup.Frame or nil,
        punchSliderFrame,
        punchTextBox,
        punchTierPopup and punchTierPopup.Frame or nil,
        Sidebar,
        settingsPnNav,
        settingsPnNavMainButton,
        settingsPnNavPatchButton,
        (mainUiTransparency and mainUiTransparency.frame) or nil,
        (mainUiTransparency and mainUiTransparency.bar) or nil,
        (mainUiTransparency and mainUiTransparency.fill) or nil,
        (mainUiTransparency and mainUiTransparency.label) or nil,
        (mainUiTransparency and mainUiTransparency.valueLabel) or nil,
        hitboxToggleHotkeyBox,
        hitboxToggleHotkeyLabel,
        combatPageNav,
        combatPage1Button,
        combatPage2Button,
        affectedPlayersBox,
    }

    if tabButtons then
        for _, button in pairs(tabButtons) do
            table.insert(freeModeWhitelist, button)
        end
    end
end

function freeModeIsAllowedInstance(instance)
    if instance:IsA("ScrollingFrame") then
        return true
    end

    for _, root in ipairs(freeModeWhitelist) do
        if root and (instance == root or instance:IsDescendantOf(root)) then
            return true
        end
    end
    return false
end

function freeModeHasAllowedDescendant(instance)
    for _, root in ipairs(freeModeWhitelist) do
        if root and root ~= instance then
            local ok, isDescendant = pcall(function()
                return root:IsDescendantOf(instance)
            end)
            if ok and isDescendant then
                return true
            end
        end
    end

    return false
end

function applyFreeModeVisualLock()
    if not MainFrame then
        return
    end

    rebuildFreeModeWhitelist()

    for _, obj in ipairs(MainFrame:GetDescendants()) do
        if not freeModeIsAllowedInstance(obj) then
            local hasAllowedDescendant = obj:IsA("GuiObject") and freeModeHasAllowedDescendant(obj)
            local state = freeModeOriginalState[obj]
            if not state then
                state = {}
                freeModeOriginalState[obj] = state

                if obj:IsA("GuiObject") then
                    state.BackgroundColor3 = obj.BackgroundColor3
                    state.BackgroundTransparency = obj.BackgroundTransparency
                    if not hasAllowedDescendant then
                        state.Active = obj.Active
                        local okInteractable, currentInteractable = pcall(function()
                            return obj.Interactable
                        end)
                        if okInteractable then
                            state.Interactable = currentInteractable
                        end
                    end
                end

                if obj:IsA("GuiButton") then
                    state.AutoButtonColor = obj.AutoButtonColor
                end
                if obj:IsA("TextBox") then
                    state.TextEditable = obj.TextEditable
                end
                if obj:IsA("ScrollingFrame") then
                    state.ScrollingEnabled = obj.ScrollingEnabled
                end
                if obj:IsA("TextLabel") or obj:IsA("TextButton") or obj:IsA("TextBox") then
                    state.TextColor3 = obj.TextColor3
                end
                if obj:IsA("ImageLabel") or obj:IsA("ImageButton") then
                    state.ImageColor3 = obj.ImageColor3
                end
                if obj:IsA("UIStroke") then
                    state.StrokeColor = obj.Color
                    state.StrokeTransparency = obj.Transparency
                end
            end

            if obj:IsA("GuiObject") then
                if not hasAllowedDescendant then
                    obj.Active = false
                    pcall(function()
                        obj.Interactable = false
                    end)
                    if not isFreeModeCreditsInstance(obj) and not isFreeModePatchNotesInstance(obj) and obj.BackgroundTransparency < 1 then
                        local n = string.lower(tostring(obj.Name or ""))
                        if obj:IsA("Frame") and n:find("underline", 1, true) then
                            obj.BackgroundColor3 = activeThemeSecondaryColor
                        elseif not isFreeModeTitleDecoration(obj) then
                            obj.BackgroundColor3 = freeModeGreyBackgroundColor
                        end
                    end
                end
            end
            if obj:IsA("GuiButton") then
                obj.Active = false
                pcall(function()
                    obj.Interactable = false
                end)
                obj.AutoButtonColor = false
            end
            if obj:IsA("TextBox") then
                obj.Active = false
                pcall(function()
                    obj.Interactable = false
                end)
                obj.TextEditable = false
            end
            if not isFreeModeCreditsInstance(obj) and not isFreeModePatchNotesInstance(obj) then
                if obj:IsA("TextLabel") then
                    if isSettingsHotkeysUiLabel(obj) then
                        obj.TextColor3 = Color3.fromRGB(255, 255, 255)
                    elseif not isFreeModeTitleLabel(obj) then
                        obj.TextColor3 = freeModeGreyTextColor
                    else
                        obj.TextColor3 = activeThemeTextColor
                    end
                elseif obj:IsA("TextButton") or obj:IsA("TextBox") then
                    obj.TextColor3 = freeModeGreyTextColor
                end
                if obj:IsA("ImageLabel") or obj:IsA("ImageButton") then
                    obj.ImageColor3 = freeModeGreyTextColor
                end
                if obj:IsA("UIStroke") then
                    obj.Color = freeModeGreyStrokeColor
                    obj.Transparency = 0.05
                end
            end
        end
    end

    enforceFreeModeToggleGreyVisuals()
    enforceFreeModeBlockedControlVisuals()
end

function clearFreeModeVisualLock()
    for obj, state in pairs(freeModeOriginalState) do
        if obj and obj.Parent and state then
            if obj:IsA("GuiObject") then
                if state.Active ~= nil then
                    obj.Active = state.Active
                end
                if state.Interactable ~= nil then
                    pcall(function()
                        obj.Interactable = state.Interactable
                    end)
                end
                if state.BackgroundColor3 ~= nil then
                    obj.BackgroundColor3 = state.BackgroundColor3
                end
                if state.BackgroundTransparency ~= nil then
                    obj.BackgroundTransparency = state.BackgroundTransparency
                end
            end

            if obj:IsA("GuiButton") and state.AutoButtonColor ~= nil then
                obj.AutoButtonColor = state.AutoButtonColor
            end
            if obj:IsA("TextBox") and state.TextEditable ~= nil then
                obj.TextEditable = state.TextEditable
            end
            if obj:IsA("ScrollingFrame") and state.ScrollingEnabled ~= nil then
                obj.ScrollingEnabled = state.ScrollingEnabled
            end
            if (obj:IsA("TextLabel") or obj:IsA("TextButton") or obj:IsA("TextBox")) and state.TextColor3 ~= nil then
                obj.TextColor3 = state.TextColor3
            end
            if (obj:IsA("ImageLabel") or obj:IsA("ImageButton")) and state.ImageColor3 ~= nil then
                obj.ImageColor3 = state.ImageColor3
            end
            if obj:IsA("UIStroke") then
                if state.StrokeColor ~= nil then
                    obj.Color = state.StrokeColor
                end
                if state.StrokeTransparency ~= nil then
                    obj.Transparency = state.StrokeTransparency
                end
            end
        end
    end

    freeModeOriginalState = setmetatable({}, {__mode = "k"})
end

function setFreeModeEnabled(enabled, announce)
    freeModeEnabled = enabled and true or false

    if freeModeEnabled then
        applyFreeModeVisualLock()
    else
        clearFreeModeVisualLock()
        if type(applyThemeColors) == "function" then
            applyThemeColors(mainColor, secondaryColor, textColor)
        end
    end

    if announce then
        showStatus(freeModeEnabled and "Free mode enabled: only Hitbox Toggle, Hitbox Size, Punch Speed." or "Free mode disabled.", false)
    end
end

if freeModeEnabled then
    setFreeModeEnabled(true, false)
end

