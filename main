applyUiCustomizationData = function(uiData)
    if type(uiData) ~= "table" then
        return
    end

    local function parseColor(snapshotColor, fallback)
        if type(snapshotColor) ~= "table" then
            return fallback
        end

        local r = tonumber(snapshotColor.R)
        local g = tonumber(snapshotColor.G)
        local b = tonumber(snapshotColor.B)
        if not r or not g or not b then
            return fallback
        end

        return Color3.fromRGB(math.clamp(r, 0, 255), math.clamp(g, 0, 255), math.clamp(b, 0, 255))
    end

    local loadedMain = parseColor(uiData.MainColor, activeThemeMainColor)
    local loadedSecondary = parseColor(uiData.SecondaryColor, activeThemeSecondaryColor)
    local loadedText = parseColor(uiData.TextColor, activeThemeTextColor)
    applyThemeColors(loadedMain, loadedSecondary, loadedText, nil, "preset")

    if uiData.MainUiTransparency ~= nil then
        local resolvedTransparency = tonumber(uiData.MainUiTransparency)
        if resolvedTransparency then
            setMainUiTransparency(resolvedTransparency)
        end
    end
end

