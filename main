        local combatPresetPendingName = nil

        local function setCombatPresetDialogMode(mode)
            combatPresetDialogMode = mode == "ui_confirm" and "ui_confirm" or "name"
            local isNameMode = combatPresetDialogMode == "name"

            combatPresetDialogTitle.Text = isNameMode and "Preset Name" or "Save UI Customizations?"
            combatPresetDialogNameBox.Visible = isNameMode
            combatPresetDialogBody.Visible = not isNameMode
            combatPresetDialogCancelButton.Text = isNameMode and "Cancel" or "No"
            combatPresetDialogConfirmButton.Text = isNameMode and "Next" or "Yes"

            if isNameMode then
                task.defer(function()
                    if combatPresetDialogNameBox and combatPresetDialogNameBox.Parent and combatPresetDialogOverlay.Visible then
                        combatPresetDialogNameBox:CaptureFocus()
                    end
                end)
            else
                pcall(function()
                    combatPresetDialogNameBox:ReleaseFocus()
                end)
            end
        end

        local function setCombatPresetDialogVisible(isVisible)
            combatPresetDialogOverlay.Visible = isVisible and true or false
            combatPresetDialog.Visible = isVisible and true or false

            if isVisible then
                setCombatPresetDialogMode("name")
                combatPresetDialogNameBox.Text = ""
            end
        end

        local function saveCombatPresetToSlot(slotIndex, presetName, includeUiCustomization)
            if not slotIndex or slotIndex < 1 or slotIndex > 10 then
                showStatus("Invalid preset slot.", true)
                return
            end

            if type(buildCombatShareSnapshot) ~= "function" then
                showStatus("Combat snapshot builder unavailable.", true)
                return
            end

            local snapshot = buildCombatShareSnapshot()
            if type(snapshot) ~= "table" then
                showStatus("Failed to capture current combat settings.", true)
                return
            end

            local slotName = trimPresetName(presetName)
            if slotName == "" then
                slotName = "Preset " .. tostring(slotIndex)
            end

            local slotData = {
                Name = slotName,
                Snapshot = snapshot,
            }

            if includeUiCustomization and presetUiSavePrompt and type(presetUiSavePrompt.buildUiCustomizationSnapshot) == "function" then
                slotData.UICustomization = presetUiSavePrompt.buildUiCustomizationSnapshot()
            end

            combatPresetSlots[slotIndex] = slotData

            local ok = persistCombatPresetSlots()
            if ok then
                refreshCombatPresetSlotButtons()
                showStatus("Saved " .. slotName .. " to slot " .. tostring(slotIndex) .. ".", false)
            else
                showStatus("Failed to save preset slot " .. tostring(slotIndex) .. ".", true)
            end
        end

        for i = 1, 10 do
            local rowY = 182 + ((i - 1) * 50)

            local loadButton = Instance.new("TextButton", combatPage2Scroll)
            loadButton.Size = UDim2.new(1, -132, 0, 34)
            loadButton.Position = UDim2.new(0, 10, 0, rowY)
            loadButton.Text = "Empty"
            loadButton.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
            loadButton.BackgroundTransparency = 0.12
            loadButton.TextColor3 = Color3.fromRGB(255, 255, 255)
            loadButton.Font = Enum.Font.Gotham
            loadButton.TextSize = 13
            loadButton.TextXAlignment = Enum.TextXAlignment.Center
            loadButton.BorderSizePixel = 0
            loadButton.AutoButtonColor = false
            Instance.new("UICorner", loadButton).CornerRadius = UDim.new(0, 8)
            local loadButtonStroke = Instance.new("UIStroke", loadButton)
            loadButtonStroke.Color = Color3.fromRGB(230, 50, 50)
            loadButtonStroke.Transparency = 0.1
            loadButtonStroke.Thickness = 1.2
            loadButtonStroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border

            local saveButton = Instance.new("TextButton", combatPage2Scroll)
            saveButton.Size = UDim2.new(0, 108, 0, 34)
            saveButton.Position = UDim2.new(1, -118, 0, rowY)
            saveButton.Text = "Overwrite"
            saveButton.BackgroundColor3 = Color3.fromRGB(230, 50, 50)
            saveButton.BackgroundTransparency = 0.04
            saveButton.TextColor3 = Color3.fromRGB(255, 255, 255)
            saveButton.Font = Enum.Font.GothamBold
            saveButton.TextSize = 12
            saveButton.BorderSizePixel = 0
            saveButton.AutoButtonColor = false
            Instance.new("UICorner", saveButton).CornerRadius = UDim.new(0, 8)
            local saveButtonStroke = Instance.new("UIStroke", saveButton)
            saveButtonStroke.Color = Color3.fromRGB(230, 50, 50)
            saveButtonStroke.Transparency = 0.08
            saveButtonStroke.Thickness = 1.2
            saveButtonStroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border

            attachPresetButtonFeedback(loadButton, 0.12)
            attachPresetButtonFeedback(saveButton, 0.12)

            combatPresetLoadButtons[i] = loadButton
            combatPresetLoadButtonStrokes[i] = loadButtonStroke
            combatPresetSaveButtons[i] = saveButton
            combatPresetSaveButtonStrokes[i] = saveButtonStroke

            connectButton(loadButton, function()
                local slot = combatPresetSlots[i]
                if not slot or type(slot.Snapshot) ~= "table" then
                    showStatus("Preset slot " .. tostring(i) .. " is empty.", true)
                    return
                end

                applySettingsData(slot.Snapshot, true)

                if slot.UICustomization and type(applyUiCustomizationData) == "function" then
                    applyUiCustomizationData(slot.UICustomization)
                end

                showStatus("Loaded combat preset " .. tostring(slot.Name or i) .. ".", false)
            end)

            connectButton(saveButton, function()
                if type(buildCombatShareSnapshot) ~= "function" then
                    showStatus("Combat snapshot builder unavailable.", true)
                    return
                end

                local snapshot = buildCombatShareSnapshot()
                if type(snapshot) ~= "table" then
                    showStatus("Failed to capture current combat settings.", true)
                    return
                end

                local existingSlot = combatPresetSlots[i]
                local slotName = trimPresetName(existingSlot and existingSlot.Name)
                if slotName == "" then
                    slotName = "Preset " .. tostring(i)
                end

                combatPresetSlots[i] = {
                    Name = slotName,
                    Snapshot = snapshot,
                    UICustomization = existingSlot and existingSlot.UICustomization or nil,
                }

                local ok = persistCombatPresetSlots()
                if ok then
                    refreshCombatPresetSlotButtons()
                    showStatus("Overwrote slot " .. tostring(i) .. ".", false)
                else
                    showStatus("Failed to overwrite slot " .. tostring(i) .. ".", true)
                end
            end)
        end

        connectButton(combatPresetCreateButton, function()
            local nextSlot = findFirstEmptyCombatPresetSlot()
            if not nextSlot then
                showStatus("All preset slots are full. Clear one or overwrite a slot.", true)
                return
            end

            combatPresetPendingSlot = nextSlot
            combatPresetPendingName = nil
            setCombatPresetDialogVisible(true)
        end)

        connectButton(combatPresetDialogConfirmButton, function()
            if combatPresetDialogMode == "name" then
                local resolvedName = trimPresetName(combatPresetDialogNameBox.Text)
                if resolvedName == "" then
                    showStatus("Enter a preset name first.", true)
                    return
                end

                combatPresetPendingName = resolvedName
                setCombatPresetDialogMode("ui_confirm")
                return
            end

            if combatPresetPendingSlot then
                saveCombatPresetToSlot(combatPresetPendingSlot, combatPresetPendingName, true)
            end
            combatPresetPendingSlot = nil
            combatPresetPendingName = nil
            setCombatPresetDialogVisible(false)
        end)

        connectButton(combatPresetDialogCancelButton, function()
            if combatPresetDialogMode == "ui_confirm" then
                if combatPresetPendingSlot then
                    saveCombatPresetToSlot(combatPresetPendingSlot, combatPresetPendingName, false)
                end
            end

            combatPresetPendingSlot = nil
            combatPresetPendingName = nil
            setCombatPresetDialogVisible(false)
        end)

        combatPresetDialogNameBox.FocusLost:Connect(function(enterPressed)
            if not enterPressed or not combatPresetDialogOverlay.Visible then
                return
            end
            if combatPresetDialogMode ~= "name" then
                return
            end

            local resolvedName = trimPresetName(combatPresetDialogNameBox.Text)
            if resolvedName == "" then
                showStatus("Enter a preset name first.", true)
                return
            end

            combatPresetPendingName = resolvedName
            setCombatPresetDialogMode("ui_confirm")
        end)

        connectButton(combatPresetClearAllButton, function()
            for i = 1, 10 do
                combatPresetSlots[i] = nil
            end

            local ok = persistCombatPresetSlots()
            if ok then
                refreshCombatPresetSlotButtons()
                showStatus("Cleared all combat preset slots.", false)
            else
                showStatus("Failed to clear combat preset slots.", true)
            end
        end)

        do
            local _, _, loadedSlots = loadCombatPresetSlots()
            for i = 1, 10 do
                combatPresetSlots[i] = loadedSlots[i]
            end
            refreshCombatPresetSlotButtons()
        end

        local pageNav = Instance.new("Frame", combatFrame)
        pageNav.Name = "CombatPageNav"
        pageNav.Size = UDim2.new(1, -20, 0, navHeight)
        pageNav.Position = UDim2.new(0, 10, 1, -navHeight)
        pageNav.BackgroundTransparency = 1
        pageNav.ZIndex = 20

        local function createPageButton(name, text, xOffset)
            local button = Instance.new("TextButton", pageNav)
            button.Name = name
            button.Size = UDim2.new(0, 34, 0, 24)
            button.AnchorPoint = Vector2.new(0.5, 0.5)
            button.Position = UDim2.new(0.5, xOffset, 0.5, 0)
            button.BackgroundColor3 = activeThemePanelColor
            button.BackgroundTransparency = 0.1
            button.BorderSizePixel = 0
            button.Font = Enum.Font.GothamBold
            button.TextSize = 14
            button.Text = text
            button.TextColor3 = activeThemeTextColor
            button.ZIndex = 21
            Instance.new("UICorner", button).CornerRadius = UDim.new(0, 8)
            return button
        end

        combatPage1Button = createPageButton("Page1Button", "1", -20)
        combatPage2Button = createPageButton("Page2Button", "2", 20)

        combatActivePageIndex = 1
        local pageSwitchBusy = false

        updateCombatPageButtonState = function()
            if not combatPage1Button or not combatPage2Button then
                return
            end

            combatPage1Button.TextColor3 = activeThemeTextColor
            combatPage2Button.TextColor3 = activeThemeTextColor
            combatPage1Button.BackgroundColor3 = (combatActivePageIndex == 1) and activeThemeSecondaryColor or activeThemePanelColor
            combatPage1Button.BackgroundTransparency = (combatActivePageIndex == 1) and 0.03 or 0.1
            combatPage2Button.BackgroundColor3 = (combatActivePageIndex == 2) and activeThemeSecondaryColor or activeThemePanelColor
            combatPage2Button.BackgroundTransparency = (combatActivePageIndex == 2) and 0.03 or 0.1
        end

        local function switchCombatPage(targetPage)
            if pageSwitchBusy or targetPage == combatActivePageIndex then
                return
            end

            pageSwitchBusy = true
            local previousPage = combatActivePageIndex
            combatActivePageIndex = targetPage
            updateCombatPageButtonState()

            if targetPage == 2 then
                combatPage2.Visible = true
                combatPage2.Position = UDim2.new(1, 0, 0, 0)

                playTween(combatPage1, TweenInfo.new(0.22, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
                    Position = UDim2.new(-1, 0, 0, 0),
                })
                playTween(combatPage2, TweenInfo.new(0.22, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
                    Position = UDim2.new(0, 0, 0, 0),
                })
            else
                combatPage1.Visible = true
                combatPage1.Position = UDim2.new(-1, 0, 0, 0)

                playTween(combatPage2, TweenInfo.new(0.22, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
                    Position = UDim2.new(1, 0, 0, 0),
                })
                playTween(combatPage1, TweenInfo.new(0.22, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
                    Position = UDim2.new(0, 0, 0, 0),
                })
            end

            task.delay(0.24, function()
                if combatActivePageIndex == 1 then
                    combatPage2.Visible = false
                else
                    combatPage1.Visible = false
                end
                pageSwitchBusy = false
            end)
        end

        connectButton(combatPage1Button, function()
            switchCombatPage(1)
        end)

        connectButton(combatPage2Button, function()
            switchCombatPage(2)
        end)

        if combatPage1 then
            combatPage1.Visible = true
            combatPage1.Position = UDim2.new(0, 0, 0, 0)
        end
        updateCombatPage1Canvas()
        updateCombatPageButtonState()
    end
end)

