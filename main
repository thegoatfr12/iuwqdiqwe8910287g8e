        mainUiTransparency.bar.InputBegan:Connect(function(inp)
            if freeModeShouldBlockControl(mainUiTransparency.bar, true) then
                return
            end

            if inp.UserInputType == Enum.UserInputType.MouseButton1 then
                mainUiTransparency.dragging = true
                setMainUiTransparency(mainUiTransparencyPosToValue(inp.Position.X))
            end
        end)

        mainUiTransparency.bar.InputEnded:Connect(function(inp)
            if inp.UserInputType == Enum.UserInputType.MouseButton1 then
                mainUiTransparency.dragging = false
            end
        end)

        UserInputService.InputChanged:Connect(function(inp)
            if mainUiTransparency.dragging and inp.UserInputType == Enum.UserInputType.MouseMovement then
                setMainUiTransparency(mainUiTransparencyPosToValue(inp.Position.X))
            end
        end)

        setMainUiTransparency(currentMainUiTransparency)
    end)

    if not okMainUiTransparencyInit then
        warn("[ToeBootstrap] Main transparency slider init failed: " .. tostring(initErr))
        mainUiTransparency.dragging = false
    end
end

