local function setHitboxColorDropdownOpen(isOpen)
    if hitboxColorDropdownAnimating then
        return
    end

    if hitboxColorDropdownOpen == isOpen then
        return
    end

    hitboxColorDropdownOpen = isOpen
    hitboxColorDropdownAnimating = true

    if isOpen then
        hitboxColorDropdownFrame.Visible = true
    end

    local targetHeight = isOpen and (#hitboxColorDropdownOptions * 26) or 0
    playTween(
        hitboxColorDropdownFrame,
        TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
        {
            Size = UDim2.new(0, 140, 0, targetHeight),
            BackgroundTransparency = isOpen and AUTH_SURFACE_GLASS_TRANSPARENCY or 1,
        }
    )

    task.delay(0.22, function()
        hitboxColorDropdownAnimating = false
        if not hitboxColorDropdownOpen then
            hitboxColorDropdownFrame.Visible = false
        end
    end)
end

for index, option in ipairs(hitboxColorDropdownOptions) do
    local optionButton = Instance.new("TextButton", hitboxColorDropdownFrame)
    optionButton.Size = UDim2.new(1, -8, 0, 24)
