mainFrameRestPosition = MainFrame.Position
mainFrameExpandedPosition = MainFrame.Position
mainFrameExpandedSize = MainFrame.Size
mainUiCollapsed = false
mainUiCollapseBusy = false
mainFrameCollapseButton = nil
mainFrameMinimizedTab = nil
mainFrameMinimizedTabStroke = nil
mainFrameClipBeforeCollapse = MainFrame.ClipsDescendants
mainMinTabDragInput = nil
mainMinTabDragStart = nil
mainMinTabStartPos = nil
mainMinTabMoved = false
mainMinTabDragging = false
mainMinTabDragIsTouch = false

MINIMIZED_MAIN_TAB_WIDTH = 220
MINIMIZED_MAIN_TAB_HEIGHT = 34
MINIMIZED_MAIN_TAB_DRAG_THRESHOLD = 6

function collapseMainUi()
    if mainUiCollapseBusy or mainUiCollapsed or not MainFrame or not MainFrame.Visible then
        return
    end

    mainUiCollapseBusy = true
    mainFrameExpandedPosition = MainFrame.Position
    mainFrameExpandedSize = MainFrame.Size
    mainFrameRestPosition = MainFrame.Position
    mainFrameClipBeforeCollapse = MainFrame.ClipsDescendants
    MainFrame.ClipsDescendants = true

    local collapsedXOffset = mainFrameExpandedPosition.X.Offset + math.max((mainFrameExpandedSize.X.Offset or 0) - MINIMIZED_MAIN_TAB_WIDTH, 0)
    local collapsedPosition = UDim2.new(
        mainFrameExpandedPosition.X.Scale,
        collapsedXOffset,
        mainFrameExpandedPosition.Y.Scale,
        mainFrameExpandedPosition.Y.Offset
    )

    if mainFrameMinimizedTab then
        mainFrameMinimizedTab.Size = UDim2.new(0, MINIMIZED_MAIN_TAB_WIDTH, 0, MINIMIZED_MAIN_TAB_HEIGHT)
        mainFrameMinimizedTab.Position = collapsedPosition
        mainFrameMinimizedTab.TextTransparency = 1
        mainFrameMinimizedTab.BackgroundTransparency = 0.28
        mainFrameMinimizedTab.Visible = true
    end

    local collapseTween = playTween(
        MainFrame,
        TweenInfo.new(0.24, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
        {
            Size = UDim2.new(0, MINIMIZED_MAIN_TAB_WIDTH, 0, MINIMIZED_MAIN_TAB_HEIGHT),
            Position = collapsedPosition,
            BackgroundTransparency = math.min(currentMainUiTransparency + 0.2, 0.92),
        }
    )

    if collapseTween then
        collapseTween.Completed:Wait()
    else
        task.wait(0.24)
    end

    MainFrame.Visible = false
    if mainFrameMinimizedTab then
        playTween(
            mainFrameMinimizedTab,
            TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
            {
                BackgroundTransparency = 0.08,
                TextTransparency = 0,
            }
        )
    end

    mainUiCollapsed = true
    mainUiCollapseBusy = false
end

function expandMainUi()
    if mainUiCollapseBusy or not mainUiCollapsed or not MainFrame then
        return
    end

    mainUiCollapseBusy = true

    local startPosition = mainFrameExpandedPosition
    local startSize = UDim2.new(0, MINIMIZED_MAIN_TAB_WIDTH, 0, MINIMIZED_MAIN_TAB_HEIGHT)
    local targetPosition = mainFrameExpandedPosition
    if mainFrameMinimizedTab then
        startPosition = mainFrameMinimizedTab.Position
        startSize = mainFrameMinimizedTab.Size

        local expandedXOffset = startPosition.X.Offset - math.max((mainFrameExpandedSize.X.Offset or MAIN_FRAME_WIDTH) - MINIMIZED_MAIN_TAB_WIDTH, 0)
        targetPosition = UDim2.new(
            startPosition.X.Scale,
            expandedXOffset,
            startPosition.Y.Scale,
            startPosition.Y.Offset
        )

        mainFrameMinimizedTab.Visible = false
    end

    MainFrame.Visible = true
    MainFrame.Position = startPosition
    MainFrame.Size = startSize
    MainFrame.BackgroundTransparency = math.min(currentMainUiTransparency + 0.2, 0.92)

    local expandTween = playTween(
        MainFrame,
        TweenInfo.new(0.26, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
        {
            Position = targetPosition,
            Size = mainFrameExpandedSize,
            BackgroundTransparency = currentMainUiTransparency,
        }
    )

    if expandTween then
        expandTween.Completed:Wait()
    else
        task.wait(0.26)
    end

    mainFrameExpandedPosition = targetPosition
    mainFrameRestPosition = targetPosition
    MainFrame.ClipsDescendants = mainFrameClipBeforeCollapse
    mainUiCollapsed = false
    mainUiCollapseBusy = false
end

mainFrameMinimizedTab = Instance.new("TextButton")
mainFrameMinimizedTab.Name = "MainFrameMinimizedTab"
mainFrameMinimizedTab.Size = UDim2.new(0, MINIMIZED_MAIN_TAB_WIDTH, 0, MINIMIZED_MAIN_TAB_HEIGHT)
mainFrameMinimizedTab.Position = mainFrameExpandedPosition
mainFrameMinimizedTab.BackgroundColor3 = MainFrame.BackgroundColor3
mainFrameMinimizedTab.BackgroundTransparency = 0.08
mainFrameMinimizedTab.BorderSizePixel = 0
mainFrameMinimizedTab.Text = "THE END OF EVERYTHING"
mainFrameMinimizedTab.TextColor3 = Color3.fromRGB(245, 245, 245)
mainFrameMinimizedTab.TextSize = 12
mainFrameMinimizedTab.Font = Enum.Font.GothamBold
mainFrameMinimizedTab.Active = true
mainFrameMinimizedTab.Visible = false
mainFrameMinimizedTab.ZIndex = 22
mainFrameMinimizedTab.Parent = ScreenGui
Instance.new("UICorner", mainFrameMinimizedTab).CornerRadius = UDim.new(0, 8)

mainFrameMinimizedTabStroke = Instance.new("UIStroke")
mainFrameMinimizedTabStroke.Color = Color3.fromRGB(230, 50, 50)
mainFrameMinimizedTabStroke.Thickness = 1.35
mainFrameMinimizedTabStroke.Transparency = 0.02
mainFrameMinimizedTabStroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
mainFrameMinimizedTabStroke.Parent = mainFrameMinimizedTab

mainFrameMinimizedTab.InputBegan:Connect(function(input)
    if input.UserInputType ~= Enum.UserInputType.MouseButton1 and input.UserInputType ~= Enum.UserInputType.Touch then
        return
    end

    mainMinTabDragging = true
    mainMinTabDragIsTouch = input.UserInputType == Enum.UserInputType.Touch
    mainMinTabDragInput = mainMinTabDragIsTouch and input or nil
    mainMinTabDragStart = input.Position
    mainMinTabStartPos = mainFrameMinimizedTab.Position
    mainMinTabMoved = false
end)

mainFrameMinimizedTab.InputEnded:Connect(function(input)
    if not mainMinTabDragging then
        return
    end

    if mainMinTabDragIsTouch then
        if mainMinTabDragInput ~= input then
            return
        end
    elseif input.UserInputType ~= Enum.UserInputType.MouseButton1 then
        return
    end

    mainMinTabDragging = false
    mainMinTabDragIsTouch = false
    mainMinTabDragInput = nil
    mainMinTabDragStart = nil
    mainMinTabStartPos = nil

    if mainMinTabMoved then
        local tabPos = mainFrameMinimizedTab.Position
        local expandedXOffset = tabPos.X.Offset - math.max((mainFrameExpandedSize.X.Offset or MAIN_FRAME_WIDTH) - MINIMIZED_MAIN_TAB_WIDTH, 0)
        mainFrameExpandedPosition = UDim2.new(
            tabPos.X.Scale,
            expandedXOffset,
            tabPos.Y.Scale,
            tabPos.Y.Offset
        )
        mainFrameRestPosition = mainFrameExpandedPosition
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if not mainMinTabDragging or not mainMinTabDragStart or not mainMinTabStartPos then
        return
    end

    if mainMinTabDragIsTouch then
        if input.UserInputType ~= Enum.UserInputType.Touch or input ~= mainMinTabDragInput then
            return
        end
    elseif input.UserInputType ~= Enum.UserInputType.MouseMovement then
        return
    end

    local delta = input.Position - mainMinTabDragStart
    if not mainMinTabMoved and delta.Magnitude >= MINIMIZED_MAIN_TAB_DRAG_THRESHOLD then
        mainMinTabMoved = true
    end

    mainFrameMinimizedTab.Position = UDim2.new(
        mainMinTabStartPos.X.Scale,
        math.floor(mainMinTabStartPos.X.Offset + delta.X),
        mainMinTabStartPos.Y.Scale,
        math.floor(mainMinTabStartPos.Y.Offset + delta.Y)
    )
end)

UserInputService.InputEnded:Connect(function(input)
    if not mainMinTabDragging then
        return
    end

    if mainMinTabDragIsTouch then
        if mainMinTabDragInput ~= input then
            return
        end
    elseif input.UserInputType ~= Enum.UserInputType.MouseButton1 then
        return
    end

    mainMinTabDragging = false
    mainMinTabDragIsTouch = false
    mainMinTabDragInput = nil
    mainMinTabDragStart = nil
    mainMinTabStartPos = nil

    if mainMinTabMoved then
        local tabPos = mainFrameMinimizedTab.Position
        local expandedXOffset = tabPos.X.Offset - math.max((mainFrameExpandedSize.X.Offset or MAIN_FRAME_WIDTH) - MINIMIZED_MAIN_TAB_WIDTH, 0)
        mainFrameExpandedPosition = UDim2.new(
            tabPos.X.Scale,
            expandedXOffset,
            tabPos.Y.Scale,
            tabPos.Y.Offset
        )
        mainFrameRestPosition = mainFrameExpandedPosition
    end
end)

connectButton(mainFrameMinimizedTab, function()
    if scriptUnloaded or not isAuthorized then
        return
    end
    if mainMinTabMoved then
        mainMinTabMoved = false
        return
    end
    expandMainUi()
end)

