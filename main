if isMobileClient then
    applyMobileTextAndLineSizing()
    task.defer(function()
        if scriptUnloaded then
            return
        end
        applyMobileTextAndLineSizing()
    end)

    local mobileCamera = Workspace.CurrentCamera
    if mobileCamera then
        mobileCamera:GetPropertyChangedSignal("ViewportSize"):Connect(function()
            if scriptUnloaded then
                return
            end
            applyMobileTextAndLineSizing()
        end)
    end

    Workspace:GetPropertyChangedSignal("CurrentCamera"):Connect(function()
        if scriptUnloaded then
            return
        end

        local nextCamera = Workspace.CurrentCamera
        if nextCamera then
            nextCamera:GetPropertyChangedSignal("ViewportSize"):Connect(function()
                if scriptUnloaded then
                    return
                end
                applyMobileTextAndLineSizing()
            end)
        end

        applyMobileTextAndLineSizing()
    end)

    MainFrame.DescendantAdded:Connect(function(added)
        if scriptUnloaded then
            return
        end
        if not added then
            return
        end
        if added:IsA("TextLabel") or added:IsA("TextButton") or added:IsA("TextBox") or added:IsA("Frame") then
            task.defer(function()
                if scriptUnloaded then
                    return
                end
                applyMobileTextAndLineSizing()
            end)
        end
    end)
end

connectButton(mainFrameCollapseButton, function()
    if scriptUnloaded or not isAuthorized then
        return
    end
    collapseMainUi()
end)

mainFrameDragDisabled = false
mainDragInput = nil
mainDragStart = nil
mainDragFrameStart = nil
mainDragging = false
mainDragIsTouch = false

function stopMainFrameDrag()
    mainDragging = false
    mainDragIsTouch = false
    mainDragInput = nil
    mainDragStart = nil
    mainDragFrameStart = nil
end

dragBar.InputBegan:Connect(function(input)
    if mainFrameDragDisabled then
        return
    end

    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        mainDragging = true
        mainDragIsTouch = input.UserInputType == Enum.UserInputType.Touch
        mainDragInput = mainDragIsTouch and input or nil
        mainDragStart = input.Position
        mainDragFrameStart = MainFrame.Position
    end
end)

dragBar.InputEnded:Connect(function(input)
    if not mainDragging then
        return
    end

    if mainDragIsTouch then
        if input.UserInputType ~= Enum.UserInputType.Touch then
            return
        end
    elseif input.UserInputType ~= Enum.UserInputType.MouseButton1 then
        return
    end

    stopMainFrameDrag()
end)

UserInputService.InputChanged:Connect(function(input)
    if not mainDragging or not mainDragStart or not mainDragFrameStart then
        return
    end

    if mainDragIsTouch then
        if input.UserInputType ~= Enum.UserInputType.Touch then
            return
        end
    elseif input.UserInputType ~= Enum.UserInputType.MouseMovement then
        return
    end

    local delta = input.Position - mainDragStart
    local targetXOffset = math.floor(mainDragFrameStart.X.Offset + delta.X)
    local targetYOffset = math.floor(mainDragFrameStart.Y.Offset + delta.Y)

    if isMobileClient then
        local viewport = Workspace.CurrentCamera and Workspace.CurrentCamera.ViewportSize
        local frameSize = MainFrame.AbsoluteSize
        if viewport and frameSize.X > 0 and frameSize.Y > 0 then
            local minX = -math.floor(frameSize.X * 0.35)
            local maxX = math.floor(viewport.X - frameSize.X * 0.65)
            local minY = 0
            local maxY = math.floor(viewport.Y - math.max(frameSize.Y, 120))
            targetXOffset = math.clamp(targetXOffset, minX, maxX)
            targetYOffset = math.clamp(targetYOffset, minY, maxY)
        end
    end

    MainFrame.Position = UDim2.new(
        mainDragFrameStart.X.Scale,
        targetXOffset,
        mainDragFrameStart.Y.Scale,
        targetYOffset
    )
end)

UserInputService.InputEnded:Connect(function(input)
    if not mainDragging then
        return
    end

    if mainDragIsTouch then
        if input.UserInputType ~= Enum.UserInputType.Touch then
            return
        end
    elseif input.UserInputType ~= Enum.UserInputType.MouseButton1 then
        return
    end

    stopMainFrameDrag()
end)

-- Disable dragging when interacting with sliders
function disableDragging()
    mainFrameDragDisabled = true
    stopMainFrameDrag()
    MainFrame.Active = true
    MainFrame.Draggable = false
end
function enableDragging()
    mainFrameDragDisabled = false
    MainFrame.Active = true
    MainFrame.Draggable = false
end

