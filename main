        legacyBlur.Enabled = false
        legacyBlur.Size = 0
    end
end

updateBootstrapStatus("Boot: theme initialized", false)


local punchDragging = false
stompSlider.Dragging = false

local function punchPosToValue(px)
    local absX = punchSliderBar.AbsolutePosition.X
    local w = punchSliderBar.AbsoluteSize.X
    local rel = math.clamp((px - absX) / math.max(w, 1), 0, 1)
    local raw = PUNCH_MIN + (PUNCH_MAX - PUNCH_MIN) * rel
    return math.clamp(math.floor(raw * 100) / 100, PUNCH_MIN, PUNCH_MAX)
end

local function getPunchTierLabelAndColor(value)
    if value <= 1.86 then
        return "Legit", Color3.fromRGB(90, 220, 120)
    elseif value <= 2.1 then
        return "dangerous", Color3.fromRGB(255, 174, 84)
    end
    return "blatant", Color3.fromRGB(255, 92, 92)
end

local function hidePunchTierPopup(delayTime)
    if not punchTierPopup or not punchTierPopup.Frame or not punchTierPopup.Label then
        return
    end

    punchTierPopup.HideToken = (punchTierPopup.HideToken or 0) + 1
    local token = punchTierPopup.HideToken

    task.delay(delayTime or 0, function()
        if not punchTierPopup or token ~= punchTierPopup.HideToken or not punchTierPopup.IsVisible then
            return
        end

        local _, _, exitPos = getTierPopupPositionsForSlider(punchSliderBar, punchTierPopup.Frame, -25, 8, 6, 0)

        playTween(
            punchTierPopup.Frame,
            TweenInfo.new(0.14, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
            {
                Position = exitPos,
                BackgroundTransparency = 1,
            }
        )
        playTween(
            punchTierPopup.Label,
            TweenInfo.new(0.14, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
            {
                TextTransparency = 1,
            }
        )

        task.delay(0.15, function()
            if punchTierPopup and token == punchTierPopup.HideToken and punchTierPopup.Frame then
                punchTierPopup.Frame.Visible = false
                punchTierPopup.IsVisible = false
            end
        end)
    end)
end

local function showPunchTierPopup(value, holdOpen)
    if not punchTierPopup or not punchTierPopup.Frame or not punchTierPopup.Label then
        return
    end

    local tierText, tierColor = getPunchTierLabelAndColor(value)
    local sameTier = punchTierPopup.CurrentTier == tierText
    punchTierPopup.CurrentTier = tierText
    punchTierPopup.HideToken = (punchTierPopup.HideToken or 0) + 1

    punchTierPopup.Label.Text = tierText
    punchTierPopup.Label.TextColor3 = tierColor

    if not punchTierPopup.IsVisible then
        local enterPos, shownPos = getTierPopupPositionsForSlider(punchSliderBar, punchTierPopup.Frame, -25, 8, 6, 0)
        punchTierPopup.Frame.Visible = true
        punchTierPopup.Frame.Position = enterPos
        punchTierPopup.Frame.BackgroundTransparency = 1
        punchTierPopup.Label.TextTransparency = 1

        playTween(
            punchTierPopup.Frame,
            TweenInfo.new(0.12, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
            {
                Position = shownPos,
                BackgroundTransparency = 0.14,
            }
        )
        playTween(
            punchTierPopup.Label,
            TweenInfo.new(0.12, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
            {
                TextTransparency = 0,
            }
        )
        punchTierPopup.IsVisible = true
    elseif not sameTier then
        local _, shownPos = getTierPopupPositionsForSlider(punchSliderBar, punchTierPopup.Frame, -25, 8, 6, 0)
        punchTierPopup.Frame.Position = shownPos
        punchTierPopup.Frame.BackgroundTransparency = 0.14
        punchTierPopup.Label.TextTransparency = 0
    end

    if not holdOpen then
        hidePunchTierPopup(0.5)
    end
end

local animationSpeedConn
local animatorSpeedConn
function isPunchAnimationTrack(track)
    if not track or not track.Animation then
        return false
    end

    local normalizedId = tostring(track.Animation.AnimationId):lower()
    if punchIDs[normalizedId] then
        return true
    end

    local trackName = tostring(track.Name or ""):lower()
    local animationName = tostring(track.Animation.Name or ""):lower()
    return trackName:find("punch", 1, true) ~= nil or animationName:find("punch", 1, true) ~= nil
end

local function getAnimationSpeed(track)
    if not track or not track.Animation then
        return nil
    end

    local normalizedId = tostring(track.Animation.AnimationId):lower()
    if punchIDs[normalizedId] then
        return currentPunchSpeed
    end

    if stompIDs[normalizedId] then
        return currentStompSpeed
    end

    local trackName = tostring(track.Name or ""):lower()
    local animationName = tostring(track.Animation.Name or ""):lower()
    if trackName:find("stomp", 1, true) or animationName:find("stomp", 1, true) then
        return currentStompSpeed
    end

    return nil
end

local function applyTrackSpeed(track)
    if scriptUnloaded then
        return
    end

    if not track or not track.Animation then return end
    local speed = getAnimationSpeed(track)
    if speed then
        pcall(function() track:AdjustSpeed(speed) end)
    end
end

applyAttackSpeedToLocalLive = function()
    if scriptUnloaded then
        if animationSpeedConn then
            animationSpeedConn:Disconnect()
            animationSpeedConn = nil
        end
        if animatorSpeedConn then
            animatorSpeedConn:Disconnect()
            animatorSpeedConn = nil
        end
        return
    end

    local live = workspace:FindFirstChild("Live")
    if not live then return end
    local myModel = live:FindFirstChild(player.Name)
    if not myModel or not myModel.Parent then return end
    local hum = myModel:FindFirstChildOfClass("Humanoid")
    if not hum then return end
    local animator = hum:FindFirstChildOfClass("Animator")

    for _, track in ipairs(hum:GetPlayingAnimationTracks()) do
        applyTrackSpeed(track)
    end

    if animationSpeedConn then
        animationSpeedConn:Disconnect()
        animationSpeedConn = nil
    end

    if animatorSpeedConn then
        animatorSpeedConn:Disconnect()
        animatorSpeedConn = nil
    end

    animationSpeedConn = hum.AnimationPlayed:Connect(function(track)
        if isPunchAnimationTrack(track) then
            refreshNoBounceModeWindow()
        end
        applyTrackSpeed(track)
    end)

    if animator then
        animatorSpeedConn = animator.ChildAdded:Connect(function(child)
            if child:IsA("AnimationTrack") then
                if isPunchAnimationTrack(child) then
                    refreshNoBounceModeWindow()
                end
                applyTrackSpeed(child)
            end
        end)
    end
end

punchSliderBar.InputBegan:Connect(function(inp)
    if inp.UserInputType == Enum.UserInputType.MouseButton1 then
        punchDragging = true
        local v = punchPosToValue(inp.Position.X)
        local rel = (v - PUNCH_MIN) / (PUNCH_MAX - PUNCH_MIN)
        punchSliderFill.Size = UDim2.new(rel, 0, 1, 0)
        punchValueLabel.Text = tostring(v)
        punchTextBox.Text = tostring(v)
        currentPunchSpeed = v
        showPunchTierPopup(v, true)
        applyAttackSpeedToLocalLive()
    end
end)
punchSliderBar.InputEnded:Connect(function(inp)
    if inp.UserInputType == Enum.UserInputType.MouseButton1 then
        punchDragging = false
        hidePunchTierPopup(0.12)
    end
end)
UserInputService.InputChanged:Connect(function(inp)
    if punchDragging and inp.UserInputType == Enum.UserInputType.MouseMovement then
        local v = punchPosToValue(inp.Position.X)
        local rel = (v - PUNCH_MIN) / (PUNCH_MAX - PUNCH_MIN)
        punchSliderFill.Size = UDim2.new(rel, 0, 1, 0)
        punchValueLabel.Text = tostring(v)
        punchTextBox.Text = tostring(v)
        currentPunchSpeed = v
        showPunchTierPopup(v, true)
        applyAttackSpeedToLocalLive()
    end
end)
UserInputService.InputEnded:Connect(function(inp)
    if punchDragging and inp.UserInputType == Enum.UserInputType.MouseButton1 then
        punchDragging = false
        hidePunchTierPopup(0.12)
    end
end)

punchTextBox.FocusLost:Connect(function()
    local v = tonumber(punchTextBox.Text)
    if v then
        v = math.clamp(math.floor(v * 100) / 100, PUNCH_MIN, PUNCH_MAX)
        currentPunchSpeed = v
        punchValueLabel.Text = tostring(v)
        local rel = (v - PUNCH_MIN) / (PUNCH_MAX - PUNCH_MIN)
        punchSliderFill.Size = UDim2.new(rel, 0, 1, 0)
        punchTextBox.Text = tostring(v)
        applyAttackSpeedToLocalLive()
    else
        punchTextBox.Text = tostring(currentPunchSpeed)
    end
end)

local function getStompTierLabelAndColor(value)
    if value <= 1.2 then
        return "Legit", Color3.fromRGB(90, 220, 120)
    elseif value < 1.5 then
        return "dangerous", Color3.fromRGB(255, 174, 84)
    end
    return "blatant", Color3.fromRGB(255, 92, 92)
end

local function hideStompTierPopup(delayTime)
    if not stompTierPopup or not stompTierPopup.Frame or not stompTierPopup.Label then
        return
    end

    stompTierPopup.HideToken = (stompTierPopup.HideToken or 0) + 1
    local token = stompTierPopup.HideToken

    task.delay(delayTime or 0, function()
        if not stompTierPopup or token ~= stompTierPopup.HideToken or not stompTierPopup.IsVisible then
            return
        end

        local _, _, exitPos = getTierPopupPositionsForSlider(stompSlider.Bar, stompTierPopup.Frame, -25, 8, 6, 0)

        playTween(
            stompTierPopup.Frame,
            TweenInfo.new(0.14, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
            {
                Position = exitPos,
                BackgroundTransparency = 1,
            }
        )
        playTween(
            stompTierPopup.Label,
            TweenInfo.new(0.14, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
            {
                TextTransparency = 1,
            }
        )

        task.delay(0.15, function()
            if stompTierPopup and token == stompTierPopup.HideToken and stompTierPopup.Frame then
                stompTierPopup.Frame.Visible = false
                stompTierPopup.IsVisible = false
            end
        end)
    end)
end

local function showStompTierPopup(value, holdOpen)
    if not stompTierPopup or not stompTierPopup.Frame or not stompTierPopup.Label then
        return
    end

    local tierText, tierColor = getStompTierLabelAndColor(value)
    local sameTier = stompTierPopup.CurrentTier == tierText
    stompTierPopup.CurrentTier = tierText
    stompTierPopup.HideToken = (stompTierPopup.HideToken or 0) + 1

    stompTierPopup.Label.Text = tierText
    stompTierPopup.Label.TextColor3 = tierColor

    if not stompTierPopup.IsVisible then
        local enterPos, shownPos = getTierPopupPositionsForSlider(stompSlider.Bar, stompTierPopup.Frame, -25, 8, 6, 0)
        stompTierPopup.Frame.Visible = true
        stompTierPopup.Frame.Position = enterPos
        stompTierPopup.Frame.BackgroundTransparency = 1
        stompTierPopup.Label.TextTransparency = 1

        playTween(
            stompTierPopup.Frame,
            TweenInfo.new(0.12, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
            {
                Position = shownPos,
                BackgroundTransparency = 0.14,
            }
        )
        playTween(
            stompTierPopup.Label,
            TweenInfo.new(0.12, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
            {
                TextTransparency = 0,
            }
        )
        stompTierPopup.IsVisible = true
    elseif not sameTier then
        local _, shownPos = getTierPopupPositionsForSlider(stompSlider.Bar, stompTierPopup.Frame, -25, 8, 6, 0)
        stompTierPopup.Frame.Position = shownPos
        stompTierPopup.Frame.BackgroundTransparency = 0.14
        stompTierPopup.Label.TextTransparency = 0
    end

    if not holdOpen then
        hideStompTierPopup(0.5)
    end
end

stompSlider.Bar.InputBegan:Connect(function(inp)
    if freeModeShouldBlockControl(stompSlider.Bar, true) then
        return
    end

    if inp.UserInputType == Enum.UserInputType.MouseButton1 then
        stompSlider.Dragging = true
        local v = stompPosToValue(inp.Position.X)
        local rel = (v - STOMP_MIN) / (STOMP_MAX - STOMP_MIN)
        stompSlider.Fill.Size = UDim2.new(rel, 0, 1, 0)
        stompSlider.ValueLabel.Text = tostring(v)
        stompSlider.TextBox.Text = tostring(v)
        currentStompSpeed = v
        showStompTierPopup(v, true)
        applyAttackSpeedToLocalLive()
    end
end)
stompSlider.Bar.InputEnded:Connect(function(inp)
    if inp.UserInputType == Enum.UserInputType.MouseButton1 then
        stompSlider.Dragging = false
        hideStompTierPopup(0.12)
    end
end)
UserInputService.InputChanged:Connect(function(inp)
    if stompSlider.Dragging and inp.UserInputType == Enum.UserInputType.MouseMovement then
        local v = stompPosToValue(inp.Position.X)
        local rel = (v - STOMP_MIN) / (STOMP_MAX - STOMP_MIN)
        stompSlider.Fill.Size = UDim2.new(rel, 0, 1, 0)
        stompSlider.ValueLabel.Text = tostring(v)
        stompSlider.TextBox.Text = tostring(v)
        currentStompSpeed = v
        showStompTierPopup(v, true)
        applyAttackSpeedToLocalLive()
    end
end)
UserInputService.InputEnded:Connect(function(inp)
    if stompSlider.Dragging and inp.UserInputType == Enum.UserInputType.MouseButton1 then
        stompSlider.Dragging = false
        hideStompTierPopup(0.12)
    end
end)

stompSlider.TextBox.FocusLost:Connect(function()
    if freeModeShouldBlockControl(stompSlider.TextBox, true) then
        stompSlider.TextBox.Text = tostring(currentStompSpeed)
        return
    end

    local v = tonumber(stompSlider.TextBox.Text)
    if v then
        v = math.clamp(math.floor(v * 100) / 100, STOMP_MIN, STOMP_MAX)
        currentStompSpeed = v
        stompSlider.ValueLabel.Text = tostring(v)
        local rel = (v - STOMP_MIN) / (STOMP_MAX - STOMP_MIN)
        stompSlider.Fill.Size = UDim2.new(rel, 0, 1, 0)
        stompSlider.TextBox.Text = tostring(v)
        applyAttackSpeedToLocalLive()
    else
        stompSlider.TextBox.Text = tostring(currentStompSpeed)
    end
end)

-- Helper to parse and clamp punch speed

-- Robust punch speed logic after respawn
local function robustPunchSpeedReconnect()
    local function waitForLiveAndPlayer()
        local live
        repeat
            live = workspace:FindFirstChild("Live")
            task.wait(0.1)
        until live
        local myModel
        repeat
            myModel = live:FindFirstChild(player.Name)
            task.wait(0.1)
        until myModel
        return myModel
    end
    local function waitForHumanoidAndAnimator(model)
        local hum
        repeat
            hum = model:FindFirstChildOfClass("Humanoid")
            task.wait(0.1)
        until hum
        local anim
        repeat
            anim = hum:FindFirstChildOfClass("Animator")
            task.wait(0.1)
        until anim
        return hum, anim
    end
    local function reconnect()
        local myModel = waitForLiveAndPlayer()
        local hum, anim = waitForHumanoidAndAnimator(myModel)
        applyAttackSpeedToLocalLive()
    end
    reconnect() -- initial
    LocalPlayer.CharacterAdded:Connect(function()
        task.wait(0.2)
        reconnect()
    end)
end

task.defer(robustPunchSpeedReconnect)

-- Apply Button (repurposed to toggle anti)
setToggleSwitchState(ApplyButton, applyToggleKnob, antiWeaveEnabled)

local quickHudFrame
local quickHudFields = {
    Labels = {},
}

local function getPunchTierForHud(value)
    if (tonumber(value) or 0) <= 1.86 then
        return "Legit", Color3.fromRGB(90, 220, 120)
    elseif (tonumber(value) or 0) <= 2.1 then
        return "dangerous", Color3.fromRGB(255, 174, 84)
    end
    return "blatant", Color3.fromRGB(255, 92, 92)
end

local function getStompTierForHud(value)
    if (tonumber(value) or 0) <= 1.2 then
        return "Legit", Color3.fromRGB(90, 220, 120)
    elseif (tonumber(value) or 0) < 1.5 then
        return "dangerous", Color3.fromRGB(255, 174, 84)
    end
    return "blatant", Color3.fromRGB(255, 92, 92)
end

local function getWeaveTierForHud(value)
    if (tonumber(value) or 0) <= 3 then
        return "Legit", Color3.fromRGB(90, 220, 120)
    elseif (tonumber(value) or 0) <= 6 then
        return "dangerous", Color3.fromRGB(255, 174, 84)
    end
    return "blatant", Color3.fromRGB(255, 92, 92)
end

local function refreshQuickHud()
    if not quickHudFrame then
        return
    end

    local visible = isAuthorized and not scriptUnloaded and quickHudFrame.Parent ~= nil and quickHudEnabled
    quickHudFrame.Visible = visible
    if not visible then
        return
    end

    quickHudFrame.BackgroundColor3 = shiftColor(activeThemeMainColor, 6)
    quickHudFrame.BackgroundTransparency = currentMainUiTransparency

    if quickHudFields.Stroke then
        quickHudFields.Stroke.Color = activeThemeSecondaryColor
    end

    if quickHudFields.Title then
        quickHudFields.Title.TextColor3 = activeThemeTextColor
    end

    for _, label in ipairs(quickHudFields.Labels) do
        if label and label.Parent then
            label.TextColor3 = shiftColor(activeThemeTextColor, -35)
        end
    end

    if quickHudFields.HitboxValue then
        quickHudFields.HitboxValue.Text = hitboxEnabled and "ON" or "OFF"
        quickHudFields.HitboxValue.TextColor3 = hitboxEnabled and Color3.fromRGB(90, 220, 120) or Color3.fromRGB(220, 120, 120)
    end
    if quickHudFields.HitboxSizeValue then
        quickHudFields.HitboxSizeValue.Text = tostring(currentHitbox)
        quickHudFields.HitboxSizeValue.TextColor3 = activeThemeTextColor
    end
    if quickHudFields.SmartModeValue then
        quickHudFields.SmartModeValue.Text = includeGroundedTargets and "ON" or "OFF"
        quickHudFields.SmartModeValue.TextColor3 = includeGroundedTargets and Color3.fromRGB(90, 220, 120) or Color3.fromRGB(220, 120, 120)
    end
    if quickHudFields.SelectionsValue then
        quickHudFields.SelectionsValue.Text = showHitboxSelections and "ON" or "OFF"
        quickHudFields.SelectionsValue.TextColor3 = showHitboxSelections and Color3.fromRGB(90, 220, 120) or Color3.fromRGB(220, 120, 120)
    end
    if quickHudFields.WeaveValue then
        quickHudFields.WeaveValue.Text = weaveGlideEnabled and "ON" or "OFF"
        quickHudFields.WeaveValue.TextColor3 = weaveGlideEnabled and Color3.fromRGB(90, 220, 120) or Color3.fromRGB(220, 120, 120)
    end

    local punchTierText, punchTierColor = getPunchTierForHud(currentPunchSpeed)
    if quickHudFields.PunchTierValue then
        quickHudFields.PunchTierValue.Text = punchTierText
        quickHudFields.PunchTierValue.TextColor3 = punchTierColor
    end

    local stompTierText, stompTierColor = getStompTierForHud(currentStompSpeed)
    if quickHudFields.StompTierValue then
        quickHudFields.StompTierValue.Text = stompTierText
        quickHudFields.StompTierValue.TextColor3 = stompTierColor
    end

    local glideTierText, glideTierColor = getWeaveTierForHud(weaveGlideStrength)
    if quickHudFields.GlideTierValue then
        quickHudFields.GlideTierValue.Text = glideTierText
        quickHudFields.GlideTierValue.TextColor3 = glideTierColor
    end
end

setWeaveGlideEnabledState = function(enabled, animate)
    if scriptUnloaded then
        return
    end

    weaveGlideEnabled = enabled and true or false
    if weaveGlideToggle and weaveGlideToggleKnob then
        setToggleSwitchState(weaveGlideToggle, weaveGlideToggleKnob, weaveGlideEnabled, animate)
    end

    -- Apply immediately if a weave BodyPosition already exists on the root.
    if type(applyWeaveGlideBoost) == "function" then
        pcall(applyWeaveGlideBoost)
    end

    refreshQuickHud()
end

local function triggerPanicMode(showMessage)
    if scriptUnloaded then
        return
    end

    hitboxEnabled = false
    includeGroundedTargets = false
    showHitboxSelections = false
    noBounceModeEnabled = false
    noBounceModeExpireAt = 0
    noBounceModeCollisionApplied = false
    antiWeaveEnabled = false
    loopWalkSpeedEnabled = false

    setWeaveGlideEnabledState(false, true)

    if hitboxToggle and hitboxToggleKnob then
        setToggleSwitchState(hitboxToggle, hitboxToggleKnob, hitboxEnabled, true)
    end
    if hitboxSmartModeToggle and hitboxSmartModeToggleKnob then
        setToggleSwitchState(hitboxSmartModeToggle, hitboxSmartModeToggleKnob, includeGroundedTargets, true)
    end
    if showSelectionsToggle and showSelectionsToggleKnob then
        setToggleSwitchState(showSelectionsToggle, showSelectionsToggleKnob, showHitboxSelections, true)
    end
    if ApplyButton and applyToggleKnob then
        setToggleSwitchState(ApplyButton, applyToggleKnob, antiWeaveEnabled, true)
    end
    if noBounceToggle and noBounceToggleKnob then
        setToggleSwitchState(noBounceToggle, noBounceToggleKnob, noBounceModeEnabled, true)
    end
    if loopWalkSpeedToggle and loopWalkSpeedToggleKnob then
        setToggleSwitchState(loopWalkSpeedToggle, loopWalkSpeedToggleKnob, loopWalkSpeedEnabled, true)
    end

    -- Reset combat sliders/fields to defaults so panic returns to a clean baseline.
    currentHitbox = 1
    if hitboxTextBox then
        hitboxTextBox.Text = tostring(currentHitbox)
    end
    if hitboxValueLabel then
        hitboxValueLabel.Text = tostring(currentHitbox)
    end
    if hitboxSliderFill then
        local hitboxRel = (currentHitbox - HITBOX_MIN) / (HITBOX_MAX - HITBOX_MIN)
        hitboxSliderFill.Size = UDim2.new(hitboxRel, 0, 1, 0)
    end

    currentPunchSpeed = PUNCH_MIN
    if punchTextBox then
        punchTextBox.Text = tostring(currentPunchSpeed)
    end
    if punchValueLabel then
        punchValueLabel.Text = tostring(currentPunchSpeed)
    end
    if punchSliderFill then
        local punchRel = (currentPunchSpeed - PUNCH_MIN) / (PUNCH_MAX - PUNCH_MIN)
        punchSliderFill.Size = UDim2.new(punchRel, 0, 1, 0)
    end

    currentStompSpeed = STOMP_MIN
    if stompSlider and stompSlider.TextBox then
        stompSlider.TextBox.Text = tostring(currentStompSpeed)
    end
    if stompSlider and stompSlider.ValueLabel then
        stompSlider.ValueLabel.Text = tostring(currentStompSpeed)
    end
    if stompSlider and stompSlider.Fill then
        local stompRel = (currentStompSpeed - STOMP_MIN) / (STOMP_MAX - STOMP_MIN)
        stompSlider.Fill.Size = UDim2.new(stompRel, 0, 1, 0)
    end

    if setWeaveGlideStrengthValue then
        setWeaveGlideStrengthValue(1)
    else
        weaveGlideStrength = 1
        if weaveGlideStrengthBox then
            weaveGlideStrengthBox.Text = tostring(weaveGlideStrength)
        end
    end

    currentWalkSpeed = 10
    if walkSpeedBox then
        walkSpeedBox.Text = tostring(currentWalkSpeed)
    end

    applyAttackSpeedToLocalLive()

    local humanoid = getLocalHumanoid()
    if humanoid then
        humanoid.WalkSpeed = defaultWalkSpeed
    end

    pcall(UpdatePlayers)
    refreshQuickHud()
    if MainFrame then
        MainFrame.Visible = false
    end

    if showMessage then
        showStatus("Panic key used: combat mods disabled.", true)
    end
end

local function unloadScriptRuntime()
    if scriptUnloaded then
        return
    end

    triggerPanicMode(false)
    scriptUnloaded = true
    isAuthorized = false

    if type(connCache) == "table" then
        for key, c in pairs(connCache) do
            if c then
                pcall(function() c:Disconnect() end)
            end
            connCache[key] = nil
        end
    end

    if type(weaveMobileButtonConnMap) == "table" then
        for buttonRef, conns in pairs(weaveMobileButtonConnMap) do
            if conns then
                for _, conn in ipairs(conns) do
                    if conn then
                        pcall(function() conn:Disconnect() end)
                    end
                end
            end
            weaveMobileButtonConnMap[buttonRef] = nil
        end
    end
    weaveMobileButtonHeld = false
    weaveMobileComboConsumed = false

    if liveRootConn then
        pcall(function() liveRootConn:Disconnect() end)
        liveRootConn = nil
    end

    if affectedPlayersCountConnAdded then
        pcall(function() affectedPlayersCountConnAdded:Disconnect() end)
        affectedPlayersCountConnAdded = nil
    end

    if affectedPlayersCountConnRemoving then
        pcall(function() affectedPlayersCountConnRemoving:Disconnect() end)
        affectedPlayersCountConnRemoving = nil
    end

    if type(playerConnections) == "table" then
        for playerRef, conTable in pairs(playerConnections) do
            if conTable then
                if conTable.humanoidConn then pcall(function() conTable.humanoidConn:Disconnect() end) end
                if conTable.diedConn then pcall(function() conTable.diedConn:Disconnect() end) end
                if conTable.knockedConn then pcall(function() conTable.knockedConn:Disconnect() end) end
                if conTable.liveChildAddedConn then pcall(function() conTable.liveChildAddedConn:Disconnect() end) end
                if conTable.charConn then pcall(function() conTable.charConn:Disconnect() end) end
            end
            playerConnections[playerRef] = nil
        end
    end

    if animationSpeedConn then
        pcall(function() animationSpeedConn:Disconnect() end)
        animationSpeedConn = nil
    end

    if animatorSpeedConn then
        pcall(function() animatorSpeedConn:Disconnect() end)
        animatorSpeedConn = nil
    end

    if stretchResConnection then
        pcall(function()
            stretchResConnection:Disconnect()
        end)
        stretchResConnection = nil
    end
    do
        local camera = Workspace.CurrentCamera
        if camera and stretchResLastBaseCFrame then
            pcall(function()
                camera.CFrame = stretchResLastBaseCFrame
            end)
        end
        stretchResLastBaseCFrame = nil
        stretchResEnabled = false
    end

    lookSensitivityEnabled = false

    mouseSensitivityMultiplier = 1
    pcall(function()
        UserInputService.MouseDeltaSensitivity = 1
    end)
    pcall(function()
        local userSettings = UserSettings()
        if userSettings and type(userSettings.GetService) == "function" then
            local gameSettings = userSettings:GetService("UserGameSettings")
            if gameSettings then
                pcall(function()
                    gameSettings.GamepadCameraSensitivity = 1
                end)
                pcall(function()
                    gameSettings.TouchCameraSensitivity = 1
                end)
            end
        end
    end)
    if lookSensitivityRenderBound then
        pcall(function()
            RunService:UnbindFromRenderStep(LOOK_SENS_RENDER_STEP_NAME)
        end)
        lookSensitivityRenderBound = false
    end
    if lookSensitivityTouchMovedConn then
        pcall(function()
            lookSensitivityTouchMovedConn:Disconnect()
        end)
        lookSensitivityTouchMovedConn = nil
    end
    if lookSensitivityInputChangedConn then
        pcall(function()
            lookSensitivityInputChangedConn:Disconnect()
        end)
        lookSensitivityInputChangedConn = nil
    end
    if lookSensitivityInputEndedConn then
        pcall(function()
            lookSensitivityInputEndedConn:Disconnect()
        end)
        lookSensitivityInputEndedConn = nil
    end
    lookSensitivityTouchDelta = Vector2.new(0, 0)
    lookSensitivityGamepadVector = Vector2.new(0, 0)

    if type(originalHRPProps) == "table" then
        for otherPlayer, props in pairs(originalHRPProps) do
            if otherPlayer and otherPlayer.Character and props then
                restoreCharacterCollisionState(otherPlayer.Character)
                local root = otherPlayer.Character:FindFirstChild("HumanoidRootPart")
                if root and root:IsA("BasePart") then
                    root.Size = props.Size
                    root.Transparency = props.Transparency
                    root.CanCollide = props.CanCollide
                    root.CanTouch = props.CanTouch
                    root.CanQuery = props.CanQuery
                    if props.Material ~= nil then root.Material = props.Material end
                    if props.Color ~= nil then root.Color = props.Color end
                    if props.Reflectance ~= nil then root.Reflectance = props.Reflectance end
                end
            end
            originalHRPProps[otherPlayer] = nil
        end
    end

    if type(characterCollisionProps) == "table" then
        for characterRef, _ in pairs(characterCollisionProps) do
            restoreCharacterCollisionState(characterRef)
        end
    end

    if type(hitboxOutlineBoxes) == "table" then
        for playerRef, outline in pairs(hitboxOutlineBoxes) do
            if outline then
                pcall(function() outline:Destroy() end)
            end
            hitboxOutlineBoxes[playerRef] = nil
        end
    end

    if type(whitelist) == "table" then
        for playerRef, _ in pairs(whitelist) do
            whitelist[playerRef] = nil
        end
    end

    if ScreenGui and ScreenGui.Parent then
        pcall(function()
            ScreenGui:Destroy()
        end)
    end

    if type(sharedRuntimeEnv) == "table" and sharedRuntimeEnv.__TOE_KILL_RUNTIME__ == unloadScriptRuntime then
        sharedRuntimeEnv.__TOE_KILL_RUNTIME__ = nil
    end
end

if type(sharedRuntimeEnv) == "table" then
    sharedRuntimeEnv.__TOE_KILL_RUNTIME__ = unloadScriptRuntime
end

quickHudFrame = Instance.new("Frame")
quickHudFrame.Name = "QuickHUD"
quickHudFrame.Size = UDim2.new(0, 184, 0, 182)
quickHudFrame.Position = UDim2.new(1, -196, 0, 52)
quickHudFrame.BackgroundColor3 = shiftColor(activeThemeMainColor, 6)
quickHudFrame.BackgroundTransparency = 0.14
quickHudFrame.BorderSizePixel = 0
quickHudFrame.Visible = false
quickHudFrame.ZIndex = 19
quickHudFrame.Parent = ScreenGui
Instance.new("UICorner", quickHudFrame).CornerRadius = UDim.new(0, 8)
quickHudFields.Stroke = Instance.new("UIStroke", quickHudFrame)
quickHudFields.Stroke.Color = activeThemeSecondaryColor
quickHudFields.Stroke.Thickness = 1.2
quickHudFields.Stroke.Transparency = 0.08
quickHudFields.Stroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border

local quickHudScale = Instance.new("UIScale")
quickHudScale.Scale = 1
quickHudScale.Parent = quickHudFrame

local QUICK_HUD_MIN_SCALE = 0.7
local QUICK_HUD_MAX_SCALE = 1.85

quickHudFields.Title = Instance.new("TextLabel", quickHudFrame)
quickHudFields.Title.Size = UDim2.new(1, -12, 0, 18)
quickHudFields.Title.Position = UDim2.new(0, 6, 0, 4)
quickHudFields.Title.BackgroundTransparency = 1
quickHudFields.Title.Text = "Quick HUD"
quickHudFields.Title.TextXAlignment = Enum.TextXAlignment.Left
quickHudFields.Title.TextColor3 = activeThemeTextColor
quickHudFields.Title.Font = Enum.Font.GothamBold
quickHudFields.Title.TextSize = 12
quickHudFields.Title.Active = true

quickHudFrame.Active = true
quickHudFrame.Draggable = false

quickHudDragInput = nil
quickHudDragStart = nil
quickHudStartPos = nil
quickHudDragging = false
quickHudDragIsTouch = false

local quickHudPinchTouches = {}
local quickHudPinchStartDistance = nil
local quickHudPinchStartScale = quickHudScale.Scale
local quickHudPinching = false

local function quickHudStopDrag()
    quickHudDragging = false
    quickHudDragIsTouch = false
    quickHudDragInput = nil
    quickHudDragStart = nil
    quickHudStartPos = nil
end

local function quickHudContainsScreenPoint(point)
    if not quickHudFrame or not quickHudFrame.Visible then
        return false
    end

    local absPos = quickHudFrame.AbsolutePosition
    local absSize = quickHudFrame.AbsoluteSize
    return point.X >= absPos.X
        and point.X <= absPos.X + absSize.X
        and point.Y >= absPos.Y
        and point.Y <= absPos.Y + absSize.Y
end

local function quickHudFindTouchIndex(input)
    for i, touch in ipairs(quickHudPinchTouches) do
        if touch == input then
            return i
        end
    end
    return nil
end

local function quickHudRefreshPinchState()
    if #quickHudPinchTouches >= 2 then
        local firstTouch = quickHudPinchTouches[1]
        local secondTouch = quickHudPinchTouches[2]
        if firstTouch and secondTouch then
            quickHudPinchStartDistance = (firstTouch.Position - secondTouch.Position).Magnitude
            quickHudPinchStartScale = quickHudScale.Scale
            quickHudPinching = quickHudPinchStartDistance and quickHudPinchStartDistance > 0
            if quickHudPinching then
                quickHudStopDrag()
            end
            return
        end
    end

    quickHudPinchStartDistance = nil
    quickHudPinching = false
end

quickHudFields.Title.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        if quickHudPinching then
            return
        end

        quickHudDragging = true
        quickHudDragIsTouch = input.UserInputType == Enum.UserInputType.Touch
        quickHudDragInput = quickHudDragIsTouch and input or nil
        quickHudDragStart = input.Position
        quickHudStartPos = quickHudFrame.Position
    end
end)

quickHudFields.Title.InputEnded:Connect(function(input)
    if not quickHudDragging then
        return
    end

    if quickHudDragIsTouch then
        if quickHudDragInput ~= input then
            return
        end
    elseif input.UserInputType ~= Enum.UserInputType.MouseButton1 then
        return
    end

    quickHudStopDrag()
end)

UserInputService.InputChanged:Connect(function(input)
    if scriptUnloaded or quickHudPinching or not quickHudDragging or not quickHudDragStart or not quickHudStartPos then
        return
    end

    if quickHudDragIsTouch then
        if input.UserInputType ~= Enum.UserInputType.Touch or input ~= quickHudDragInput then
            return
        end
    elseif input.UserInputType ~= Enum.UserInputType.MouseMovement then
        return
    end

    local delta = input.Position - quickHudDragStart
    quickHudFrame.Position = UDim2.new(
        quickHudStartPos.X.Scale,
        math.floor(quickHudStartPos.X.Offset + delta.X),
        quickHudStartPos.Y.Scale,
        math.floor(quickHudStartPos.Y.Offset + delta.Y)
    )
end)

UserInputService.InputEnded:Connect(function(input)
    if not quickHudDragging then
        return
    end

    if quickHudDragIsTouch then
        if quickHudDragInput ~= input then
            return
        end
    elseif input.UserInputType ~= Enum.UserInputType.MouseButton1 then
        return
    end

    quickHudStopDrag()
end)

UserInputService.TouchStarted:Connect(function(input)
    if scriptUnloaded or not isAuthorized or not quickHudEnabled or not quickHudFrame.Visible then
        return
    end

    if not quickHudContainsScreenPoint(input.Position) then
        return
    end

    if not quickHudFindTouchIndex(input) then
        quickHudPinchTouches[#quickHudPinchTouches + 1] = input
    end
    quickHudRefreshPinchState()
end)

UserInputService.TouchMoved:Connect(function()
    if scriptUnloaded or not quickHudPinching or #quickHudPinchTouches < 2 then
        return
    end

    local firstTouch = quickHudPinchTouches[1]
    local secondTouch = quickHudPinchTouches[2]
    if not firstTouch or not secondTouch or not quickHudPinchStartDistance or quickHudPinchStartDistance <= 0 then
        return
    end

    local currentDistance = (firstTouch.Position - secondTouch.Position).Magnitude
    local pinchRatio = currentDistance / quickHudPinchStartDistance
    quickHudScale.Scale = math.clamp(quickHudPinchStartScale * pinchRatio, QUICK_HUD_MIN_SCALE, QUICK_HUD_MAX_SCALE)
end)

UserInputService.TouchEnded:Connect(function(input)
    local index = quickHudFindTouchIndex(input)
    if index then
        table.remove(quickHudPinchTouches, index)
        quickHudRefreshPinchState()
    end
end)

local function createQuickHudLabel(yOffset, text)
    local label = Instance.new("TextLabel", quickHudFrame)
    label.Size = UDim2.new(0, 98, 0, 18)
    label.Position = UDim2.new(0, 8, 0, yOffset)
    label.BackgroundTransparency = 1
    label.Text = text
    label.TextColor3 = shiftColor(activeThemeTextColor, -35)
    label.Font = Enum.Font.Gotham
    label.TextSize = 11
    label.TextXAlignment = Enum.TextXAlignment.Left
    table.insert(quickHudFields.Labels, label)
    return label
end

local function createQuickHudValueLabel(yOffset)
    local valueLabel = Instance.new("TextLabel", quickHudFrame)
    valueLabel.Size = UDim2.new(0, 72, 0, 18)
    valueLabel.Position = UDim2.new(1, -80, 0, yOffset)
    valueLabel.BackgroundTransparency = 1
    valueLabel.Text = "-"
    valueLabel.TextColor3 = activeThemeTextColor
    valueLabel.Font = Enum.Font.GothamBold
    valueLabel.TextSize = 11
    valueLabel.TextXAlignment = Enum.TextXAlignment.Right
    return valueLabel
end

