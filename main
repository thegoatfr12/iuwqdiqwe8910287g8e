-- =========================
-- Anti-weave stun protection
-- =========================

-- Simple safe wrapper (pcall wrapper)
function safe(fn)
    local ok, err = pcall(fn)
    if not ok then
        -- silent fail; optionally print(err) for debugging
    end
end

-- Connection cache and helpers for anti-weave
connCache = {} -- key -> connection
function disconnectKey(key)
    local c = connCache[key]
    if c then
        pcall(function() c:Disconnect() end)
        connCache[key] = nil
    end
end

-- Anti-weave state and tick
antiTick = 0.15 -- fallback loop interval (seconds)
weaveGlideLastTick = weaveGlideLastTick or 0
weaveGlideSpaceHeld = weaveGlideSpaceHeld or false
weaveMoveW = weaveMoveW or false
weaveMoveA = weaveMoveA or false
weaveMoveS = weaveMoveS or false
weaveMoveD = weaveMoveD or false
weaveLastMoveKey = weaveLastMoveKey or nil
weaveThumbstickVector = weaveThumbstickVector or Vector2.new(0, 0)
weaveGamepadTriggerHeld = weaveGamepadTriggerHeld or false
weaveGamepadComboConsumed = weaveGamepadComboConsumed or false
weaveLastGamepadDirection = weaveLastGamepadDirection or nil
weaveMobileButtonHeld = weaveMobileButtonHeld or false
weaveMobileComboConsumed = weaveMobileComboConsumed or false
weaveMobileButtonConnMap = weaveMobileButtonConnMap or {}

function clearMobileWeaveButtonHooks()
    if scriptUnloaded then
        return
    end
    for button, conns in pairs(weaveMobileButtonConnMap) do
        if conns then
            for _, conn in ipairs(conns) do
                if conn then
                    pcall(function() conn:Disconnect() end)
                end
            end
        end
        weaveMobileButtonConnMap[button] = nil
    end
end

function isLikelyMobileWeaveButton(gui)
    if not gui or not gui:IsA("GuiButton") then
        return false
    end

    local name = tostring(gui.Name or ""):lower()
    local text = ""
    if gui:IsA("TextButton") then
        text = tostring(gui.Text or ""):lower()
    end

    if name:find("weave", 1, true) or name:find("dodge", 1, true) then
        return true
    end
    if text:find("weave", 1, true) or text:find("dodge", 1, true) then
        return true
    end

    return false
end

function attachMobileWeaveButton(button)
    if scriptUnloaded then
        return
    end
    if not button or weaveMobileButtonConnMap[button] then
        return
    end

    local beganConn = button.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch then
            weaveMobileButtonHeld = true
            weaveMobileComboConsumed = false
        end
    end)

    local endedConn = button.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch then
            weaveMobileButtonHeld = false
            weaveMobileComboConsumed = false
        end
    end)

    local ancestryConn = button.AncestryChanged:Connect(function(_, parent)
        if parent then
            return
        end

        local conns = weaveMobileButtonConnMap[button]
        if conns then
            for _, conn in ipairs(conns) do
                if conn then
                    pcall(function() conn:Disconnect() end)
                end
            end
        end
        weaveMobileButtonConnMap[button] = nil
    end)

    weaveMobileButtonConnMap[button] = {beganConn, endedConn, ancestryConn}
end

function connectMobileWeaveButtons()
    if scriptUnloaded then
        return
    end
    disconnectKey("WeaveMobileDescAdded")
    clearMobileWeaveButtonHooks()

    if not UserInputService.TouchEnabled then
        return
    end

    local playerGui = player and player:FindFirstChildOfClass("PlayerGui")
    if not playerGui then
        return
    end

    -- Chunk the initial scan to avoid a noticeable startup hitch on large PlayerGui trees.
    task.spawn(function()
        local descendants = playerGui:GetDescendants()
        for index, desc in ipairs(descendants) do
            if isLikelyMobileWeaveButton(desc) then
                attachMobileWeaveButton(desc)
            end

            if index % 80 == 0 then
                task.wait()
            end
        end
    end)

    connCache["WeaveMobileDescAdded"] = playerGui.DescendantAdded:Connect(function(desc)
        if isLikelyMobileWeaveButton(desc) then
            attachMobileWeaveButton(desc)
        end
    end)
end

function directionFromMoveKey(keyCode, root)
    if not keyCode or not root then
        return nil
    end

    local forward = Vector3.new(root.CFrame.LookVector.X, 0, root.CFrame.LookVector.Z)
    local right = Vector3.new(root.CFrame.RightVector.X, 0, root.CFrame.RightVector.Z)

    if forward.Magnitude <= 0.01 or right.Magnitude <= 0.01 then
        return nil
    end

    forward = forward.Unit
    right = right.Unit

    if keyCode == Enum.KeyCode.W then
        return forward
    elseif keyCode == Enum.KeyCode.A then
        return -right
    elseif keyCode == Enum.KeyCode.S then
        return -forward
    elseif keyCode == Enum.KeyCode.D then
        return right
    end

    return nil
end

function getThumbstickWorldDirection(root)
    if not root then
        return nil
    end

    local stick = weaveThumbstickVector or Vector2.new(0, 0)
    local stickX = tonumber(stick.X) or 0
    local stickY = tonumber(stick.Y) or 0
    if math.abs(stickX) < 0.08 and math.abs(stickY) < 0.08 then
        return nil
    end

    local cam = workspace.CurrentCamera
    local lookSource = cam and cam.CFrame.LookVector or root.CFrame.LookVector
    local rightSource = cam and cam.CFrame.RightVector or root.CFrame.RightVector
    local forward = Vector3.new(lookSource.X, 0, lookSource.Z)
    local right = Vector3.new(rightSource.X, 0, rightSource.Z)
    if forward.Magnitude <= 0.01 or right.Magnitude <= 0.01 then
        return nil
    end

    -- Keep Y sign as-is so forward/back on the stick maps naturally in this game.
    local world = (right.Unit * stickX) + (forward.Unit * stickY)
    if world.Magnitude <= 0.01 then
        return nil
    end

    return world.Unit
end

function shouldTriggerGamepadGlideForDirection(newDirection)
    if not newDirection then
        return false
    end

    if not weaveGamepadComboConsumed then
        return true
    end

    local lastDirection = weaveLastGamepadDirection
    if not lastDirection then
        return true
    end

    return lastDirection:Dot(newDirection) < 0.92
end

function getWeaveGlideCharacter()
    local char = player.Character
    if char and char.Parent then
        return char
    end

    local live = workspace:FindFirstChild("Live")
    local liveModel = live and live:FindFirstChild(player.Name)
    if liveModel and liveModel.Parent then
        return liveModel
    end

    return nil
end

function isLikelyFistsToolName(name)
    local lowered = tostring(name or ""):lower()
    if lowered == "" then
        return false
    end

    return lowered:find("fist", 1, true)
        or lowered:find("boxing", 1, true)
        or lowered:find("glove", 1, true)
        or lowered:find("gauntlet", 1, true)
        or lowered:find("knuckle", 1, true)
        or lowered:find("combat", 1, true)
end

function isLikelyWeaponToolName(name)
    local lowered = tostring(name or ""):lower()
    if lowered == "" then
        return false
    end

    return lowered:find("gun", 1, true)
        or lowered:find("rifle", 1, true)
        or lowered:find("shotgun", 1, true)
        or lowered:find("revolver", 1, true)
        or lowered:find("smg", 1, true)
        or lowered:find("uzi", 1, true)
        or lowered:find("ak", 1, true)
        or lowered:find("ar", 1, true)
        or lowered:find("pistol", 1, true)
        or lowered:find("knife", 1, true)
        or lowered:find("blade", 1, true)
        or lowered:find("sword", 1, true)
        or lowered:find("katana", 1, true)
        or lowered:find("bat", 1, true)
        or lowered:find("hammer", 1, true)
        or lowered:find("mace", 1, true)
end

function isFistsEquippedForWeave()
    local character = getWeaveGlideCharacter()
    if not character then
        return false
    end

    local equippedTools = {}
    for _, child in ipairs(character:GetChildren()) do
        if child:IsA("Tool") then
            equippedTools[#equippedTools + 1] = child
        end
    end

    -- If a tool is equipped, only allow weave glide for fist/combat-like tool names.
    if #equippedTools > 0 then
        local hasUnknownNonWeaponTool = false
        for _, tool in ipairs(equippedTools) do
            if isLikelyFistsToolName(tool.Name) then
                return true
            end

            if not isLikelyWeaponToolName(tool.Name) then
                hasUnknownNonWeaponTool = true
            end
        end

        if hasUnknownNonWeaponTool then
            return true
        end

        return false
    end

    -- No tool equipped means fists are away, so weave glide should stay blocked.
    return false
end

function applyWeaveGlideBodyPositionDistance(root, bodyPosition)
    if not root or not bodyPosition or not bodyPosition:IsA("BodyPosition") then
        return
    end

    if bodyPosition:GetAttribute("m") ~= 1 then
        return
    end

    local currentPosition = bodyPosition.Position
    local rootPosition = root.Position
    local direction = currentPosition - rootPosition
    if direction.Magnitude <= 0 then
        return
    end

    -- Slider-driven weave logic:
    -- Strength 1 matches baseline behavior; 15 pushes very blatant distance.
    local strength = math.clamp(tonumber(weaveGlideStrength) or 1, 1, 15)
    local normalizedStrength = (strength - 1) / 14
    local enabledDistance = 2.2 + (4.6 * normalizedStrength)
    local targetDistance = weaveGlideEnabled and enabledDistance or 2.2
    bodyPosition.Position = rootPosition + (direction.Unit * targetDistance)
end

function hookWeaveGlideRoot(root)
    disconnectKey("WeaveGlideBodyPositionChildAdded")
    if not root then
        return
    end

    connCache["WeaveGlideBodyPositionChildAdded"] = root.ChildAdded:Connect(function(child)
        safe(function()
            applyWeaveGlideBodyPositionDistance(root, child)
        end)
    end)

    for _, child in ipairs(root:GetChildren()) do
        safe(function()
            applyWeaveGlideBodyPositionDistance(root, child)
        end)
    end
end

function hookWeaveGlideCharacter(character)
    disconnectKey("WeaveGlideBodyPositionChildAdded")
    if not character then
        return
    end

    local root = character:FindFirstChild("HumanoidRootPart") or character:WaitForChild("HumanoidRootPart", 10)
    if not root then
        return
    end

    hookWeaveGlideRoot(root)
end

disconnectKey("WeaveGlideBodyPositionCharacterAdded")
connCache["WeaveGlideBodyPositionCharacterAdded"] = player.CharacterAdded:Connect(function(character)
    safe(function()
        hookWeaveGlideCharacter(character)
    end)
end)

safe(function()
    hookWeaveGlideCharacter(player.Character)
end)

function applyWeaveGlideBoost(_trigger)
    refreshNoBounceModeWindow()

    -- Legacy entrypoint retained because existing listeners call this function.
    local character = getWeaveGlideCharacter()
    if not character then
        return
    end

    local root = character:FindFirstChild("HumanoidRootPart")
    if not root then
        return
    end

    for _, child in ipairs(root:GetChildren()) do
        applyWeaveGlideBodyPositionDistance(root, child)
    end
end

-- connectWeaveListeners adapted from your snippet
local function connectWeaveListeners()
    if scriptUnloaded then
        return
    end
    disconnectKey("LiveWeave")
    disconnectKey("ModelWeave")
    disconnectKey("WeaveChild")
    disconnectKey("WeaveAnim")

    local live = workspace:FindFirstChild("Live")
    if not live then
        connCache["LiveWeave"] = workspace.ChildAdded:Connect(function(ch)
            if ch.Name == "Live" then
                task.defer(connectWeaveListeners)
            end
        end)
        return
    end

    connCache["ModelWeave"] = live.ChildAdded:Connect(function(ch)
        if ch.Name == player.Name then
            task.defer(connectWeaveListeners)
        end
    end)

    local pl = live:FindFirstChild(player.Name)
    if not pl then return end

    -- Delete instantly if already present (only when enabled)
    local stun = pl:FindFirstChild("WeaveStun")
    if stun then safe(applyWeaveGlideBoost) end
    if antiWeaveEnabled and stun then safe(function() stun:Destroy() end) end

    -- Real-time deletion
    connCache["WeaveChild"] = pl.ChildAdded:Connect(function(ch)
        if ch.Name == "WeaveStun" then
            safe(applyWeaveGlideBoost)
        end
        if antiWeaveEnabled and ch.Name == "WeaveStun" then
            safe(function() ch:Destroy() end)
        end
    end)

    local character = player.Character
    local humanoid = character and character:FindFirstChildOfClass("Humanoid")
    if humanoid then
        connCache["WeaveAnim"] = humanoid.AnimationPlayed:Connect(function(track)
            if not weaveGlideEnabled or not track or not track.Animation then
                return
            end

            local trackName = tostring(track.Name or ""):lower()
            local animationId = tostring(track.Animation.AnimationId or ""):lower()
            if trackName:find("weave") or animationId:find("weave") then
                safe(applyWeaveGlideBoost)
            end
        end)
    end

    -- Reconnect after death
    pl.AncestryChanged:Connect(function(_, parent)
        if not parent then
            task.defer(connectWeaveListeners)
        end
    end)
end

task.defer(connectWeaveListeners)
task.delay(0.8, connectMobileWeaveButtons)

-- Fallback loop
task.spawn(function()
    while true do
        if scriptUnloaded then
            break
        end

        syncNoBounceModeWindow()

        if antiWeaveEnabled or weaveGlideEnabled then
            local live = workspace:FindFirstChild("Live")
            local pl = live and live:FindFirstChild(player.Name)
            local stun = pl and pl:FindFirstChild("WeaveStun")
            if stun then
                if weaveGlideEnabled then
                    safe(applyWeaveGlideBoost)
                end
                if antiWeaveEnabled then
                    safe(function() stun:Destroy() end)
                end
            end
        end

        if weaveGlideEnabled and weaveMobileButtonHeld and not weaveMobileComboConsumed then
            local character = getWeaveGlideCharacter()
            local humanoid = character and character:FindFirstChildOfClass("Humanoid")
            if humanoid then
                local moveDirection = humanoid.MoveDirection
                local horizontal = Vector3.new(moveDirection.X, 0, moveDirection.Z)
                if horizontal.Magnitude > 0.08 then
                    weaveMobileComboConsumed = true
                    safe(function()
                        applyWeaveGlideBoost(horizontal.Unit)
                    end)
                end
            end
        end

        task.wait(antiTick)
    end
end)

-- Apply button now toggles anti on/off (instead of calling UpdatePlayers)
function toggleAntiWeaveFromHotkey()
    if scriptUnloaded then
        return
    end
    antiWeaveEnabled = not antiWeaveEnabled
    setToggleSwitchState(ApplyButton, applyToggleKnob, antiWeaveEnabled, true)

    if antiWeaveEnabled then
        -- Immediately attempt to remove any existing WeaveStun and ensure listeners are active
        task.defer(function()
            connectWeaveListeners()
            -- immediate sweep
            local live = workspace:FindFirstChild("Live")
            local pl = live and live:FindFirstChild(player.Name)
            local stun = pl and pl:FindFirstChild("WeaveStun")
            if stun then safe(function() stun:Destroy() end) end
        end)
        showStatus("Anti-weave: Enabled", false)
    else
        showStatus("Anti-weave: Disabled", false)
        -- When disabling, we keep listeners but they will no longer destroy stuns because checks use antiWeaveEnabled
    end
end

ApplyButton.MouseButton1Click:Connect(function()
    if freeModeShouldBlockControl(ApplyButton, true) then
        return
    end

    toggleAntiWeaveFromHotkey()
end)

UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed or scriptUnloaded then
        return
    end

    local keyCode = input.KeyCode

    if keyCode == Enum.KeyCode.ButtonL2 then
        weaveGamepadTriggerHeld = true
        weaveGamepadComboConsumed = false
        weaveLastGamepadDirection = nil

        if weaveGlideEnabled then
            local character = getWeaveGlideCharacter()
            local root = character and character:FindFirstChild("HumanoidRootPart")
            local thumbDir = root and getThumbstickWorldDirection(root) or nil
            if shouldTriggerGamepadGlideForDirection(thumbDir) then
                weaveGamepadComboConsumed = true
                weaveLastGamepadDirection = thumbDir
                safe(function()
                    applyWeaveGlideBoost(thumbDir)
                end)
            end
        end
        return
    end

    if keyCode == Enum.KeyCode.Space then
        weaveGlideSpaceHeld = true
        if weaveGlideEnabled
            and (weaveMoveW or weaveMoveA or weaveMoveS or weaveMoveD) then
            local keyToUse = weaveLastMoveKey
            if keyToUse ~= Enum.KeyCode.W
                and keyToUse ~= Enum.KeyCode.A
                and keyToUse ~= Enum.KeyCode.S
                and keyToUse ~= Enum.KeyCode.D then
                if weaveMoveW then
                    keyToUse = Enum.KeyCode.W
                elseif weaveMoveA then
                    keyToUse = Enum.KeyCode.A
                elseif weaveMoveS then
                    keyToUse = Enum.KeyCode.S
                elseif weaveMoveD then
                    keyToUse = Enum.KeyCode.D
                end
            end

            safe(function()
                applyWeaveGlideBoost(keyToUse)
            end)
        end
        return
    end

    if keyCode == Enum.KeyCode.W then
        weaveMoveW = true
    elseif keyCode == Enum.KeyCode.A then
        weaveMoveA = true
    elseif keyCode == Enum.KeyCode.S then
        weaveMoveS = true
    elseif keyCode == Enum.KeyCode.D then
        weaveMoveD = true
    else
        return
    end

    weaveLastMoveKey = keyCode

    if weaveGlideEnabled and weaveGlideSpaceHeld then
        safe(function()
            applyWeaveGlideBoost(keyCode)
        end)
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if scriptUnloaded then
        return
    end
    local keyCode = input.KeyCode

    if keyCode == Enum.KeyCode.ButtonL2 then
        weaveGamepadTriggerHeld = false
        weaveGamepadComboConsumed = false
        weaveLastGamepadDirection = nil
        return
    end

    if keyCode == Enum.KeyCode.Space then
        weaveGlideSpaceHeld = false
        return
    end

    if keyCode == Enum.KeyCode.W then
        weaveMoveW = false
    elseif keyCode == Enum.KeyCode.A then
        weaveMoveA = false
    elseif keyCode == Enum.KeyCode.S then
        weaveMoveS = false
    elseif keyCode == Enum.KeyCode.D then
        weaveMoveD = false
    end

    if weaveLastMoveKey == keyCode then
        if weaveMoveW then
            weaveLastMoveKey = Enum.KeyCode.W
        elseif weaveMoveA then
            weaveLastMoveKey = Enum.KeyCode.A
        elseif weaveMoveS then
            weaveLastMoveKey = Enum.KeyCode.S
        elseif weaveMoveD then
            weaveLastMoveKey = Enum.KeyCode.D
        else
            weaveLastMoveKey = nil
        end
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if scriptUnloaded then
        return
    end
    if input.UserInputType == Enum.UserInputType.Gamepad1 and input.KeyCode == Enum.KeyCode.Thumbstick1 then
        weaveThumbstickVector = Vector2.new(input.Position.X, input.Position.Y)

        if weaveGlideEnabled and weaveGamepadTriggerHeld then
            local character = getWeaveGlideCharacter()
            local root = character and character:FindFirstChild("HumanoidRootPart")
            local thumbDir = root and getThumbstickWorldDirection(root) or nil

            if not thumbDir then
                weaveGamepadComboConsumed = false
                weaveLastGamepadDirection = nil
                return
            end

            if shouldTriggerGamepadGlideForDirection(thumbDir) then
                weaveGamepadComboConsumed = true
                weaveLastGamepadDirection = thumbDir
                safe(function()
                    applyWeaveGlideBoost(thumbDir)
                end)
            end
        end
    end
end)

