        {date = "2026-04-10", title = "Split share codes by Combat and Customization", details = ""},
        {date = "2026-04-10", title = "Mobile teleport reliability overhaul", details = ""},
        {date = "2026-04-08", title = "Startup no-show fix", details = ""},
        {date = "2026-04-08", title = "Local register overflow fix", details = ""},
    }

    settingsPnDateFilters = {"All"}
    do
        local seen = {}
        local dates = {}
        for _, entry in ipairs(settingsPnEntries) do
            if type(entry.date) == "string" and entry.date ~= "" and not seen[entry.date] then
                seen[entry.date] = true
                dates[#dates + 1] = entry.date
            end
        end
        table.sort(dates, function(a, b)
            return tostring(a) > tostring(b)
        end)
        for _, dateValue in ipairs(dates) do
            settingsPnDateFilters[#settingsPnDateFilters + 1] = dateValue
        end
    end

    settingsPnFilterIndex = 1
    settingsPageActive = 1
    local settingsPageSwitchBusy = false

    rebuildSettingsPnList = function()
        if not settingsPnList then
            return
        end

        for _, child in ipairs(settingsPnList:GetChildren()) do
            if child:IsA("Frame") then
                child:Destroy()
            end
        end

        local activeFilter = settingsPnDateFilters[settingsPnFilterIndex] or "All"
        local layoutOrder = 0
        for _, entry in ipairs(settingsPnEntries) do
            if activeFilter == "All" or tostring(entry.date) == activeFilter then
                layoutOrder = layoutOrder + 1
                local detailsText = tostring(entry.details or "")
                local hasDetails = detailsText ~= ""

                local card = Instance.new("Frame", settingsPnList)
                card.Size = UDim2.new(1, -8, 0, hasDetails and 74 or 46)
                card.BackgroundColor3 = shiftColor(activeThemeMainColor, 10)
                card.BackgroundTransparency = 0.1
                card.BorderSizePixel = 0
                card.ZIndex = 4
                card.LayoutOrder = layoutOrder
                Instance.new("UICorner", card).CornerRadius = UDim.new(0, 7)

                local dateLabel = Instance.new("TextLabel", card)
                dateLabel.Size = UDim2.new(0, 110, 0, 18)
                dateLabel.Position = UDim2.new(0, 8, 0, 4)
                dateLabel.BackgroundTransparency = 1
                dateLabel.Text = tostring(entry.date or "")
                dateLabel.TextColor3 = activeThemeSecondaryColor
                dateLabel.Font = Enum.Font.GothamBold
                dateLabel.TextSize = 11
                dateLabel.TextXAlignment = Enum.TextXAlignment.Left
                dateLabel.ZIndex = 5

                local titleLabel = Instance.new("TextLabel", card)
                titleLabel.Size = UDim2.new(1, -16, 0, 18)
                titleLabel.Position = UDim2.new(0, 8, 0, 22)
                titleLabel.BackgroundTransparency = 1
                titleLabel.Text = tostring(entry.title or "")
