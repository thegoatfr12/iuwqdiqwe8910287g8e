    while true do
        if isFreeModeActive() then
            if type(enforceFreeModeToggleGreyVisuals) == "function" then
                pcall(enforceFreeModeToggleGreyVisuals)
            end
            if type(enforceFreeModeBlockedControlVisuals) == "function" then
                pcall(enforceFreeModeBlockedControlVisuals)
            end
        end
        task.wait(0.35)
    end
end)

