-- Default UI colors
local mainColor = Color3.fromRGB(10, 10, 12)
local secondaryColor = Color3.fromRGB(230, 50, 50)
local textColor = Color3.fromRGB(245, 245, 245)

local function shiftColor(color, delta)
    return Color3.fromRGB(
        math.clamp(math.floor(color.R * 255 + delta), 0, 255),
        math.clamp(math.floor(color.G * 255 + delta), 0, 255),
        math.clamp(math.floor(color.B * 255 + delta), 0, 255)
    )
end

local function setColorPickerValue(picker, color)
    if not picker or not picker.boxes then
        return
    end

    picker.boxes[1].Text = tostring(math.floor(color.R * 255 + 0.5))
    picker.boxes[2].Text = tostring(math.floor(color.G * 255 + 0.5))
    picker.boxes[3].Text = tostring(math.floor(color.B * 255 + 0.5))
end

local function ensureLiquidGradient(instance, gradientName, topColor, bottomColor, rotation)
    if not instance then
        return
    end

    local gradient = instance:FindFirstChild(gradientName)
    if not gradient then
        gradient = Instance.new("UIGradient")
        gradient.Name = gradientName
        gradient.Parent = instance
    end

    gradient.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, topColor),
        ColorSequenceKeypoint.new(0.52, shiftColor(topColor, -6)),
        ColorSequenceKeypoint.new(1, bottomColor),
    })
    gradient.Rotation = rotation or 90
end

-- Helper to create color picker (simple RGB input)
local function createColorPicker(parent, labelText, defaultColor, posY, onChanged)
    local label = Instance.new("TextLabel", parent)
    label.Text = labelText
    label.Size = UDim2.new(0, 110, 0, 22)
    label.Position = UDim2.new(0, 10, 0, posY)
    label.BackgroundTransparency = 1
    label.TextColor3 = textColor
    label.Font = Enum.Font.Gotham
    label.TextSize = 15

    local rBox = Instance.new("TextBox", parent)
    rBox.Size = UDim2.new(0, 36, 0, 22)
    rBox.Position = UDim2.new(0, 130, 0, posY)
    rBox.Text = tostring(math.floor(defaultColor.R * 255))
    rBox.PlaceholderText = "R"
    rBox.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    rBox.TextColor3 = textColor
    rBox.Font = Enum.Font.Gotham
    rBox.TextSize = 14
    rBox.BorderSizePixel = 0
    Instance.new("UICorner", rBox).CornerRadius = UDim.new(0, 6)

    local gBox = Instance.new("TextBox", parent)
    gBox.Size = UDim2.new(0, 36, 0, 22)
    gBox.Position = UDim2.new(0, 172, 0, posY)
    gBox.Text = tostring(math.floor(defaultColor.G * 255))
    gBox.PlaceholderText = "G"
    gBox.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    gBox.TextColor3 = textColor
    gBox.Font = Enum.Font.Gotham
    gBox.TextSize = 14
    gBox.BorderSizePixel = 0
    Instance.new("UICorner", gBox).CornerRadius = UDim.new(0, 6)

    local bBox = Instance.new("TextBox", parent)
    bBox.Size = UDim2.new(0, 36, 0, 22)
    bBox.Position = UDim2.new(0, 214, 0, posY)
    bBox.Text = tostring(math.floor(defaultColor.B * 255))
    bBox.PlaceholderText = "B"
    bBox.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    bBox.TextColor3 = textColor
    bBox.Font = Enum.Font.Gotham
    bBox.TextSize = 14
    bBox.BorderSizePixel = 0
    Instance.new("UICorner", bBox).CornerRadius = UDim.new(0, 6)

    local function updateColor()
        local r = tonumber(rBox.Text) or 0
        local g = tonumber(gBox.Text) or 0
        local b = tonumber(bBox.Text) or 0
        r = math.clamp(r, 0, 255)
        g = math.clamp(g, 0, 255)
        b = math.clamp(b, 0, 255)
        local color = Color3.fromRGB(r, g, b)
        if onChanged then onChanged(color) end
    end
    rBox.FocusLost:Connect(updateColor)
    gBox.FocusLost:Connect(updateColor)
    bBox.FocusLost:Connect(updateColor)
    return {
        label = label,
        boxes = {rBox, gBox, bBox},
    }
end

local mainColorPicker
local secondaryColorPicker
local textColorPicker
local themePresetsLabel
mainUiTransparency = {
    frame = nil,
    bar = nil,
    fill = nil,
    label = nil,
    valueLabel = nil,
    dragging = false,
    min = 0.05,
    max = 0.9,
}

setMainUiTransparency = function(value)
    local clamped = math.clamp(math.floor(value * 100) / 100, mainUiTransparency.min, mainUiTransparency.max)
    currentMainUiTransparency = clamped
    if MainFrame then
        MainFrame.BackgroundTransparency = currentMainUiTransparency
    end
    if affectedPlayersBox then
        affectedPlayersBox.BackgroundTransparency = currentMainUiTransparency
    end

    if mainUiTransparency.valueLabel then
        mainUiTransparency.valueLabel.Text = tostring(currentMainUiTransparency)
    end

    if mainUiTransparency.fill then
        local rel = (currentMainUiTransparency - mainUiTransparency.min) / (mainUiTransparency.max - mainUiTransparency.min)
        mainUiTransparency.fill.Size = UDim2.new(rel, 0, 1, 0)
    end
end

local function mainUiTransparencyPosToValue(px)
    if not mainUiTransparency.bar then
        return currentMainUiTransparency
    end

    local absX = mainUiTransparency.bar.AbsolutePosition.X
    local w = mainUiTransparency.bar.AbsoluteSize.X
    local rel = math.clamp((px - absX) / math.max(w, 1), 0, 1)
    local raw = mainUiTransparency.min + (mainUiTransparency.max - mainUiTransparency.min) * rel
    return math.clamp(math.floor(raw * 100) / 100, mainUiTransparency.min, mainUiTransparency.max)
end

local function ensureGlassHazeLayer(container, layerName, hazeColor, hazeTransparency)
    if not container then
        return
    end

    local haze = container:FindFirstChild(layerName)
    if not haze then
        haze = Instance.new("Frame")
        haze.Name = layerName
        haze.Size = UDim2.new(1, 0, 1, 0)
        haze.Position = UDim2.new(0, 0, 0, 0)
        haze.BorderSizePixel = 0
        haze.ZIndex = 0
        haze.Parent = container

        local shimmer = Instance.new("UIGradient")
        shimmer.Name = "HazeGradient"
        shimmer.Rotation = 100
        shimmer.Parent = haze

        local gloss = Instance.new("Frame")
        gloss.Name = "GlassGloss"
        gloss.Size = UDim2.new(1, 0, 0.42, 0)
        gloss.Position = UDim2.new(0, 0, 0, 0)
        gloss.BackgroundTransparency = 1
        gloss.BorderSizePixel = 0
        gloss.ZIndex = 0
        gloss.Parent = haze

        local glossGradient = Instance.new("UIGradient")
        glossGradient.Name = "GlossGradient"
        glossGradient.Rotation = 90
        glossGradient.Parent = gloss
    end

    haze.BackgroundColor3 = hazeColor
    haze.BackgroundTransparency = hazeTransparency

    local sourceCorner = container:FindFirstChildOfClass("UICorner")
    if sourceCorner then
        local hazeCorner = haze:FindFirstChild("HazeCorner")
        if not hazeCorner then
            hazeCorner = Instance.new("UICorner")
            hazeCorner.Name = "HazeCorner"
            hazeCorner.Parent = haze
        end
        hazeCorner.CornerRadius = sourceCorner.CornerRadius
    end

    local shimmer = haze:FindFirstChild("HazeGradient")
    if shimmer and shimmer:IsA("UIGradient") then
        shimmer.Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, hazeColor),
            ColorSequenceKeypoint.new(0.26, hazeColor),
            ColorSequenceKeypoint.new(0.64, hazeColor),
            ColorSequenceKeypoint.new(1, hazeColor),
        })
        shimmer.Transparency = NumberSequence.new({
            NumberSequenceKeypoint.new(0, 0.48),
            NumberSequenceKeypoint.new(0.5, 0.7),
            NumberSequenceKeypoint.new(1, 0.48),
        })
    end

    local gloss = haze:FindFirstChild("GlassGloss")
    if gloss and gloss:IsA("Frame") then
        gloss.Visible = false
        gloss.BackgroundColor3 = shiftColor(hazeColor, 44)
        gloss.BackgroundTransparency = 1
        local glossGradient = gloss:FindFirstChild("GlossGradient")
        if glossGradient and glossGradient:IsA("UIGradient") then
            glossGradient.Color = ColorSequence.new({
                ColorSequenceKeypoint.new(0, shiftColor(hazeColor, 64)),
                ColorSequenceKeypoint.new(1, shiftColor(hazeColor, 28)),
            })
            glossGradient.Transparency = NumberSequence.new({
                NumberSequenceKeypoint.new(0, 1),
                NumberSequenceKeypoint.new(0.6, 1),
                NumberSequenceKeypoint.new(1, 1),
            })
        end
    end
end

applyThemeColors = function(newMainColor, newSecondaryColor, newTextColor, themeName, themeSource)
    mainColor = newMainColor
    secondaryColor = newSecondaryColor
    textColor = newTextColor
    local allowPresetButtonsColorUpdate = themeSource ~= "preset"

    local panelColor = shiftColor(mainColor, 12)
    local trackColor = shiftColor(mainColor, 20)
    local sidebarColor = shiftColor(mainColor, 4)
    local liquidTop = shiftColor(mainColor, 20)
    local liquidBottom = shiftColor(mainColor, -6)

    activeThemeMainColor = mainColor
    activeThemeSecondaryColor = secondaryColor
    activeThemeTextColor = textColor
    activeThemePanelColor = panelColor

    inactiveTabIconColor = shiftColor(textColor, -55)
    selectedTabIconColor = secondaryColor

    MainFrame.BackgroundColor3 = mainColor
    MainFrame.BackgroundTransparency = currentMainUiTransparency
    AuthFrame.BackgroundColor3 = mainColor
    AuthFrame.BackgroundTransparency = AUTH_FRAME_GLASS_TRANSPARENCY
    MainFrameStroke.Color = secondaryColor
    MainFrameStroke.Thickness = 2
    MainFrameStroke.Transparency = 0
    AuthFrameStroke.Color = secondaryColor
    AuthFrameStroke.Thickness = 2
    AuthFrameStroke.Transparency = 0
    Sidebar.BackgroundColor3 = sidebarColor
    Sidebar.BackgroundTransparency = SIDEBAR_GLASS_TRANSPARENCY
    Notification.BackgroundColor3 = sidebarColor
    Notification.BackgroundTransparency = 0.06
    TouchToggleButton.BackgroundColor3 = secondaryColor
    TouchToggleButton.BackgroundTransparency = 0.05
    if mainFrameCollapseButton then
        mainFrameCollapseButton.BackgroundColor3 = secondaryColor
        mainFrameCollapseButton.TextColor3 = textColor
        mainFrameCollapseButton.BackgroundTransparency = 0.12
    end
