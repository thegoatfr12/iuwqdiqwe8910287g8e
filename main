local keyCodeLookupByName = {}
for _, keyCode in ipairs(Enum.KeyCode:GetEnumItems()) do
    keyCodeLookupByName[string.upper(keyCode.Name)] = keyCode
end

local keyCodeAliasByName = {
    ["CTRL"] = "LEFTCONTROL",
    ["CONTROL"] = "LEFTCONTROL",
    ["LCTRL"] = "LEFTCONTROL",
    ["RCTRL"] = "RIGHTCONTROL",
    ["SHIFT"] = "LEFTSHIFT",
    ["LSHIFT"] = "LEFTSHIFT",
    ["RSHIFT"] = "RIGHTSHIFT",
    ["ALT"] = "LEFTALT",
    ["LALT"] = "LEFTALT",
    ["RALT"] = "RIGHTALT",
    ["CMD"] = "LEFTSUPER",
    ["COMMAND"] = "LEFTSUPER",
    ["WIN"] = "LEFTSUPER",
    ["WINDOWS"] = "LEFTSUPER",
    ["META"] = "LEFTSUPER",
    ["ESC"] = "ESCAPE",
    ["RETURN"] = "ENTER",
    ["DEL"] = "DELETE",
    ["BACK"] = "BACKSPACE",
    ["0"] = "ZERO",
    ["1"] = "ONE",
    ["2"] = "TWO",
    ["3"] = "THREE",
    ["4"] = "FOUR",
    ["5"] = "FIVE",
    ["6"] = "SIX",
    ["7"] = "SEVEN",
    ["8"] = "EIGHT",
    ["9"] = "NINE",
}

local function parseKeyCodeFromText(rawText)
    local normalized = string.upper(tostring(rawText or ""))
    normalized = normalized:gsub("%s+", "")
    normalized = normalized:gsub("^ENUM%.KEYCODE%.", "")
    normalized = normalized:gsub("^KEYCODE%.", "")
    if normalized == "" then
        return nil
    end

    if keyCodeAliasByName[normalized] then
        normalized = keyCodeAliasByName[normalized]
    end

    local keyCode = keyCodeLookupByName[normalized]
    if keyCode then
        return keyCode
    end

    return nil
end

local function stompPosToValue(px)
    if not stompSlider.Bar then
        return STOMP_MIN
    end

    local absX = stompSlider.Bar.AbsolutePosition.X
    local w = stompSlider.Bar.AbsoluteSize.X
    local rel = math.clamp((px - absX) / math.max(w, 1), 0, 1)
    local raw = STOMP_MIN + (STOMP_MAX - STOMP_MIN) * rel
    return math.clamp(math.floor(raw * 100) / 100, STOMP_MIN, STOMP_MAX)
end

