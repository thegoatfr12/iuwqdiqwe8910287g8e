local function updateAffectedPlayersCountText()
    if not affectedPlayersBox then
        return
    end

    local localPlayerRef = Players.LocalPlayer
    local affectedCount = 0
    if hitboxEnabled then
        if type(whitelist) == "table" then
            for playerRef, isAffected in pairs(whitelist) do
                if isAffected and playerRef and playerRef ~= localPlayerRef then
                    affectedCount = affectedCount + 1
                end
            end
        else
            affectedCount = #Players:GetPlayers()
            if localPlayerRef then
                affectedCount = affectedCount - 1
            end
            affectedCount = math.max(affectedCount, 0)
        end
    end

    local statusText = hitboxEnabled and "Active" or "Inactive"
    affectedPlayersBox.Text = "Status: " .. statusText .. " - " .. tostring(affectedCount) .. " affected players"
    affectedPlayersBox.TextColor3 = hitboxEnabled and activeThemeSecondaryColor or activeThemeTextColor
    affectedPlayersBox.BackgroundTransparency = currentMainUiTransparency
end

updateAffectedPlayersCountText()

if affectedPlayersCountConnAdded then
    affectedPlayersCountConnAdded:Disconnect()
    affectedPlayersCountConnAdded = nil
end
if affectedPlayersCountConnRemoving then
    affectedPlayersCountConnRemoving:Disconnect()
    affectedPlayersCountConnRemoving = nil
end

affectedPlayersCountConnAdded = Players.PlayerAdded:Connect(function()
    if scriptUnloaded then
        return
    end
    task.defer(updateAffectedPlayersCountText)
end)

affectedPlayersCountConnRemoving = Players.PlayerRemoving:Connect(function()
    task.defer(updateAffectedPlayersCountText)
end)

