local function buildIdentitySummary()
    local playerName = tostring(LocalPlayer.DisplayName or LocalPlayer.Name or "Unknown")
    local userId = tostring(LocalPlayer.UserId or "Unknown")

    return "Player: " .. playerName .. "\nPlayer ID: " .. userId
end

function isNoBounceModeCollisionActive()
    return noBounceModeEnabled and tick() < (noBounceModeExpireAt or 0)
end

function refreshNoBounceModeWindow()
    if not noBounceModeEnabled then
        return
    end

    noBounceModeExpireAt = tick() + noBounceModeWindowSeconds
    if not noBounceModeCollisionApplied then
        noBounceModeCollisionApplied = true
        pcall(UpdatePlayers)
    end
end

function syncNoBounceModeWindow()
    local activeNow = isNoBounceModeCollisionActive()
    if activeNow ~= noBounceModeCollisionApplied then
        noBounceModeCollisionApplied = activeNow
        pcall(UpdatePlayers)
    end
end

local function writeBootTrace(text)
    appendBootTrace(text)
end

local function safeConnect(signal, handler, label)
    local ok, connectionOrError = pcall(function()
        return signal:Connect(handler)
    end)

    if not ok then
        writeBootTrace("connect failed: " .. tostring(label) .. " | " .. tostring(connectionOrError))
        return nil
    end

    return connectionOrError
end

local function trimStatusText(text, maxLength)
    local value = tostring(text or "")
    local limit = maxLength or 90
    if #value <= limit then
        return value
    end

    return value:sub(1, limit - 3) .. "..."
end

local function updateBootstrapStatus(text, isError)
    local message = trimStatusText(text, 110)
    if bootstrapStatusLabel then
        bootstrapStatusLabel.Text = message
        bootstrapStatusLabel.TextColor3 = isError and Color3.fromRGB(255, 170, 170) or Color3.fromRGB(255, 255, 255)
        bootstrapStatusLabel.BackgroundColor3 = isError and Color3.fromRGB(85, 20, 20) or Color3.fromRGB(18, 18, 18)
        bootstrapStatusLabel.Visible = true
    end

    if TOP_NOTIFICATIONS_ENABLED then
        pcall(function()
            StarterGui:SetCore("SendNotification", {
                Title = LUA_NAME,
                Text = message,
                Duration = isError and 6 or 3,
            })
        end)
    end
end

local function hideBootstrapStatus(delaySeconds)
    task.delay(delaySeconds or 8, function()
        if bootstrapStatusLabel then
            bootstrapStatusLabel.Visible = false
        end
        if earlyStatusGui then
            earlyStatusGui:Destroy()
            earlyStatusGui = nil
        end
        if preflightGui then
            preflightGui:Destroy()
            preflightGui = nil
        end
    end)
end

writeBootTrace("script entered")
writeBootTrace("local player resolved")

local function connectButton(button, callback)
    local function freeModeAllowsButtonInteraction()
        return not (type(freeModeShouldBlockControl) == "function" and freeModeShouldBlockControl(button, true))
    end

    local function guardedCallback(...)
        if not freeModeAllowsButtonInteraction() then
            return
        end

        callback(...)
    end

    local activatedConnected = pcall(function()
        button.Activated:Connect(guardedCallback)
    end)

    if activatedConnected then
        return
    end

    button.MouseButton1Click:Connect(guardedCallback)
end

local function playTween(instance, tweenInfo, properties)
    local tween = TweenService:Create(instance, tweenInfo, properties)
    tween:Play()
    return tween
end

local function sendCoreNotification(text, duration)
    if not TOP_NOTIFICATIONS_ENABLED then
        return
    end

    pcall(function()
        StarterGui:SetCore("SendNotification", {
            Title = LUA_NAME,
            Text = text,
            Duration = duration or 4,
        })
    end)
end

local function keyAuthRequest(params)
    local encoded = {}
    for key, value in pairs(params) do
        table.insert(encoded, HttpService:UrlEncode(key) .. "=" .. HttpService:UrlEncode(tostring(value)))
    end

    table.sort(encoded)

    local success, response = pcall(function()
        return game:HttpGet(KEYAUTH_API_URL .. "?" .. table.concat(encoded, "&"))
    end)

    if not success then
        return false, "HTTP request failed"
    end

    if response == "KeyAuth_Invalid" then
        return false, "Application not found"
    end

    local decodeOk, data = pcall(function()
        return HttpService:JSONDecode(response)
    end)

    if not decodeOk or type(data) ~= "table" then
        return false, "Invalid API response"
    end

    if data.success then
        return true, data
    end

    return false, data.message or "Request failed"
end

local function initializeKeyAuth()
    if keyAuthInitialized then
        return true
    end

    if keyAuthAppName == "" or keyAuthOwnerId == "" then
        return false, "Set KeyAuth app name and owner id first"
    end

    local ok, dataOrMessage = keyAuthRequest({
        type = "init",
        name = keyAuthAppName,
        ownerid = keyAuthOwnerId,
        ver = APP_VERSION,
    })

    if not ok then
        return false, dataOrMessage
    end

    keyAuthSessionId = dataOrMessage.sessionid or ""
    keyAuthInitialized = keyAuthSessionId ~= ""
    if not keyAuthInitialized then
        return false, "Missing session id"
    end

    return true, dataOrMessage
end

local function getHardwareId()
    if type(gethwid) == "function" then
        local ok, hwid = pcall(gethwid)
        if ok and type(hwid) == "string" and hwid ~= "" then
            return hwid
        end
    end

    local ok, clientId = pcall(function()
        return RbxAnalyticsService:GetClientId()
    end)
    if ok and type(clientId) == "string" and clientId ~= "" then
        return clientId
    end

    return nil
end

refreshIdentityInfo = function()
    setRuntimeInfoText(buildIdentitySummary())
end

refreshIdentityInfo()

local function isTruthyFlag(value)
    if value == true then
        return true
    end

    if type(value) == "string" then
        local normalized = value:lower()
        return normalized == "true" or normalized == "1" or normalized == "yes" or normalized == "banned"
    end

    if type(value) == "number" then
        return value ~= 0
    end

    return false
end

local function getBanReason(data)
    if type(data) ~= "table" then
        return nil
    end

    if isTruthyFlag(data.banned) or isTruthyFlag(data.isBanned) then
        return data.message or "Key is banned"
    end

    local info = data.info
    if type(info) == "table" then
        if isTruthyFlag(info.banned) or isTruthyFlag(info.isBanned) or isTruthyFlag(info.blacklisted) then
            return data.message or info.message or "Key is banned"
        end

        if type(info.status) == "string" and info.status:lower() == "banned" then
            return data.message or info.message or "Key is banned"
        end
    end

    if type(data.message) == "string" then
        local normalizedMessage = data.message:lower()
        if normalizedMessage:find("banned", 1, true) or normalizedMessage:find("blacklisted", 1, true) then
            return data.message
        end
    end

    return nil
end

local function authorizeWithKeyAuth(licenseKey)
    local initOk, initDataOrMessage = initializeKeyAuth()
    if not initOk then
        return false, initDataOrMessage
    end

    local hardwareId = getHardwareId()
    if not hardwareId then
        return false, "Unable to determine device HWID"
    end

    local ok, dataOrMessage = keyAuthRequest({
        type = "license",
        name = keyAuthAppName,
        ownerid = keyAuthOwnerId,
        key = licenseKey,
        hwid = hardwareId,
        ver = APP_VERSION,
        sessionid = keyAuthSessionId,
    })

    if not ok then
        return false, dataOrMessage
    end

    local banReason = getBanReason(dataOrMessage)
    if banReason then
        return false, banReason
    end

    return true, dataOrMessage
end

local function canUseAuthCache()
    return type(readfile) == "function"
        and type(writefile) == "function"
        and type(isfile) == "function"
end

local function ensureAuthCacheFolder()
    if type(makefolder) == "function" and type(isfolder) == "function" and not isfolder(AUTH_CACHE_FOLDER) then
        pcall(makefolder, AUTH_CACHE_FOLDER)
    end
end

local function loadCachedLicenseKey()
    if not canUseAuthCache() or not isfile(AUTH_CACHE_FILE) then
        return nil
    end

    local ok, contents = pcall(readfile, AUTH_CACHE_FILE)
    if not ok or not contents or contents == "" then
        return nil
    end

    local decodeOk, data = pcall(function()
        return HttpService:JSONDecode(contents)
    end)

    if not decodeOk or type(data) ~= "table" or type(data.licenseKey) ~= "string" or data.licenseKey == "" then
        return nil
    end

    local currentHardwareId = getHardwareId()
    if data.hwid and currentHardwareId and data.hwid ~= currentHardwareId then
        return nil
    end

    return data.licenseKey
end

local function cacheLicenseKey(licenseKey)
    if not canUseAuthCache() or type(licenseKey) ~= "string" or licenseKey == "" then
        return false
    end

    ensureAuthCacheFolder()

    local ok = pcall(function()
        local hardwareId = getHardwareId()
        writefile(AUTH_CACHE_FILE, HttpService:JSONEncode({
            licenseKey = licenseKey,
            hwid = hardwareId,
            updatedAt = os.time(),
        }))
    end)

    return ok
end

local function clearCachedLicenseKey()
    if type(delfile) == "function" and type(isfile) == "function" and isfile(AUTH_CACHE_FILE) then
        pcall(delfile, AUTH_CACHE_FILE)
    end
end

local function loadPersistedSettingsData()
    if not canUseAuthCache() or not isfile(SETTINGS_CACHE_FILE) then
        return nil
    end

    local ok, contents = pcall(readfile, SETTINGS_CACHE_FILE)
    if not ok or not contents or contents == "" then
        return nil
    end

    local decodeOk, data = pcall(function()
        return HttpService:JSONDecode(contents)
    end)

    if not decodeOk or type(data) ~= "table" then
        return nil
    end

    return data
end

local function persistSettingsData(data)
    if not canUseAuthCache() or type(data) ~= "table" then
        return false
    end

    ensureAuthCacheFolder()

    local ok = pcall(function()
        writefile(SETTINGS_CACHE_FILE, HttpService:JSONEncode(data))
    end)

    return ok
end

local function setCachedTransparency(instance, hidden)
    if not instance then
        return
    end

    if hidden then
        if headTransparencyCache[instance] == nil then
            headTransparencyCache[instance] = instance.Transparency
        end
        instance.Transparency = 1
        return
    end

    local originalTransparency = headTransparencyCache[instance]
    if originalTransparency ~= nil then
        instance.Transparency = originalTransparency
        headTransparencyCache[instance] = nil
    end
end

local function applyLocalHeadPartVisibility(character)
    local activeCharacter = character or LocalPlayer.Character
    if not activeCharacter then return end

    local head = activeCharacter:FindFirstChild("Head")
    if head and head:IsA("BasePart") then
        head.LocalTransparencyModifier = headHidden and 1 or 0
    end
end

local function applyLocalHeadFaceVisibility(character)
    local activeCharacter = character or LocalPlayer.Character
    if not activeCharacter then
        return
    end

    local head = activeCharacter:FindFirstChild("Head")
    if not head then
        return
    end

    applyLocalHeadPartVisibility(activeCharacter)

    for _, descendant in ipairs(head:GetDescendants()) do
        if descendant:IsA("Decal") or descendant:IsA("Texture") then
            setCachedTransparency(descendant, headHidden)
        end
    end
end

local function restoreAccessoryVisibility(character)
    local activeCharacter = character or LocalPlayer.Character
    if not activeCharacter then
        return
    end

    for _, child in ipairs(activeCharacter:GetChildren()) do
        if child:IsA("Accessory") then
            local handle = child:FindFirstChild("Handle")
            if handle and handle:IsA("BasePart") then
                setCachedTransparency(handle, false)
            end

            for _, descendant in ipairs(child:GetDescendants()) do
                if descendant:IsA("Decal") or descendant:IsA("Texture") then
                    setCachedTransparency(descendant, false)
                elseif descendant:IsA("BasePart") then
                    setCachedTransparency(descendant, false)
                end
            end
        end
    end
end

local function applyLocalHeadVisibility(character)
    local activeCharacter = character or LocalPlayer.Character
    if not activeCharacter then return end

    applyLocalHeadFaceVisibility(activeCharacter)

    restoreAccessoryVisibility(activeCharacter)
end

local function applyLocalRootVisibility(character)
    local activeCharacter = character or LocalPlayer.Character
    if not activeCharacter then return end

    local rootPart = activeCharacter:FindFirstChild("HumanoidRootPart")
    if rootPart and rootPart:IsA("BasePart") then
        rootPart.LocalTransparencyModifier = 1
    end
end

local function getLocalHumanoid()
    local activeCharacter = LocalPlayer.Character
    if not activeCharacter then
        return nil
    end

    return activeCharacter:FindFirstChildOfClass("Humanoid")
end

do
    local humanoid = getLocalHumanoid()
    if humanoid then
        defaultWalkSpeed = humanoid.WalkSpeed
    end
end

local ROOT_VISIBILITY_REFRESH_INTERVAL = 1
local nextRootVisibilityRefreshAt = 0
headVisibilityDescendantConn = nil
headVisibilityCharacterConn = nil
headVisibilityCharacterRemovedConn = nil

function refreshHeadVisibilityHook(character)
    if headVisibilityDescendantConn then
        headVisibilityDescendantConn:Disconnect()
        headVisibilityDescendantConn = nil
    end

    if headVisibilityCharacterConn then
        headVisibilityCharacterConn:Disconnect()
        headVisibilityCharacterConn = nil
    end

    if headVisibilityCharacterRemovedConn then
        headVisibilityCharacterRemovedConn:Disconnect()
        headVisibilityCharacterRemovedConn = nil
    end

    if not headHidden then
        return
    end

    local activeCharacter = character or LocalPlayer.Character
    if not activeCharacter then
        return
    end

    local head = activeCharacter:FindFirstChild("Head")
    if not head then
        return
    end

    headVisibilityDescendantConn = safeConnect(head.DescendantAdded, function(descendant)
        if descendant:IsA("Decal") or descendant:IsA("Texture") then
            setCachedTransparency(descendant, true)
        end
    end, "Head.DescendantAdded")

    headVisibilityCharacterConn = safeConnect(activeCharacter.ChildAdded, function(child)
        if not headHidden then
            return
        end

        if child:IsA("Tool") or child.Name == "Head" then
            applyLocalHeadVisibility(activeCharacter)
            task.defer(function()
                applyLocalHeadVisibility(activeCharacter)
            end)

            if child.Name == "Head" then
                task.defer(function()
                    refreshHeadVisibilityHook(activeCharacter)
                end)
            end
        end
    end, "Character.ChildAdded")

    headVisibilityCharacterRemovedConn = safeConnect(activeCharacter.ChildRemoved, function(child)
        if not headHidden then
            return
        end

        if child:IsA("Tool") then
            applyLocalHeadVisibility(activeCharacter)
            task.defer(function()
                applyLocalHeadVisibility(activeCharacter)
            end)
        end
    end, "Character.ChildRemoved")
end

safeConnect(LocalPlayer.CharacterAdded, function(character)
    task.defer(function()
        applyLocalHeadVisibility(character)
        refreshHeadVisibilityHook(character)
        applyLocalRootVisibility(character)
        local humanoid = getLocalHumanoid()
        if humanoid then
            if loopWalkSpeedEnabled then
                humanoid.WalkSpeed = currentWalkSpeed
            else
                defaultWalkSpeed = humanoid.WalkSpeed
            end
        end
    end)
end, "LocalPlayer.CharacterAdded")

safeConnect(LocalPlayer.CharacterAppearanceLoaded, function(character)
    task.defer(function()
        applyLocalHeadVisibility(character)
        refreshHeadVisibilityHook(character)
        applyLocalRootVisibility(character)
        local humanoid = getLocalHumanoid()
        if humanoid and loopWalkSpeedEnabled then
            humanoid.WalkSpeed = currentWalkSpeed
        end
    end)
end, "LocalPlayer.CharacterAppearanceLoaded")

safeConnect(RunService.RenderStepped, function()
    local now = os.clock()

    if headHidden then
        applyLocalHeadFaceVisibility()
    end

    if now >= nextRootVisibilityRefreshAt then
        applyLocalRootVisibility()
        nextRootVisibilityRefreshAt = now + ROOT_VISIBILITY_REFRESH_INTERVAL
    end

    if loopWalkSpeedEnabled then
        local humanoid = getLocalHumanoid()
        if humanoid and humanoid.WalkSpeed ~= currentWalkSpeed then
            humanoid.WalkSpeed = currentWalkSpeed
        end
    end
end, "RunService.RenderStepped")

writeBootTrace("local visibility hooks ready")

local function setTeleportButtonsBusy(isBusy)
    local isEnabled = not isBusy
    local transparency = isBusy and 0.35 or 0

    if teleportToProButton then
        teleportToProButton.Active = isEnabled
        teleportToProButton.AutoButtonColor = isEnabled
        teleportToProButton.BackgroundTransparency = transparency
    end
    if teleportToVcButton then
        teleportToVcButton.Active = isEnabled
        teleportToVcButton.AutoButtonColor = isEnabled
        teleportToVcButton.BackgroundTransparency = transparency
    end
    if rejoinButton then
        rejoinButton.Active = isEnabled
        rejoinButton.AutoButtonColor = isEnabled
        rejoinButton.BackgroundTransparency = transparency
    end
end

teleportRequestToken = teleportRequestToken or 0
teleportStartedFlag = teleportStartedFlag or false
teleportLastRequestedPlaceId = teleportLastRequestedPlaceId or nil

function beginTeleport(label, placeId, serverId)
    if teleportInProgress then
        showStatus("Teleport already in progress.", true)
        return false
    end

    if type(placeId) ~= "number" then
        showStatus("Teleport failed: invalid destination place ID.", true)
        return false
    end

    teleportInProgress = true
    teleportRequestToken = teleportRequestToken + 1
    local requestToken = teleportRequestToken
    teleportStartedFlag = false
    teleportLastRequestedPlaceId = placeId
    teleportFallbackPlaceId = placeId
    teleportFallbackLabel = label
    teleportFallbackAttempted = serverId == nil
    setTeleportButtonsBusy(true)
    showStatus("Teleporting to " .. label .. "...", false)
    writeBootTrace("teleport begin | label=" .. tostring(label) .. " | placeId=" .. tostring(placeId) .. " | serverId=" .. tostring(serverId))

    task.delay(3, function()
        if not teleportInProgress or requestToken ~= teleportRequestToken or teleportStartedFlag then
            return
        end

        writeBootTrace("mobile teleport watchdog retry | label=" .. tostring(label) .. " | placeId=" .. tostring(placeId))
        local retryOk, retryErr = pcall(function()
            TeleportService:Teleport(placeId)
        end)

        if not retryOk then
            writeBootTrace("mobile teleport watchdog retry failed | " .. tostring(retryErr))
        end
    end)

    task.delay(10, function()
        if not teleportInProgress or requestToken ~= teleportRequestToken then
            return
        end

        teleportInProgress = false
        teleportStartedFlag = false
        setTeleportButtonsBusy(false)
        showStatus("Teleport timeout. Please try again.", true)
        writeBootTrace("teleport timeout | label=" .. tostring(label) .. " | placeId=" .. tostring(placeId))
    end)

    local mobileDirectTeleport = UserInputService.TouchEnabled
    if mobileDirectTeleport then
        writeBootTrace("mobile direct teleport mode active")
    end

    local ok, err
    if RunService:IsClient() then
        if serverId and (not mobileDirectTeleport) then
            ok, err = pcall(function()
                TeleportService:TeleportToPlaceInstance(placeId, tostring(serverId))
            end)
        end

        if not ok then
            ok, err = pcall(function()
                TeleportService:Teleport(placeId)
            end)
        end
    else
        if serverId and (not mobileDirectTeleport) then
            ok, err = pcall(function()
                local options = Instance.new("TeleportOptions")
                options.ServerInstanceId = tostring(serverId)
                TeleportService:TeleportAsync(placeId, {LocalPlayer}, options)
            end)

            if not ok then
                ok, err = pcall(function()
                    TeleportService:TeleportToPlaceInstance(placeId, tostring(serverId), LocalPlayer)
                end)
            end
        else
            ok, err = pcall(function()
                TeleportService:Teleport(placeId, LocalPlayer)
            end)

            if not ok then
                ok, err = pcall(function()
                    TeleportService:TeleportAsync(placeId, {LocalPlayer})
                end)
            end
        end
    end

    if ok then
        writeBootTrace("teleport request accepted | label=" .. tostring(label))
        return true
    end

    teleportInProgress = false
    setTeleportButtonsBusy(false)
    showStatus("Teleport failed: " .. tostring(err), true)
    writeBootTrace("teleport request failed | " .. tostring(err))
    return false
end

function teleportToRandomPublicServer(placeId, label)
    if UserInputService.TouchEnabled and (not UserInputService.KeyboardEnabled) then
        writeBootTrace("mobile path: skipping public server lookup")
        beginTeleport(label, placeId, nil)
        return
    end

    local availableServers = {}
    local success, result = pcall(function()
        return HttpService:JSONDecode(game:HttpGet("https://games.roblox.com/v1/games/" .. placeId .. "/servers/Public?sortOrder=Asc&limit=100"))
    end)

    if success and result and result.data then
        for _, server in ipairs(result.data) do
            if server.playing < server.maxPlayers and server.id ~= game.JobId then
                table.insert(availableServers, server.id)
            end
        end
    end

    if #availableServers > 0 then
        local serverId = availableServers[math.random(1, #availableServers)]
        if beginTeleport(label, placeId, serverId) then
            return
        end
    end

    beginTeleport(label, placeId, nil)
end

function rejoinCurrentServer()
    local currentPlayerCount = #Players:GetPlayers()
    if currentPlayerCount > 1 then
        if beginTeleport("current server", game.PlaceId, game.JobId) then
            return
        end
    end

    beginTeleport("current place", game.PlaceId, nil)
end

safeConnect(TeleportService.TeleportInitFailed, function(failedPlayer, teleportResult, errorMessage, placeId)
    if not teleportInProgress then
        return
    end

    if failedPlayer and failedPlayer ~= LocalPlayer then
        return
    end

    teleportInProgress = false
    teleportStartedFlag = false
    teleportRequestToken = teleportRequestToken + 1
    setTeleportButtonsBusy(false)
    writeBootTrace("TeleportInitFailed | result=" .. tostring(teleportResult) .. " | msg=" .. tostring(errorMessage) .. " | placeId=" .. tostring(placeId))

    if placeId == teleportFallbackPlaceId and not teleportFallbackAttempted then
        teleportFallbackAttempted = true
        showStatus("Specific server failed. Trying default teleport...", true)
        task.defer(function()
            beginTeleport(teleportFallbackLabel or "destination", placeId, nil)
        end)
        return
    end

    local reason = errorMessage
    if reason == nil or reason == "" then
        reason = tostring(teleportResult)
    end
    showStatus("Teleport failed: " .. tostring(reason), true)
end, "TeleportService.TeleportInitFailed")

safeConnect(LocalPlayer.OnTeleport, function(state, placeId)
    local stateName = tostring(state)
    writeBootTrace("OnTeleport | state=" .. stateName .. " | placeId=" .. tostring(placeId))

    if state == Enum.TeleportState.Started or stateName:find("Started", 1, true) or stateName:find("InProgress", 1, true) then
        teleportStartedFlag = true
        return
    end

    if not teleportInProgress then
        return
    end

    if state == Enum.TeleportState.Failed or stateName:find("Failed", 1, true) or stateName:find("Cancelled", 1, true) then
        teleportInProgress = false
        teleportStartedFlag = false
        teleportRequestToken = teleportRequestToken + 1
        setTeleportButtonsBusy(false)
        showStatus("Teleport failed (" .. stateName .. ").", true)
    end
end, "LocalPlayer.OnTeleport")

