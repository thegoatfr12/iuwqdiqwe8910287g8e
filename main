connectButton(loopWalkSpeedToggle, function()
    loopWalkSpeedEnabled = not loopWalkSpeedEnabled
    setToggleSwitchState(loopWalkSpeedToggle, loopWalkSpeedToggleKnob, loopWalkSpeedEnabled, true)

    local humanoid = getLocalHumanoid()
    if humanoid then
        if loopWalkSpeedEnabled then
            humanoid.WalkSpeed = currentWalkSpeed
        else
            humanoid.WalkSpeed = defaultWalkSpeed
        end
    end
end)

walkSpeedBox.FocusLost:Connect(function()
    if freeModeShouldBlockControl(walkSpeedBox, true) then
        walkSpeedBox.Text = tostring(currentWalkSpeed)
        return
    end

    local walkSpeedValue = tonumber(walkSpeedBox.Text)
    if walkSpeedValue then
        currentWalkSpeed = math.clamp(math.floor(walkSpeedValue * 100) / 100, 0, 300)
        walkSpeedBox.Text = tostring(currentWalkSpeed)
        if loopWalkSpeedEnabled then
            local humanoid = getLocalHumanoid()
            if humanoid then
                humanoid.WalkSpeed = currentWalkSpeed
            end
        end
    else
        walkSpeedBox.Text = tostring(currentWalkSpeed)
    end
end)

