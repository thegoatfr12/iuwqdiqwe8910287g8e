    local settingsData = persisted
    if type(persisted.SavedSettings) == "table" then
        settingsData = persisted.SavedSettings
    elseif type(settingsData) ~= "table" then
        settingsData = {}
        persisted = {SavedSettings = settingsData}
    end

    settingsData.StretchResEnabled = stretchResEnabled
    settingsData.StretchResValue = STRETCH_RESOLUTION
    persistSettingsData(persisted)
end

function persistStartupAnimationSetting()
    local persisted = loadPersistedSettingsData() or {}
    local settingsData = persisted
    if type(persisted.SavedSettings) == "table" then
        settingsData = persisted.SavedSettings
    elseif type(settingsData) ~= "table" then
        settingsData = {}
        persisted = {SavedSettings = settingsData}
    end

    settingsData.StartupCinematicEnabled = STARTUP_CINEMATIC_ENABLED
    persistSettingsData(persisted)
end

function toggleStartupAnimationSetting(animate)
    STARTUP_CINEMATIC_ENABLED = not STARTUP_CINEMATIC_ENABLED
    if startupAnimationToggle and startupAnimationToggleKnob then
        setToggleSwitchState(startupAnimationToggle, startupAnimationToggleKnob, STARTUP_CINEMATIC_ENABLED, animate)
    end

    showStatus(STARTUP_CINEMATIC_ENABLED and "Startup animation enabled (applies next execute)." or "Startup animation disabled (applies next execute).", false)
    persistStartupAnimationSetting()
end

