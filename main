local quickHudEnabled = false
do
    local persisted = loadPersistedSettingsData() or {}
    local settingsData = persisted
    if type(persisted.SavedSettings) == "table" then
        settingsData = persisted.SavedSettings
    end
    if type(settingsData) == "table" and settingsData.QuickHudEnabled ~= nil then
        quickHudEnabled = settingsData.QuickHudEnabled and true or false
    end
    if type(settingsData) == "table" and settingsData.StretchResValue ~= nil then
        local parsedStretchResValue = tonumber(settingsData.StretchResValue)
        if parsedStretchResValue then
            STRETCH_RESOLUTION = math.clamp(parsedStretchResValue, STRETCH_RESOLUTION_MIN, STRETCH_RESOLUTION_MAX)
        end
    end
    if type(settingsData) == "table" and settingsData.LookSensitivityEnabled ~= nil then
        lookSensitivityEnabled = settingsData.LookSensitivityEnabled and true or false
    end
end
