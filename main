    settingsPnListLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center
    settingsPnListLayout.SortOrder = Enum.SortOrder.LayoutOrder

    settingsPnEntries = {
        {date = "2026-04-18", title = "fixed mobile ui bug", details = ""},
        {date = "2026-04-17", title = "UI re organized", details = ""},
