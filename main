guiSpawnDropdownOptions = {
    "Center",
    "Top Left",
    "Top Right",
    "Bottom Left",
    "Bottom Right",
}
guiSpawnDropdownOpen = false
guiSpawnDropdownAnimating = false

local function persistGuiSpawnPositionSelection()
    local persisted = loadPersistedSettingsData() or {}
    local settingsData = persisted
    if type(persisted.SavedSettings) == "table" then
        settingsData = persisted.SavedSettings
    elseif type(settingsData) ~= "table" then
        settingsData = {}
        persisted = {SavedSettings = settingsData}
    end

    settingsData.GuiSpawnPosition = GUI_SPAWN_POSITION_MODE
    persistSettingsData(persisted)
end

local function setGuiSpawnDropdownOpen(isOpen)
    if guiSpawnDropdownAnimating then
        return
    end

    if guiSpawnDropdownOpen == isOpen then
        return
    end

    guiSpawnDropdownOpen = isOpen
    guiSpawnDropdownAnimating = true

    if isOpen then
        guiSpawnDropdownFrame.Visible = true
    end

    local targetHeight = isOpen and (#guiSpawnDropdownOptions * 26) or 0
    playTween(
        guiSpawnDropdownFrame,
        TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
        {
            Size = UDim2.new(0, 140, 0, targetHeight),
            BackgroundTransparency = isOpen and AUTH_SURFACE_GLASS_TRANSPARENCY or 1,
        }
    )

    task.delay(0.22, function()
        guiSpawnDropdownAnimating = false
        if not guiSpawnDropdownOpen then
            guiSpawnDropdownFrame.Visible = false
        end
    end)
end

for index, optionLabel in ipairs(guiSpawnDropdownOptions) do
    local optionButton = Instance.new("TextButton", guiSpawnDropdownFrame)
    optionButton.Size = UDim2.new(1, -8, 0, 24)
    optionButton.Position = UDim2.new(0, 4, 0, (index - 1) * 26 + 1)
    optionButton.BackgroundColor3 = Color3.fromRGB(44, 44, 44)
    optionButton.BackgroundTransparency = 0.08
    optionButton.BorderSizePixel = 0
    optionButton.Text = optionLabel
    optionButton.TextColor3 = Color3.fromRGB(235, 235, 235)
    optionButton.Font = Enum.Font.Gotham
    optionButton.TextSize = 12
    optionButton.ZIndex = 12
    Instance.new("UICorner", optionButton).CornerRadius = UDim.new(0, 6)

    connectButton(optionButton, function()
        applyGuiSpawnPosition(optionLabel, true)
        persistGuiSpawnPositionSelection()
        showStatus("Startup position: " .. tostring(optionLabel) .. " (saved)", false)
        setGuiSpawnDropdownOpen(false)
    end)
end

connectButton(guiSpawnPositionButton, function()
    setGuiSpawnDropdownOpen(not guiSpawnDropdownOpen)
end)

