local function colorToRgbTuple(color)
    if typeof(color) ~= "Color3" then
        return nil, nil, nil
    end

    return math.floor(color.R * 255 + 0.5), math.floor(color.G * 255 + 0.5), math.floor(color.B * 255 + 0.5)
end

local function getReadableTextColorForBackground(backgroundColor)
    local r, g, b = colorToRgbTuple(backgroundColor)
    if not r or not g or not b then
        return Color3.fromRGB(245, 245, 245)
    end

    local luminance = (0.299 * r + 0.587 * g + 0.114 * b) / 255
    if luminance > 0.6 then
        return Color3.fromRGB(15, 15, 15)
    end

    return Color3.fromRGB(245, 245, 245)
end

local hitboxColorDropdownOptions = {}
for _, themeData in ipairs(themePresets) do
    local optionName = themeData.name
    local optionColor = themeData.secondary
    if themeData.name == "Liquid Black" then
        optionName = "Black"
        optionColor = Color3.fromRGB(0, 0, 0)
    elseif themeData.name == "Default" then
        optionName = "Red"
    end

    table.insert(hitboxColorDropdownOptions, {
        name = optionName,
        color = optionColor,
    })
end

local hitboxColorDropdownOpen = false
local hitboxColorDropdownAnimating = false

local function resolveHitboxColorPresetName(color)
    local r, g, b = colorToRgbTuple(color)
    if not r or not g or not b then
        return "Custom"
    end

    for _, option in ipairs(hitboxColorDropdownOptions) do
        local optionR, optionG, optionB = colorToRgbTuple(option.color)
        if optionR == r and optionG == g and optionB == b then
            return option.name
        end
    end

    return "Custom"
end

setHitboxColorControlState = function(color)
    if typeof(color) == "Color3" then
        HITBOX_TRANSPARENT_COLOR = color
    end

    if hitboxColorButton then
        hitboxColorButton.Text = resolveHitboxColorPresetName(HITBOX_TRANSPARENT_COLOR)
    end
end

