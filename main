        local function attachPresetButtonFeedback(button, normalTransparency)
            if not button then
                return
            end

            local idleTransparency = normalTransparency or 0.12
            local pressedTransparency = math.max(idleTransparency - 0.08, 0)
            local scale = button:FindFirstChild("PressScale")
            if not scale then
                scale = Instance.new("UIScale")
                scale.Name = "PressScale"
                scale.Scale = 1
                scale.Parent = button
            end

            local function setPressedVisual(isPressed)
                playTween(
                    button,
                    TweenInfo.new(0.08, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
                    {
                        BackgroundTransparency = isPressed and pressedTransparency or idleTransparency,
                    }
                )
                playTween(
                    scale,
                    TweenInfo.new(0.08, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
                    {
                        Scale = isPressed and 0.96 or 1,
                    }
                )
            end

            button.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                    setPressedVisual(true)
                end
            end)

            button.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                    setPressedVisual(false)
                end
            end)

            pcall(function()
                button.MouseLeave:Connect(function()
                    setPressedVisual(false)
                end)
            end)
        end

        attachPresetButtonFeedback(combatPresetCreateButton, 0.12)
