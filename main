local function spaceTabControls(tabFrame, startYOffset, growthFactor)
    if not tabFrame then
        return
    end

    for _, child in ipairs(tabFrame:GetChildren()) do
        if child:IsA("GuiObject") then
            local pos = child.Position
            if pos.Y.Scale == 0 and pos.Y.Offset >= startYOffset then
                local extra = math.floor((pos.Y.Offset - startYOffset) * growthFactor)
                child.Position = UDim2.new(pos.X.Scale, pos.X.Offset, pos.Y.Scale, pos.Y.Offset + extra)
            end
        end
    end
end

spaceTabControls(tabFrames["Combat"], 56, 0.06)
spaceTabControls(tabFrames["Settings"], 56, 0.06)
spaceTabControls(tabFrames["Customization"], 56, 0.06)
spaceTabControls(tabFrames["Socials"], 56, 0.06)

