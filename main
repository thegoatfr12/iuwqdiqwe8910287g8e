Sidebar.BackgroundColor3 = Color3.fromRGB(18, 18, 18)
Sidebar.BackgroundTransparency = SIDEBAR_GLASS_TRANSPARENCY
Sidebar.BorderSizePixel = 0
Sidebar.Parent = MainFrame
Instance.new("UICorner", Sidebar).CornerRadius = UDim.new(0, 10)

local function tryGetLucideIcon(iconName)
    local ok, iconData = pcall(function()
        if type(loadstring) ~= "function" then
            return nil
        end

        local moduleSource = game:HttpGet("https://raw.githubusercontent.com/deividcomsono/lucide-roblox-direct/refs/heads/main/source.lua")
        if type(moduleSource) ~= "string" or moduleSource == "" then
            return nil
        end

        local moduleChunk = loadstring(moduleSource)
        if type(moduleChunk) ~= "function" then
            return nil
        end

        local lucideModule = moduleChunk()
        if type(lucideModule) ~= "table" or type(lucideModule.GetAsset) ~= "function" then
            return nil
        end

        return lucideModule.GetAsset(iconName)
    end)

    if ok and type(iconData) == "table" and type(iconData.Url) == "string" then
        return iconData
    end

    return nil
end

-- Tab icon asset IDs (replace with your own if desired)
local tabIcons = {
    Combat = "rbxassetid://6031094670", -- Roblox UI sword icon (always visible)
    Settings = "rbxassetid://6031280882", -- gear icon
    Customization = "rbxassetid://6026568198", -- palette icon (represents customization)
    Socials = "rbxassetid://6031260782", -- fallback icon; upgraded to Lucide star icon below
}

-- Tab order
local tabList = {"Combat", "Settings", "Customization", "Socials"}

-- Tab buttons
local tabButtons = {}
local selectedTab = "Combat"
tabSwitchBusy = tabSwitchBusy or false

-- Calculate vertical positions for top, middle, bottom
local sidebarHeight = MAIN_FRAME_HEIGHT -- matches MainFrame height
local btnSize = 40
local margin = 30
local positions = {}
if #tabList <= 1 then
    positions[tabList[1]] = margin
else
    local spacing = (sidebarHeight - btnSize - (margin * 2)) / math.max(#tabList - 1, 1)
    for index, tabName in ipairs(tabList) do
        positions[tabName] = margin + math.floor((spacing * (index - 1)) + 0.5)
    end
end

for i, tabName in ipairs(tabList) do
    local btn = Instance.new("ImageButton")
    btn.Name = tabName .. "Tab"
    btn.Size = UDim2.new(0, btnSize, 0, btnSize)
    btn.Position = UDim2.new(0, 10, 0, positions[tabName])
    btn.BackgroundTransparency = 1
    btn.Image = tabIcons[tabName]

    btn.Parent = Sidebar
    tabButtons[tabName] = btn
end

-- Upgrade Combat icon to Lucide sword (same style as AddTab("Combat", "sword")).
task.spawn(function()
    local lucideSwordIcon = tryGetLucideIcon("sword")
    if not lucideSwordIcon then
        return
    end

    local combatButton = tabButtons and tabButtons.Combat
    if not combatButton or not combatButton.Parent then
        return
    end

    combatButton.Image = lucideSwordIcon.Url

    local rectSize = lucideSwordIcon.ImageRectSize
    local rectOffset = lucideSwordIcon.ImageRectOffset
    if rectSize and rectOffset and rectSize.X > 0 and rectSize.Y > 0 then
        combatButton.ImageRectOffset = rectOffset
        combatButton.ImageRectSize = rectSize
    else
        combatButton.ImageRectOffset = Vector2.new(0, 0)
        combatButton.ImageRectSize = Vector2.new(0, 0)
    end

    combatButton.ImageColor3 = (selectedTab == "Combat") and selectedTabIconColor or inactiveTabIconColor
end)

socialsTabBadge = nil

task.spawn(function()
    local socialsButton = tabButtons and tabButtons.Socials
    if not socialsButton or not socialsButton.Parent then
        return
    end

    local lucideStarIcon = tryGetLucideIcon("star")
    if lucideStarIcon then
        socialsButton.Image = lucideStarIcon.Url

        local starRectSize = lucideStarIcon.ImageRectSize
        local starRectOffset = lucideStarIcon.ImageRectOffset
        if starRectSize and starRectOffset and starRectSize.X > 0 and starRectSize.Y > 0 then
            socialsButton.ImageRectOffset = starRectOffset
            socialsButton.ImageRectSize = starRectSize
        else
            socialsButton.ImageRectOffset = Vector2.new(0, 0)
            socialsButton.ImageRectSize = Vector2.new(0, 0)
        end
    end

    socialsButton.ImageColor3 = (selectedTab == "Socials") and selectedTabIconColor or inactiveTabIconColor
end)

-- Content frames for each tab
local tabFrames = {}
for _, tabName in ipairs(tabList) do
    local frame = Instance.new("Frame")
    frame.Name = tabName .. "Frame"
    frame.Size = UDim2.new(1, -60, 1, 0)
    frame.Position = UDim2.new(0, 60, 0, 0)
    frame.BackgroundTransparency = 1
    frame.Visible = (tabName == selectedTab)
    frame.Parent = MainFrame
    tabFrames[tabName] = frame
end

-- Tab switching logic
function selectTab(tabName)
    if not tabFrames[tabName] then
        return
    end

    if tabSwitchBusy then
        return
    end

    local previousTab = selectedTab
    selectedTab = tabName

    for name, btn in pairs(tabButtons) do
        btn.ImageColor3 = (name == tabName) and selectedTabIconColor or inactiveTabIconColor
    end

    if socialsTabBadge then
        socialsTabBadge.ImageColor3 = (tabName == "Socials") and selectedTabIconColor or inactiveTabIconColor
    end

    if previousTab == tabName then
        for name, frame in pairs(tabFrames) do
            frame.Visible = (name == tabName)
            frame.Position = UDim2.new(0, 60, 0, 0)
        end
        return
    end

    local incoming = tabFrames[tabName]
    local outgoing = tabFrames[previousTab]
    if not incoming then
        return
    end

    tabSwitchBusy = true

    if outgoing and outgoing ~= incoming then
        outgoing.Visible = false
        outgoing.Position = UDim2.new(0, 60, 0, 0)
    end

    for name, frame in pairs(tabFrames) do
        if name ~= tabName and frame ~= outgoing then
            frame.Visible = false
            frame.Position = UDim2.new(0, 60, 0, 0)
        end
    end

    incoming.Visible = true
    incoming.Position = UDim2.new(0, 88, 0, 0)
    playTween(
        incoming,
        TweenInfo.new(0.16, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
        {Position = UDim2.new(0, 60, 0, 0)}
    )

    task.delay(0.16, function()
        tabSwitchBusy = false
    end)
end
for tabName, btn in pairs(tabButtons) do
    btn.MouseButton1Click:Connect(function()
        selectTab(tabName)
    end)
end
selectTab(selectedTab)

