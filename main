    if scriptUnloaded then
        return
    end
    if setWeaveGlideEnabledState then
        setWeaveGlideEnabledState(not weaveGlideEnabled, true)
    else
        weaveGlideEnabled = not weaveGlideEnabled
        setToggleSwitchState(weaveGlideToggle, weaveGlideToggleKnob, weaveGlideEnabled, true)
    end
end)

weaveGlideStrengthBox.FocusLost:Connect(function()
    if freeModeShouldBlockControl(weaveGlideStrengthBox, true) then
        weaveGlideStrengthBox.Text = string.format("%.2f", weaveGlideStrength)
        return
    end

    local parsedStrength = tonumber(weaveGlideStrengthBox.Text)
    if parsedStrength then
        setWeaveGlideStrengthValue(parsedStrength)
    else
        setWeaveGlideStrengthValue(weaveGlideStrength)
    end
end)

local loopWalkSpeedToggle, loopWalkSpeedToggleKnob, loopWalkSpeedToggleLabel = createToggleSwitch(tabFrames["Combat"], "Loop WalkSpeed", 572)
