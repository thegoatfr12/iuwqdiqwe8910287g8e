                titleLabel.Font = Enum.Font.GothamBold
                titleLabel.TextSize = 12
                titleLabel.TextXAlignment = Enum.TextXAlignment.Left
                titleLabel.ZIndex = 5

                if hasDetails then
                    local detailsLabel = Instance.new("TextLabel", card)
                    detailsLabel.Size = UDim2.new(1, -16, 0, 30)
                    detailsLabel.Position = UDim2.new(0, 8, 0, 40)
                    detailsLabel.BackgroundTransparency = 1
                    detailsLabel.Text = detailsText
                    detailsLabel.TextWrapped = true
                    detailsLabel.TextColor3 = activeThemeTextColor
                    detailsLabel.Font = Enum.Font.Gotham
                    detailsLabel.TextSize = 11
                    detailsLabel.TextXAlignment = Enum.TextXAlignment.Left
                    detailsLabel.TextYAlignment = Enum.TextYAlignment.Top
                    detailsLabel.ZIndex = 5
                end
            end
        end

        local totalHeight = settingsPnListLayout.AbsoluteContentSize.Y + 10
        settingsPnList.CanvasSize = UDim2.new(0, 0, 0, math.max(totalHeight, settingsPnList.AbsoluteSize.Y))
    end

    settingsPnListLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        if settingsPnList then
            local totalHeight = settingsPnListLayout.AbsoluteContentSize.Y + 10
            settingsPnList.CanvasSize = UDim2.new(0, 0, 0, math.max(totalHeight, settingsPnList.AbsoluteSize.Y))
        end
    end)

    local function updateSettingsPnFilterText()
        if settingsPnDateValue then
            settingsPnDateValue.Text = settingsPnDateFilters[settingsPnFilterIndex] or "All"
        end
    end

    local function cycleSettingsPnFilter(delta)
        local count = #settingsPnDateFilters
        if count <= 0 then
            return
        end

        settingsPnFilterIndex = settingsPnFilterIndex + delta
        if settingsPnFilterIndex < 1 then
            settingsPnFilterIndex = count
        elseif settingsPnFilterIndex > count then
            settingsPnFilterIndex = 1
        end

        updateSettingsPnFilterText()
        if rebuildSettingsPnList then
            rebuildSettingsPnList()
        end
    end

    connectButton(settingsPnPrevDateButton, function()
        cycleSettingsPnFilter(-1)
    end)

    connectButton(settingsPnNextDateButton, function()
        cycleSettingsPnFilter(1)
    end)

    settingsSwitchPage = function(targetPage, skipAnimation)
        local pageNumber = tonumber(targetPage)
        local resolvedTarget = math.clamp(math.floor(pageNumber or 1), 1, 2)
        local previousPage = settingsPageActive
        local pages = {
            settingsPageMain,
            settingsPagePn,
        }

        if settingsPageSwitchBusy and not skipAnimation then
            return
        end

        settingsPageActive = resolvedTarget

        if settingsPnNavMainButton then
            settingsPnNavMainButton.BackgroundColor3 = (settingsPageActive == 1) and activeThemeSecondaryColor or activeThemePanelColor
            settingsPnNavMainButton.BackgroundTransparency = (settingsPageActive == 1) and 0.03 or 0.1
        end
        if settingsPnNavPatchButton then
            settingsPnNavPatchButton.BackgroundColor3 = (settingsPageActive == 2) and activeThemeSecondaryColor or activeThemePanelColor
            settingsPnNavPatchButton.BackgroundTransparency = (settingsPageActive == 2) and 0.03 or 0.1
        end

        if settingsPageActive == 2 and rebuildSettingsPnList then
            rebuildSettingsPnList()
        end

        if skipAnimation or previousPage == settingsPageActive then
            for index, page in ipairs(pages) do
                if page then
                    page.Visible = index == settingsPageActive
                    if index < settingsPageActive then
                        page.Position = UDim2.new(-1, 0, 0, 0)
                    elseif index > settingsPageActive then
                        page.Position = UDim2.new(1, 0, 0, 0)
                    else
                        page.Position = UDim2.new(0, 0, 0, 0)
                    end
                end
            end
            return
        end

        local previousFrame = pages[previousPage]
        local targetFrame = pages[settingsPageActive]
        if not previousFrame or not targetFrame then
            return
        end

        settingsPageSwitchBusy = true
        local direction = (settingsPageActive > previousPage) and 1 or -1
        targetFrame.Visible = true
        targetFrame.Position = UDim2.new(direction, 0, 0, 0)

        playTween(previousFrame, TweenInfo.new(0.22, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
            Position = UDim2.new(-direction, 0, 0, 0),
        })
        playTween(targetFrame, TweenInfo.new(0.22, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
            Position = UDim2.new(0, 0, 0, 0),
        })

        task.delay(0.24, function()
            for index, page in ipairs(pages) do
                if page and index ~= settingsPageActive then
                    page.Visible = false
                end
            end
            settingsPageSwitchBusy = false
        end)
    end

    connectButton(settingsPnNavMainButton, function()
        if settingsSwitchPage then
            settingsSwitchPage(1)
        end
    end)

    connectButton(settingsPnNavPatchButton, function()
        if settingsSwitchPage then
            settingsSwitchPage(2)
        end
    end)

    updateSettingsPnFilterText()
    if rebuildSettingsPnList then
        rebuildSettingsPnList()
    end
    if settingsSwitchPage then
        settingsSwitchPage(1, true)
    end
end)

