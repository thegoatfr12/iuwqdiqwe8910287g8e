function createToggleSwitch(parent, labelText, yPos)
    local row = Instance.new("Frame", parent)
    row.Name = "ToggleRow"
    row.Size = UDim2.new(1, -20, 0, 28)
    row.Position = UDim2.new(0, 10, 0, yPos)
    row.BackgroundTransparency = 1
    pcall(function()
        row:SetAttribute("ToeToggleRow", true)
    end)

    local label = Instance.new("TextLabel", row)
    label.Name = "ToggleLabel"
    label.Size = UDim2.new(1, -60, 1, 0)
    label.Position = UDim2.new(0, 0, 0, 0)
    label.BackgroundTransparency = 1
    label.Text = labelText
    label.TextColor3 = activeThemeTextColor
    label.Font = Enum.Font.GothamBold
    label.TextSize = 15
    label.TextXAlignment = Enum.TextXAlignment.Left

    local toggle = Instance.new("TextButton", row)
    toggle.Name = "ToggleButton"
    toggle.Text = ""
    toggle.Size = UDim2.new(0, 44, 0, 24)
    toggle.Position = UDim2.new(1, -44, 0.5, -12)
    toggle.BackgroundColor3 = activeThemePanelColor
    toggle.BackgroundTransparency = 0.14
    toggle.BorderSizePixel = 0
    toggle.AutoButtonColor = false
    pcall(function()
        toggle:SetAttribute("ToeToggleButton", true)
    end)
    Instance.new("UICorner", toggle).CornerRadius = UDim.new(0, 12)

    local knob = Instance.new("Frame", toggle)
    knob.Name = "ToggleKnob"
    knob.Size = UDim2.new(0, 16, 0, 16)
    knob.Position = UDim2.new(0, 4, 0.5, -8)
    knob.BackgroundColor3 = activeThemeTextColor
    knob.BorderSizePixel = 0
    Instance.new("UICorner", knob).CornerRadius = UDim.new(1, 0)

    return toggle, knob, label
end

function isLikelyToggleButton(button)
    if not button or not button:IsA("TextButton") then
        return false
    end

    if button:GetAttribute("ToeToggleButton") == true then
        return true
    end

    if button.Text ~= "" then
        return false
    end

    if button.Size.X.Offset ~= 44 or button.Size.Y.Offset ~= 24 then
        return false
    end

    local row = button.Parent
    return row and row:IsA("Frame") and row:FindFirstChild("ToggleLabel") ~= nil
end

function isRedAccentColor(color)
    if typeof(color) ~= "Color3" then
        return false
    end

    local secondary = activeThemeSecondaryColor or Color3.fromRGB(230, 50, 50)
    local nearSecondary = math.abs(color.R - secondary.R) <= 0.07
        and math.abs(color.G - secondary.G) <= 0.07
        and math.abs(color.B - secondary.B) <= 0.07

    local redDominant = color.R >= 0.55
        and color.G <= 0.35
        and color.B <= 0.35
        and (color.R - math.max(color.G, color.B)) >= 0.18

    return nearSecondary or redDominant
end

function isFreeModeTitleLabel(label)
    if not label or not label:IsA("TextLabel") then
        return false
    end

    local labelName = string.lower(tostring(label.Name or ""))
    if labelName:find("title", 1, true) or labelName:find("sectionlabel", 1, true) then
        return true
    end

    local textLower = string.lower(tostring(label.Text or ""))
    if textLower == "combat settings"
        or textLower == "settings"
        or textLower == "hitbox"
        or textLower == "combat"
        or textLower == "customization" then
        return true
    end

    return false
end

function isSettingsHotkeysUiLabel(label)
    if not label or not label:IsA("TextLabel") then
        return false
    end

    if string.lower(tostring(label.Text or "")) ~= "ui" then
        return false
    end

    local current = label
    while current do
        local nameLower = string.lower(tostring(current.Name or ""))
        if nameLower == "settingspagemain" then
            return true
        end
        if tabFrames and current == tabFrames["Settings"] then
            return true
        end
        current = current.Parent
    end

    return false
end

function isFreeModeTitleDecoration(instance)
    if not instance then
        return false
    end

    if instance:IsA("TextLabel") and isFreeModeTitleLabel(instance) then
        return true
    end

    local nameLower = string.lower(tostring(instance.Name or ""))
    if nameLower:find("title", 1, true) or nameLower:find("underline", 1, true) or nameLower:find("section", 1, true) then
        return true
    end

    if instance:IsA("Frame") and instance.Size.Y.Offset <= 3 and instance.BackgroundTransparency < 1 then
        local parent = instance.Parent
        if tabFrames and parent and (
            parent == tabFrames["Combat"]
            or parent == tabFrames["Settings"]
            or parent == tabFrames["Customization"]
            or parent == tabFrames["Socials"]
        ) then
            return true
        end
    end

    return false
end

function isFreeModeCreditsInstance(instance)
    if not instance or not tabFrames then
        return false
    end

    local socialsFrame = tabFrames["Socials"]
    if not socialsFrame then
        return false
    end

    return instance == socialsFrame or instance:IsDescendantOf(socialsFrame)
end

function isFreeModePatchNotesInstance(instance)
    if not instance then
        return false
    end

    return settingsPagePn and (instance == settingsPagePn or instance:IsDescendantOf(settingsPagePn))
end

function applyBlockedToggleGreyStyle(toggle)
    if not toggle then
        return
    end

    toggle.Active = false
    toggle.AutoButtonColor = false
    pcall(function()
        toggle.Interactable = false
    end)

    if isRedAccentColor(toggle.BackgroundColor3) then
        toggle.BackgroundColor3 = freeModeGreyBackgroundColor
    end

    local knob = toggle:FindFirstChild("ToggleKnob")
    if knob and knob:IsA("Frame") and isRedAccentColor(knob.BackgroundColor3) then
        knob.BackgroundColor3 = freeModeGreyTextColor
    end

    local row = toggle.Parent
    if row then
        for _, child in ipairs(row:GetChildren()) do
            if child:IsA("TextLabel") and isRedAccentColor(child.TextColor3) then
                child.TextColor3 = freeModeGreyTextColor
            end
        end
    end
end

function isFreeModeAllowedToggleButton(toggle)
    return toggle == freeModeHitboxToggleButton
        or toggle == freeModeShowHitboxVisualsToggleButton
        or toggle == freeModeHeadlessToggleButton
end

function enforceFreeModeToggleGreyVisuals()
    if not MainFrame then
        return
    end

    if freeModeHitboxToggleButton and freeModeHitboxToggleButton.Parent then
        local hitboxKnob = freeModeHitboxToggleButton:FindFirstChild("ToggleKnob")
        if hitboxKnob and hitboxKnob:IsA("Frame") then
            freeModeHitboxToggleButton.Active = true
            pcall(function()
                freeModeHitboxToggleButton.Interactable = true
            end)
            setToggleSwitchState(freeModeHitboxToggleButton, hitboxKnob, hitboxEnabled, false)
        end

        for _, child in ipairs(freeModeHitboxToggleButton.Parent:GetChildren()) do
            if child:IsA("TextLabel") then
                child.TextColor3 = activeThemeTextColor
            end
        end
    end

    for _, obj in ipairs(MainFrame:GetDescendants()) do
        if isLikelyToggleButton(obj) and isFreeModeActive() and not isFreeModeAllowedToggleButton(obj) then
            applyBlockedToggleGreyStyle(obj)
        end
    end
end

function enforceFreeModeBlockedControlVisuals()
    if not MainFrame or not isFreeModeActive() then
        return
    end

    for _, obj in ipairs(MainFrame:GetDescendants()) do
        if obj:IsA("TextLabel") and isSettingsHotkeysUiLabel(obj) then
            obj.TextColor3 = Color3.fromRGB(255, 255, 255)
        elseif isFreeModeTitleDecoration(obj) then
            if obj:IsA("TextLabel") then
                obj.TextColor3 = activeThemeTextColor
            elseif obj:IsA("Frame") then
                local n = string.lower(tostring(obj.Name or ""))
                if n:find("underline", 1, true) then
                    obj.BackgroundColor3 = activeThemeSecondaryColor
                end
            end
        elseif obj:IsA("UIStroke") and obj.Parent and obj.Parent:IsA("TextBox") and freeModeIsControlAllowed(obj.Parent) then
            obj.Color = activeThemeSecondaryColor
            obj.Transparency = 0.02
        elseif not freeModeIsControlAllowed(obj) and not isFreeModeCreditsInstance(obj) and not isFreeModePatchNotesInstance(obj) then
            if obj:IsA("GuiObject") and not isFreeModeTitleDecoration(obj) and obj.BackgroundTransparency < 1 then
                obj.BackgroundColor3 = freeModeGreyBackgroundColor
            end

            if obj:IsA("TextBox") then
                obj.TextColor3 = freeModeGreyTextColor
                obj.PlaceholderColor3 = freeModeGreyTextColor
            elseif obj:IsA("TextLabel") then
                obj.TextColor3 = freeModeGreyTextColor
            elseif obj:IsA("TextButton") then
                obj.TextColor3 = freeModeGreyTextColor
            elseif obj:IsA("ImageLabel") or obj:IsA("ImageButton") then
                obj.ImageColor3 = freeModeGreyTextColor
            elseif obj:IsA("UIStroke") then
                obj.Color = freeModeGreyStrokeColor
                obj.Transparency = 0.05
            end
        end
    end

    if Title then
        Title.TextColor3 = activeThemeTextColor
    end
    if settingsPageTitle then
        settingsPageTitle.TextColor3 = activeThemeTextColor
    end
    if hitboxSectionLabel then
        hitboxSectionLabel.TextColor3 = activeThemeTextColor
    end
    if combatSectionLabel then
        combatSectionLabel.TextColor3 = activeThemeTextColor
    end
    if settingsHotkeyHeaderLabel then
        settingsHotkeyHeaderLabel.TextColor3 = activeThemeTextColor
    end
    if customizationPageTitle then
        customizationPageTitle.TextColor3 = Color3.fromRGB(245, 245, 245)
    end

    if combatPageTitleUnderline then
        combatPageTitleUnderline.BackgroundColor3 = freeModeAccentRed
    end
    if settingsPageTitleUnderline then
        settingsPageTitleUnderline.BackgroundColor3 = freeModeAccentRed
    end
    if hitboxSectionUnderline then
        hitboxSectionUnderline.BackgroundColor3 = freeModeAccentRed
    end
    if combatSectionUnderline then
        combatSectionUnderline.BackgroundColor3 = freeModeAccentRed
    end
    if settingsHotkeyUnderline then
        settingsHotkeyUnderline.BackgroundColor3 = freeModeAccentRed
    end
    if affectedPlayersBox then
        affectedPlayersBox.BackgroundColor3 = activeThemeMainColor
        affectedPlayersBox.BackgroundTransparency = currentMainUiTransparency
    end
    if affectedPlayersBoxStroke then
        affectedPlayersBoxStroke.Color = activeThemeSecondaryColor
        affectedPlayersBoxStroke.Transparency = 0.02
    end
    pcall(updateAffectedPlayersCountText)
end

function setToggleSwitchState(toggle, knob, enabled, animate)
    if not toggle or not knob then
        return
    end

    local blockedByFree = isFreeModeActive() and not isFreeModeAllowedToggleButton(toggle)
    local targetToggleColor = enabled and activeThemeSecondaryColor or activeThemePanelColor
    local targetToggleTransparency = enabled and 0.05 or 0.14
    local targetKnobPosition = enabled and UDim2.new(1, -20, 0.5, -8) or UDim2.new(0, 4, 0.5, -8)
    local targetKnobColor = activeThemeTextColor

    if blockedByFree then
        if isRedAccentColor(targetToggleColor) then
            targetToggleColor = freeModeGreyBackgroundColor
        end
        if isRedAccentColor(targetKnobColor) then
            targetKnobColor = freeModeGreyTextColor
        end
        toggle.Active = false
        pcall(function()
            toggle.Interactable = false
        end)
        toggle.AutoButtonColor = false
    end

    local row = toggle.Parent
    if row then
        for _, child in ipairs(row:GetChildren()) do
            if child:IsA("TextLabel") then
                if blockedByFree then
                    if isRedAccentColor(child.TextColor3) then
                        child.TextColor3 = freeModeGreyTextColor
                    end
                else
                    child.TextColor3 = activeThemeTextColor
                end
            end
        end
    end

    toggle.BackgroundColor3 = targetToggleColor
    toggle.BackgroundTransparency = targetToggleTransparency
    knob.BackgroundColor3 = targetKnobColor

    if not animate or blockedByFree then
        knob.Size = UDim2.new(0, 16, 0, 16)
        knob.Position = targetKnobPosition
        return
    end

    playTween(
        toggle,
        TweenInfo.new(0.14, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
        {
            BackgroundColor3 = targetToggleColor,
            BackgroundTransparency = targetToggleTransparency,
        }
    )

    local popPosition = enabled and UDim2.new(1, -22, 0.5, -9) or UDim2.new(0, 2, 0.5, -9)
    playTween(
        knob,
        TweenInfo.new(0.08, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
        {
            Size = UDim2.new(0, 18, 0, 18),
            Position = popPosition,
        }
    )

    task.delay(0.08, function()
        if knob and knob.Parent then
            playTween(
                knob,
                TweenInfo.new(0.1, Enum.EasingStyle.Back, Enum.EasingDirection.Out),
                {
                    Size = UDim2.new(0, 16, 0, 16),
                    Position = targetKnobPosition,
                }
            )
        end
    end)
end

local function attachSmallSliderKnob(fillFrame)
    if not fillFrame then
        return nil
    end

    local knob = Instance.new("Frame")
    knob.Name = "SliderKnob"
    knob.AnchorPoint = Vector2.new(0.5, 0.5)
    knob.Position = UDim2.new(1, 0, 0.5, 0)
    knob.Size = UDim2.new(0, 12, 0, 12)
    knob.BackgroundColor3 = Color3.fromRGB(245, 245, 245)
    knob.BorderSizePixel = 0
    knob.ZIndex = (fillFrame.ZIndex or 1) + 1
    knob.Parent = fillFrame

    local knobCorner = Instance.new("UICorner", knob)
    knobCorner.CornerRadius = UDim.new(1, 0)

    local knobStroke = Instance.new("UIStroke", knob)
    knobStroke.Color = Color3.fromRGB(230, 50, 50)
    knobStroke.Thickness = 1
    knobStroke.Transparency = 0.08
    knobStroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border

    return knob
end


