weaveGlideTierPopup = {}
weaveGlideTierPopup.Frame = Instance.new("Frame", tabFrames["Combat"])
weaveGlideTierPopup.Frame.Size = UDim2.new(0, 124, 0, 20)
weaveGlideTierPopup.Frame.Position = UDim2.new(0, 110, 0, 532)
weaveGlideTierPopup.Frame.BackgroundColor3 = Color3.fromRGB(24, 24, 24)
weaveGlideTierPopup.Frame.BackgroundTransparency = 1
