        local combatPresetSlots = {}
        combatPresetLoadButtons = {}
        combatPresetLoadButtonStrokes = {}
        combatPresetSaveButtons = {}
        combatPresetSaveButtonStrokes = {}

        local function trimPresetName(value)
            return tostring(value or ""):gsub("^%s+", ""):gsub("%s+$", "")
        end

        local function getSavedSettingsRootForPresetSlots()
            local persisted = loadPersistedSettingsData() or {}
            if type(persisted) ~= "table" then
                persisted = {}
            end

            local settingsRoot = nil
            if type(getSavedSettingsBlock) == "function" then
                settingsRoot = getSavedSettingsBlock(persisted)
            elseif type(persisted.SavedSettings) == "table" then
                settingsRoot = persisted.SavedSettings
            else
                settingsRoot = persisted
            end

            if type(settingsRoot) ~= "table" then
                settingsRoot = {}
                persisted = {SavedSettings = settingsRoot}
            end

            return persisted, settingsRoot
        end

        local function loadCombatPresetSlots()
            local persisted, settingsRoot = getSavedSettingsRootForPresetSlots()
            local storedSlots = type(settingsRoot.CombatPresetSlots) == "table" and settingsRoot.CombatPresetSlots or {}
            local loadedSlots = {}

            for i = 1, 10 do
                local slot = storedSlots[i]
                if type(slot) == "table" and type(slot.Snapshot) == "table" then
                    local slotName = trimPresetName(slot.Name)
                    if slotName == "" then
                        slotName = "Preset " .. tostring(i)
                    end
                    loadedSlots[i] = {
                        Name = slotName,
                        Snapshot = slot.Snapshot,
                        UICustomization = type(slot.UICustomization) == "table" and slot.UICustomization or nil,
                    }
                else
                    loadedSlots[i] = nil
                end
            end

            return persisted, settingsRoot, loadedSlots
        end

        local function persistCombatPresetSlots()
            local persisted, settingsRoot = getSavedSettingsRootForPresetSlots()
            settingsRoot.CombatPresetSlots = {}

            for i = 1, 10 do
                local slot = combatPresetSlots[i]
                if slot and type(slot.Snapshot) == "table" then
                    settingsRoot.CombatPresetSlots[i] = {
                        Name = trimPresetName(slot.Name) ~= "" and trimPresetName(slot.Name) or ("Preset " .. tostring(i)),
                        Snapshot = slot.Snapshot,
                        UICustomization = type(slot.UICustomization) == "table" and slot.UICustomization or nil,
                    }
                else
                    settingsRoot.CombatPresetSlots[i] = nil
                end
            end

            return persistSettingsData(persisted)
        end

        local function refreshCombatPresetSlotButtons()
            for i = 1, 10 do
                local loadButton = combatPresetLoadButtons[i]
                local loadStroke = combatPresetLoadButtonStrokes and combatPresetLoadButtonStrokes[i]
                local saveButton = combatPresetSaveButtons and combatPresetSaveButtons[i]
                local saveStroke = combatPresetSaveButtonStrokes and combatPresetSaveButtonStrokes[i]
                if loadButton then
                    local slot = combatPresetSlots[i]
                    if slot and type(slot.Snapshot) == "table" then
                        local slotName = trimPresetName(slot.Name)
                        if slotName == "" then
                            slotName = "Preset " .. tostring(i)
                        end
                        local uiTag = slot.UICustomization and " +UI" or ""
                        loadButton.Text = slotName .. uiTag
                        loadButton.TextXAlignment = Enum.TextXAlignment.Left
                        loadButton.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
                        loadButton.BackgroundTransparency = 0.12
                        loadButton.TextColor3 = Color3.fromRGB(255, 255, 255)
                    else
                        loadButton.Text = "Empty"
                        loadButton.TextXAlignment = Enum.TextXAlignment.Center
                        loadButton.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
                        loadButton.BackgroundTransparency = 0.12
                        loadButton.TextColor3 = Color3.fromRGB(255, 255, 255)
                    end

                    if loadStroke then
                        loadStroke.Color = Color3.fromRGB(230, 50, 50)
                        loadStroke.Transparency = 0.1
                        loadStroke.Thickness = 1.2
                    end

                    if saveButton then
                        saveButton.BackgroundColor3 = Color3.fromRGB(230, 50, 50)
                        saveButton.BackgroundTransparency = 0.04
                        saveButton.TextColor3 = Color3.fromRGB(255, 255, 255)
                    end

                    if saveStroke then
                        saveStroke.Color = Color3.fromRGB(230, 50, 50)
                        saveStroke.Transparency = 0.08
                        saveStroke.Thickness = 1.2
                    end
                end
            end
        end

        local function findFirstEmptyCombatPresetSlot()
            for i = 1, 10 do
                local slot = combatPresetSlots[i]
                if not slot or type(slot.Snapshot) ~= "table" then
                    return i
                end
            end
            return nil
        end

