    if freeModeShouldBlockControl(mouseSensitivitySliderBar, true) then
        return
    end

    if inp.UserInputType == Enum.UserInputType.MouseButton1 then
        mouseSensitivitySliderDragging = true
        setMouseSensitivityMultiplier(mouseSensitivityPosToValue(inp.Position.X))
    end
end)

