local lowGraphicsCapturedDefaults = false
local lowGraphicsLightingDefaults = {}
local lowGraphicsTerrainDefaults = {}
local lowGraphicsObjectStates = setmetatable({}, {__mode = "k"})
local lowGraphicsDescendantConn

local LOW_GRAPHICS_EFFECT_CLASSES = {
    BloomEffect = true,
    BlurEffect = true,
    SunRaysEffect = true,
    ColorCorrectionEffect = true,
    DepthOfFieldEffect = true,
}

local LOW_GRAPHICS_RELEVANT_CLASSES = {
    Decal = true,
    Texture = true,
    ParticleEmitter = true,
    Trail = true,
    Beam = true,
    Smoke = true,
    Fire = true,
    Sparkles = true,
    BloomEffect = true,
    BlurEffect = true,
    SunRaysEffect = true,
    ColorCorrectionEffect = true,
    DepthOfFieldEffect = true,
}

local LOW_GRAPHICS_DECAL_TRANSPARENCY = 0.45

local function isLowGraphicsRelevantInstance(instance)
    return instance and LOW_GRAPHICS_RELEVANT_CLASSES[instance.ClassName] == true
end

local function cacheObjectProperty(instance, propertyName)
    local props = lowGraphicsObjectStates[instance]
    if not props then
        props = {}
        lowGraphicsObjectStates[instance] = props
    end

    if props[propertyName] ~= nil then
        return
    end

    local ok, value = pcall(function()
        return instance[propertyName]
    end)
    if ok then
        props[propertyName] = value
    end
end

local function setCachedObjectProperty(instance, propertyName, newValue)
    cacheObjectProperty(instance, propertyName)
    pcall(function()
        instance[propertyName] = newValue
    end)
end

local function applyLowGraphicsToInstance(instance)
    if not isLowGraphicsRelevantInstance(instance) then
        return
    end

    if instance:IsA("Decal") or instance:IsA("Texture") then
        cacheObjectProperty(instance, "Transparency")
        local ok, decalTransparency = pcall(function()
            return instance.Transparency
        end)
        if ok then
            pcall(function()
                instance.Transparency = math.max(decalTransparency, LOW_GRAPHICS_DECAL_TRANSPARENCY)
            end)
        end
        return
    end

    if instance:IsA("ParticleEmitter") then
        setCachedObjectProperty(instance, "Enabled", false)
        return
    end

    if instance:IsA("Trail")
        or instance:IsA("Beam")
        or instance:IsA("Smoke")
        or instance:IsA("Fire")
        or instance:IsA("Sparkles") then
        setCachedObjectProperty(instance, "Enabled", false)
        return
    end

    if LOW_GRAPHICS_EFFECT_CLASSES[instance.ClassName] then
        setCachedObjectProperty(instance, "Enabled", false)
    end
end

local function setLowGraphicsMode(enabled)
    if lowGraphicsEnabled == enabled then
        return
    end

    if enabled then
        if not lowGraphicsCapturedDefaults then
            lowGraphicsCapturedDefaults = true

            local okShadows, shadows = pcall(function()
                return Lighting.GlobalShadows
            end)
            if okShadows then
                lowGraphicsLightingDefaults.GlobalShadows = shadows
            end

            local okFogStart, fogStart = pcall(function()
                return Lighting.FogStart
            end)
            if okFogStart then
                lowGraphicsLightingDefaults.FogStart = fogStart
            end

            local okFogEnd, fogEnd = pcall(function()
                return Lighting.FogEnd
            end)
            if okFogEnd then
                lowGraphicsLightingDefaults.FogEnd = fogEnd
            end

            local terrain = Workspace:FindFirstChildOfClass("Terrain")
            if terrain then
                local okWaveSize, waveSize = pcall(function()
                    return terrain.WaterWaveSize
                end)
                if okWaveSize then
                    lowGraphicsTerrainDefaults.WaterWaveSize = waveSize
                end

                local okWaveSpeed, waveSpeed = pcall(function()
                    return terrain.WaterWaveSpeed
                end)
                if okWaveSpeed then
                    lowGraphicsTerrainDefaults.WaterWaveSpeed = waveSpeed
                end

                local okWaterReflectance, waterReflectance = pcall(function()
                    return terrain.WaterReflectance
                end)
                if okWaterReflectance then
                    lowGraphicsTerrainDefaults.WaterReflectance = waterReflectance
                end
            end
        end

        pcall(function()
            Lighting.GlobalShadows = false
        end)
        pcall(function()
            Lighting.FogStart = 0
            Lighting.FogEnd = 25000
        end)

        local terrain = Workspace:FindFirstChildOfClass("Terrain")
        if terrain then
            pcall(function()
                terrain.WaterWaveSize = 0.05
                terrain.WaterWaveSpeed = 0.05
                terrain.WaterReflectance = 0.02
            end)
        end

        for _, child in ipairs(Lighting:GetChildren()) do
            applyLowGraphicsToInstance(child)
        end

        for _, descendant in ipairs(Workspace:GetDescendants()) do
            if isLowGraphicsRelevantInstance(descendant) then
                applyLowGraphicsToInstance(descendant)
            end
        end

        if lowGraphicsDescendantConn then
            lowGraphicsDescendantConn:Disconnect()
            lowGraphicsDescendantConn = nil
        end
        lowGraphicsDescendantConn = Workspace.DescendantAdded:Connect(function(descendant)
            if isLowGraphicsRelevantInstance(descendant) then
                applyLowGraphicsToInstance(descendant)
            end
        end)
    else
        if lowGraphicsDescendantConn then
            lowGraphicsDescendantConn:Disconnect()
            lowGraphicsDescendantConn = nil
        end

        for instance, props in pairs(lowGraphicsObjectStates) do
            for propertyName, value in pairs(props) do
                pcall(function()
                    instance[propertyName] = value
                end)
            end
        end
        lowGraphicsObjectStates = setmetatable({}, {__mode = "k"})

        if lowGraphicsCapturedDefaults then
            if lowGraphicsLightingDefaults.GlobalShadows ~= nil then
                pcall(function()
                    Lighting.GlobalShadows = lowGraphicsLightingDefaults.GlobalShadows
                end)
            end
            if lowGraphicsLightingDefaults.FogStart ~= nil then
                pcall(function()
                    Lighting.FogStart = lowGraphicsLightingDefaults.FogStart
                end)
            end
            if lowGraphicsLightingDefaults.FogEnd ~= nil then
                pcall(function()
                    Lighting.FogEnd = lowGraphicsLightingDefaults.FogEnd
                end)
            end

            local terrain = Workspace:FindFirstChildOfClass("Terrain")
            if terrain then
                if lowGraphicsTerrainDefaults.WaterWaveSize ~= nil then
                    pcall(function()
                        terrain.WaterWaveSize = lowGraphicsTerrainDefaults.WaterWaveSize
                    end)
                end
                if lowGraphicsTerrainDefaults.WaterWaveSpeed ~= nil then
                    pcall(function()
                        terrain.WaterWaveSpeed = lowGraphicsTerrainDefaults.WaterWaveSpeed
                    end)
                end
                if lowGraphicsTerrainDefaults.WaterReflectance ~= nil then
                    pcall(function()
                        terrain.WaterReflectance = lowGraphicsTerrainDefaults.WaterReflectance
                    end)
                end
            end
        end
    end

    lowGraphicsEnabled = enabled
end

local earlyStatusGui

local function getEarlyGuiParent()
    local localPlayer = Players.LocalPlayer
    if localPlayer then
        local playerGui = localPlayer:FindFirstChildOfClass("PlayerGui")
        if playerGui then
            return playerGui
        end
    end

    if type(gethui) == "function" then
        local ok, guiParent = pcall(gethui)
        if ok and guiParent then
            return guiParent
        end
    end

    local ok, coreGui = pcall(function()
        return game:GetService("CoreGui")
    end)
    if ok and coreGui then
        return coreGui
    end

    return nil
end

local function setEarlyStatus(text, isError)
    if not STARTUP_TOP_STATUS_ENABLED then
        return
    end

    local guiParent = getEarlyGuiParent()
    if not guiParent then
        warn("[ToeBootstrap] " .. tostring(text or ""))
        return
    end

    local ok = pcall(function()
        if not earlyStatusGui then
            earlyStatusGui = Instance.new("ScreenGui")
            earlyStatusGui.Name = "ToeEarlyStatusGui"
            earlyStatusGui.ResetOnSpawn = false
            earlyStatusGui.Parent = guiParent

            local label = Instance.new("TextLabel")
            label.Name = "StatusLabel"
            label.Size = UDim2.new(0, 320, 0, 38)
            label.Position = UDim2.new(0.5, -160, 0, 12)
            label.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
            label.BorderSizePixel = 0
            label.TextColor3 = Color3.fromRGB(255, 255, 255)
            label.Font = Enum.Font.GothamBold
            label.TextSize = 14
            label.Parent = earlyStatusGui
        end

        local label = earlyStatusGui:FindFirstChild("StatusLabel")
        if label then
            label.Text = tostring(text or "")
            label.BackgroundColor3 = isError and Color3.fromRGB(90, 20, 20) or Color3.fromRGB(20, 20, 20)
            label.TextColor3 = isError and Color3.fromRGB(255, 200, 200) or Color3.fromRGB(255, 255, 255)
        end
    end)

    if not ok then
        earlyStatusGui = nil
    end
end

local function appendBootTrace(text)
    if type(writefile) ~= "function" then
        return
    end

    if type(makefolder) == "function" and type(isfolder) == "function" and not isfolder(AUTH_CACHE_FOLDER) then
        pcall(makefolder, AUTH_CACHE_FOLDER)
    end

    local line = os.date("!%Y-%m-%dT%H:%M:%SZ") .. " | " .. tostring(text or "") .. "\n"
    pcall(function()
        if type(appendfile) == "function" then
            appendfile(BOOT_TRACE_FILE, line)
        else
            writefile(BOOT_TRACE_FILE, line)
        end
    end)
end

local function emitRuntimeSignal(text, isError)
    local message = tostring(text or "")
    warn("[ToeBootstrap] " .. message)
    appendBootTrace(message)

    if isError then
        setEarlyStatus(message, true)
    end
end

local function runtimeErrorHandler(err)
    local message = "Fatal: " .. tostring(err)
    local ok, trace = pcall(function()
        return debug.traceback(message, 2)
    end)

    warn("[ToeBootstrap] " .. tostring(ok and trace or message))

    emitRuntimeSignal(ok and trace or message, true)
    return ok and trace or message
end

local function main()

setEarlyStatus("Waiting for LocalPlayer...", false)

local LocalPlayer = Players.LocalPlayer
local nextLocalPlayerStatusAt = tick() + 5
while not LocalPlayer do
    task.wait(0.2)
    LocalPlayer = Players.LocalPlayer
    if not LocalPlayer and tick() >= nextLocalPlayerStatusAt then
        setEarlyStatus("Still waiting for LocalPlayer...", false)
        nextLocalPlayerStatusAt = tick() + 5
    end
end

setEarlyStatus("Waiting for PlayerGui...", false)

local PlayerGui = LocalPlayer:FindFirstChildOfClass("PlayerGui")
local nextPlayerGuiStatusAt = tick() + 5
while not PlayerGui do
    task.wait(0.2)
    PlayerGui = LocalPlayer:FindFirstChildOfClass("PlayerGui")
    if not PlayerGui then
        PlayerGui = getEarlyGuiParent()
        if PlayerGui and PlayerGui ~= LocalPlayer:FindFirstChildOfClass("PlayerGui") then
            emitRuntimeSignal("PlayerGui missing. Using CoreGui/gethui fallback.", false)
            break
        end

        if tick() >= nextPlayerGuiStatusAt then
            setEarlyStatus("Still waiting for PlayerGui...", false)
            nextPlayerGuiStatusAt = tick() + 5
        end
    end
end

if not PlayerGui then
    emitRuntimeSignal("No PlayerGui and no CoreGui/gethui fallback found. UI cannot be created.", true)
    setEarlyStatus("No GUI parent found. UI cannot be created.", true)
    return
end

local function destroyNamedStatusGui(parentRef, guiName)
    if not parentRef or type(guiName) ~= "string" or guiName == "" then
        return
    end

    local existing = parentRef:FindFirstChild(guiName)
    if existing and existing:IsA("ScreenGui") then
        pcall(function()
            existing:Destroy()
        end)
    end
end

destroyNamedStatusGui(PlayerGui, "ToeEarlyStatusGui")
destroyNamedStatusGui(PlayerGui, "ToePreflightGui")
local earlyParent = getEarlyGuiParent()
if earlyParent and earlyParent ~= PlayerGui then
    destroyNamedStatusGui(earlyParent, "ToeEarlyStatusGui")
    destroyNamedStatusGui(earlyParent, "ToePreflightGui")
end

local preflightGui

local function createPreflightGui()
    if not PlayerGui then
        return
    end

    local ok = pcall(function()
        preflightGui = Instance.new("ScreenGui")
        preflightGui.Name = "ToePreflightGui"
        preflightGui.ResetOnSpawn = false
        preflightGui.Parent = PlayerGui

        local label = Instance.new("TextLabel")
        label.Name = "PreflightLabel"
        label.Size = UDim2.new(0, 240, 0, 36)
        label.Position = UDim2.new(0.5, -120, 0, 12)
        label.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
        label.BorderSizePixel = 0
        label.Text = "Script started"
        label.TextColor3 = Color3.fromRGB(255, 255, 255)
        label.Font = Enum.Font.GothamBold
        label.TextSize = 14
        label.Parent = preflightGui
    end)

    if not ok then
        preflightGui = nil
    end
end

if STARTUP_TOP_STATUS_ENABLED then
    createPreflightGui()
end

local function getGuiParent()
    return PlayerGui
end

