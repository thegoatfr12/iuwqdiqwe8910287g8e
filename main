function isFreeModeActive()
    return freeModeEnabled == true or freeAuthSession == true
end

function freeModeIsControlAllowed(instance)
    if not isFreeModeActive() then
        return true
    end

    if not instance then
        return false
    end

    if instance == freeModeHitboxToggleButton
        or instance == freeModeHeadlessToggleButton
        or instance == freeModeShowHitboxVisualsToggleButton
        or instance == hitboxToggleHotkeyBox
        or instance == toggleKeyBox
        or instance == (mainUiTransparency and mainUiTransparency.frame)
        or instance == (mainUiTransparency and mainUiTransparency.bar)
        or instance == (mainUiTransparency and mainUiTransparency.fill)
        or instance == (mainUiTransparency and mainUiTransparency.valueLabel)
        or instance == hitboxSliderFrame
        or instance == hitboxSliderBar
        or instance == hitboxSliderFill
        or instance == hitboxTextBox
        or instance == punchSliderFrame
        or instance == punchSliderBar
        or instance == punchSliderFill
        or instance == punchTextBox
        or instance == combatPage1Button
        or instance == combatPage2Button
        or instance == settingsPnNavMainButton
        or instance == settingsPnNavPatchButton
        or instance == Sidebar
        or instance == affectedPlayersBox
        or instance == mainFrameCollapseButton
        or instance == mainFrameMinimizedTab
        or instance == TouchToggleButton then
        return true
    end

    if tabButtons then
        for _, button in pairs(tabButtons) do
            if instance == button then
                return true
            end
        end
    end

    local current = instance
    while current do
        if current == hitboxSliderFrame
            or current == freeModeHitboxToggleRow
            or current == hitboxToggleHotkeyBox
            or current == punchSliderFrame
            or current == affectedPlayersBox
            or current == (mainUiTransparency and mainUiTransparency.frame)
            or current == freeModeHeadlessToggleRow
            or current == freeModeShowHitboxVisualsToggleRow
            or current == settingsPnNav
            or current == Sidebar then
            return true
        end
        current = current.Parent
    end

    return false
end

function freeModeShouldBlockControl(instance, announce)
    if not isFreeModeActive() then
        return false
    end

    if freeModeIsControlAllowed(instance) then
        return false
    end

    if announce and type(showStatus) == "function" then
        showStatus("Free mode lock: this control is disabled.", true)
    end

    return true
end
